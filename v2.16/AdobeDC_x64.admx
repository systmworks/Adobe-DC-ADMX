    <!-- Cloud and Connectors > OneDrive Connector -->
    <!-- bOneDriveConnectorEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_10066 -->
    <policy class="Machine" displayName="$(string.bOneDriveConnectorEnabledDC_x64)" explainText="$(string.bOneDriveConnectorEnabledDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
      name="bOneDriveConnectorEnabledDC_x64" valueName="bOneDriveConnectorEnabled">
