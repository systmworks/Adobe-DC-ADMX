    <!-- ADC4275034   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureState.html -->
    <policy class="Machine" displayName="$(string.ADC4275034DC_x64)" explainText="$(string.ADC4275034DC_x64_Explain)" key="SOFTWARE\Adobe\Adobe Acrobat\DC\FeatureState"
      name="ADC4275034DC_x64" valueName="ADC4275034">
