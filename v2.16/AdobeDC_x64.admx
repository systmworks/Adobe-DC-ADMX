    <policy class="Machine" displayName="$(string.ProtectOldExperienceDC_x64)" explainText="$(string.ProtectOldExperienceDC_x64_Explain)" key="SOFTWARE\Adobe\Adobe Acrobat\DC\FeatureState"
      name="ProtectOldExperienceDC_x64" valueName="ProtectOldExperience">
