    <!-- ======================================== -->
    <!--        Context, Tools and Search         -->
    <!-- ======================================== -->

    <!-- Context, Tools and Search > Auto UI Density Detection -->
    <!-- bUIDensityAutoDetectionEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html -->
    <policy class="Machine" displayName="$(string.bUIDensityAutoDetectionEnabledDC_x64)" explainText="$(string.bUIDensityAutoDetectionEnabledDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
      name="bUIDensityAutoDetectionEnabledDC_x64" valueName="bUIDensityAutoDetectionEnabled">
      <parentCategory ref="ContextToolsSearchCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Click-to-Edit Mode -->
    <!-- ADC4275035_ClickEdit   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureState.html -->
    <policy class="Machine" displayName="$(string.ADC4275035_ClickEditDC_x64)" explainText="$(string.ADC4275035_ClickEditDC_x64_Explain)" key="SOFTWARE\Adobe\Adobe Acrobat\DC\FeatureState"
      name="ADC4275035_ClickEditDC_x64" valueName="ADC4275035_ClickEdit">
      <parentCategory ref="ContextToolsSearchCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="1" />
