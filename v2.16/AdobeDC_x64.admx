    <policy class="Machine" displayName="$(string.bEnableRCMNewPOPUpDC_x64)" explainText="$(string.bEnableRCMNewPOPUpDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
      name="bEnableRCMNewPOPUpDC_x64" valueName="bEnableRCMNewPOPUp">
