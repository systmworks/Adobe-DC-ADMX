    <!-- Context, Tools and Search > Cloud-Powered Search -->
    <!-- bEnableCloudPoweredSearch   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_12671 -->
    <policy class="Machine" displayName="$(string.bEnableCloudPoweredSearchDC_x64)" explainText="$(string.bEnableCloudPoweredSearchDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
      name="bEnableCloudPoweredSearchDC_x64" valueName="bEnableCloudPoweredSearch">
      <parentCategory ref="ContextToolsSearchCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
