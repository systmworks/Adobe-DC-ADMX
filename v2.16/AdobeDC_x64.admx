      name="bEnableCloudPoweredSearchTokenCachingDC_x64" valueName="bEnableCloudPoweredSearchTokenCaching">
      <parentCategory ref="ContextToolsSearchCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
