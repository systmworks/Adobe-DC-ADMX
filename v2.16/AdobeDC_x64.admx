    <!-- Context, Tools and Search > Contextual Help Tips -->
    <!-- bEnableContextualTips   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html -->
    <policy class="Machine" displayName="$(string.bEnableContextualTipsDC_x64)" explainText="$(string.bEnableContextualTipsDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
      name="bEnableContextualTipsDC_x64" valueName="bEnableContextualTips">
      <parentCategory ref="ContextToolsSearchCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
