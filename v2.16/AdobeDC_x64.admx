    <!-- Updates and Desktop Integration > Update Watchdog Interval (Days) -->
    <!-- iInterval   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/Updater-Win.html -->
    <policy class="Machine" displayName="$(string.iInterval_x64)" explainText="$(string.iInterval_x64_Explain)" key="SOFTWARE\Adobe\Adobe ARM\1.0\ARM"
      name="iInterval_x64" valueName="iInterval" presentation="$(presentation.iInterval_x64_enum)">
      <parentCategory ref="UpdatesDesktopCategory_x64"/>
      <supportedOn ref="SupportedReaderDC_x64"/>
      <elements>
        <enum id="iInterval_x64_enum" valueName="iInterval">
          <item displayName="$(string.iInterval_x64_opt0)">
            <value>
              <decimal value="90" />
            </value>
          </item>
          <item displayName="$(string.iInterval_x64_opt1)">
            <value>
              <decimal value="135" />
            </value>
          </item>
          <item displayName="$(string.iInterval_x64_opt2)">
            <value>
              <decimal value="180" />
            </value>
          </item>
          <item displayName="$(string.iInterval_x64_opt3)">
            <value>
              <decimal value="365" />
            </value>
          </item>
        </enum>
      </elements>
    </policy>

