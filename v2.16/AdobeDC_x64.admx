    <!-- bEnableContextualToolbar   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html -->
    <policy class="Machine" displayName="$(string.bEnableContextualToolbarDC_x64)" explainText="$(string.bEnableContextualToolbarDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
      name="bEnableContextualToolbarDC_x64" valueName="bEnableContextualToolbar">
      <parentCategory ref="ContextToolsSearchCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="1" />
