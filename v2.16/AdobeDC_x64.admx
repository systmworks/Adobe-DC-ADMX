<policyDefinitions xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  revision="2.16" schemaVersion="1.0"
  xmlns="http://schemas.microsoft.com/GroupPolicy/2006/07/PolicyDefinitions">
  <policyNamespaces>
    <target prefix="Adobe_x64" namespace="Adobe.Policies.Adobe_x64" />
  </policyNamespaces>
  <resources minRequiredRevision="2.16" />
  <supportedOn>
    <definitions>
      <definition displayName="$(string.SupportedAcrobatDC_x64)" name="SupportedAcrobatDC_x64"/>
      <definition displayName="$(string.SupportedReaderDC_x64)" name="SupportedReaderDC_x64"/>
    </definitions>
  </supportedOn>

  <categories>
    <!-- Parent Category -->
    <category displayName="$(string.AdobeCategory_x64)" name="AdobeCategory_x64"/>

    <!-- Acrobat DC (x64) Category -->
    <category displayName="$(string.AcrobatDCCategory_x64)" name="AcrobatDCCategory_x64">
      <parentCategory ref="AdobeCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_CloudConnectors_x64)" name="CloudConnectorsCategoryDC_x64">
      <parentCategory ref="AcrobatDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_ContextToolsSearch_x64)" name="ContextToolsSearchCategoryDC_x64">
      <parentCategory ref="AcrobatDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_DocsEditAccess_x64)" name="DocsEditAccessCategoryDC_x64">
      <parentCategory ref="AcrobatDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_SecurityExec_x64)" name="SecurityExecCategoryDC_x64">
      <parentCategory ref="AcrobatDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_SecurityTrust_x64)" name="SecurityTrustCategoryDC_x64">
      <parentCategory ref="AcrobatDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_SharingFeatures_x64)" name="SharingFeaturesCategoryDC_x64">
      <parentCategory ref="AcrobatDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_StartupExperience_x64)" name="StartupExperienceCategoryDC_x64">
      <parentCategory ref="AcrobatDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_UpdatesDesktop_x64)" name="UpdatesDesktopCategoryDC_x64">
      <parentCategory ref="AcrobatDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_Upsell_x64)" name="UpsellCategoryDC_x64">
      <parentCategory ref="AcrobatDCCategory_x64"/>
    </category>

    <!-- Reader DC (x64) Category -->
    <category displayName="$(string.ReaderDCCategory_x64)" name="ReaderDCCategory_x64">
      <parentCategory ref="AdobeCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_CloudConnectors_x64)" name="CloudConnectorsCategory_x64">
      <parentCategory ref="ReaderDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_ContextToolsSearch_x64)" name="ContextToolsSearchCategory_x64">
      <parentCategory ref="ReaderDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_DocsEditAccess_x64)" name="DocsEditAccessCategory_x64">
      <parentCategory ref="ReaderDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_SecurityExec_x64)" name="SecurityExecCategory_x64">
      <parentCategory ref="ReaderDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_SecurityTrust_x64)" name="SecurityTrustCategory_x64">
      <parentCategory ref="ReaderDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_SharingFeatures_x64)" name="SharingFeaturesCategory_x64">
      <parentCategory ref="ReaderDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_StartupExperience_x64)" name="StartupExperienceCategory_x64">
      <parentCategory ref="ReaderDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_UpdatesDesktop_x64)" name="UpdatesDesktopCategory_x64">
      <parentCategory ref="ReaderDCCategory_x64"/>
    </category>
    <category displayName="$(string.Cat_Upsell_x64)" name="UpsellCategory_x64">
      <parentCategory ref="ReaderDCCategory_x64"/>
    </category>

  </categories>
  <policies>

    <!-- ======================================== -->
    <!--                                          -->
    <!--    Adobe Acrobat DC (x64) - policies     -->
    <!--                                          -->
    <!-- ======================================== -->

    <!-- ======================================== -->
    <!--           Cloud and Connectors           -->
    <!-- ======================================== -->

    <!-- Cloud and Connectors > Adobe Fill and Sign -->
    <!-- bToggleFillSign   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9299 -->
    <policy class="Machine" displayName="$(string.bToggleFillSignDC_x64)" explainText="$(string.bToggleFillSignDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
      name="bToggleFillSignDC_x64" valueName="bToggleFillSign">
      <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="0" />
      </enabledValue>
      <disabledValue>
        <decimal value="1" />
      </disabledValue>
    </policy>

    <!-- Cloud and Connectors > Box Cloud Connector -->
    <!-- bBoxConnectorEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9966 -->
    <policy class="Machine" displayName="$(string.bBoxConnectorEnabledDC_x64)" explainText="$(string.bBoxConnectorEnabledDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
      name="bBoxConnectorEnabledDC_x64" valueName="bBoxConnectorEnabled">
      <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Cloud and Connectors > Document Cloud Services -->
    <!-- bToggleAdobeDocumentServices   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9204 -->
    <policy class="Machine" displayName="$(string.bToggleAdobeDocumentServicesDC_x64)" explainText="$(string.bToggleAdobeDocumentServicesDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
      name="bToggleAdobeDocumentServicesDC_x64" valueName="bToggleAdobeDocumentServices">
      <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="0" />
      </enabledValue>
      <disabledValue>
        <decimal value="1" />
      </disabledValue>
    </policy>

    <!-- Cloud and Connectors > Document Cloud Storage -->
    <!-- bToggleDocumentCloud   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9877 -->
    <policy class="Machine" displayName="$(string.bToggleDocumentCloudDC_x64)" explainText="$(string.bToggleDocumentCloudDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
      name="bToggleDocumentCloudDC_x64" valueName="bToggleDocumentCloud">
      <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="0" />
      </enabledValue>
      <disabledValue>
        <decimal value="1" />
      </disabledValue>
    </policy>

    <!-- Cloud and Connectors > Dropbox Cloud Connector -->
    <!-- bDropboxConnectorEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_10016 -->
    <policy class="Machine" displayName="$(string.bDropboxConnectorEnabledDC_x64)" explainText="$(string.bDropboxConnectorEnabledDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
      name="bDropboxConnectorEnabledDC_x64" valueName="bDropboxConnectorEnabled">
      <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Cloud and Connectors > Generative AI Technology -->
    <!-- bEnableGentech   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html -->
    <policy class="Machine" displayName="$(string.bEnableGentechDC_x64)" explainText="$(string.bEnableGentechDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
      name="bEnableGentechDC_x64" valueName="bEnableGentech">
      <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Cloud and Connectors > Google Drive Connector -->
    <!-- bGoogleDriveConnectorEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_10116 -->
    <policy class="Machine" displayName="$(string.bGoogleDriveConnectorEnabledDC_x64)" explainText="$(string.bGoogleDriveConnectorEnabledDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
      name="bGoogleDriveConnectorEnabledDC_x64" valueName="bGoogleDriveConnectorEnabled">
      <parentCategory ref="CloudConnectorsCategoryDC_x64"/>
      <supportedOn ref="SupportedAcrobatDC_x64"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
