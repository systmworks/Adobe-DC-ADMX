    <!-- Context, Tools and Search > Online Actions Library Link -->
    <!-- bFindMoreWorkflowsOnline   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_11507 -->
    <policy class="Machine" displayName="$(string.bFindMoreWorkflowsOnlineDC_x64)" explainText="$(string.bFindMoreWorkflowsOnlineDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
      name="bFindMoreWorkflowsOnlineDC_x64" valueName="bFindMoreWorkflowsOnline">
      <parentCategory ref="ContextToolsSearchCategoryDC_x64"/>
