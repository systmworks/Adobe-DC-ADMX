    <policy class="Machine" displayName="$(string.bSuppressSignOutDC_x64)" explainText="$(string.bSuppressSignOutDC_x64_Explain)" key="SOFTWARE\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
      name="bSuppressSignOutDC_x64" valueName="bSuppressSignOut">
