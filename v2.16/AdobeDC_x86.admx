<policyDefinitions xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  revision="2.16" schemaVersion="1.0"
  xmlns="http://schemas.microsoft.com/GroupPolicy/2006/07/PolicyDefinitions">
  <policyNamespaces>
    <target prefix="Adobe_x86" namespace="Adobe.Policies.Adobe_x86" />
  </policyNamespaces>
  <resources minRequiredRevision="2.16" />
  <supportedOn>
    <definitions>
      <definition displayName="$(string.SupportedAcrobatDC_x86)" name="SupportedAcrobatDC_x86"/>
      <definition displayName="$(string.SupportedReaderDC_x86)" name="SupportedReaderDC_x86"/>
    </definitions>
  </supportedOn>

  <categories>
    <!-- Parent Category -->
    <category displayName="$(string.AdobeCategory_x86)" name="AdobeCategory_x86"/>

    <!-- Acrobat DC (x86) Category -->
    <category displayName="$(string.AcrobatDCCategory_x86)" name="AcrobatDCCategory_x86">
      <parentCategory ref="AdobeCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_CloudConnectors_x86)" name="CloudConnectorsCategoryDC_x86">
      <parentCategory ref="AcrobatDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_ContextToolsSearch_x86)" name="ContextToolsSearchCategoryDC_x86">
      <parentCategory ref="AcrobatDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_DocsEditAccess_x86)" name="DocsEditAccessCategoryDC_x86">
      <parentCategory ref="AcrobatDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_SecurityExec_x86)" name="SecurityExecCategoryDC_x86">
      <parentCategory ref="AcrobatDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_SecurityTrust_x86)" name="SecurityTrustCategoryDC_x86">
      <parentCategory ref="AcrobatDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_SharingFeatures_x86)" name="SharingFeaturesCategoryDC_x86">
      <parentCategory ref="AcrobatDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_StartupExperience_x86)" name="StartupExperienceCategoryDC_x86">
      <parentCategory ref="AcrobatDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_UpdatesDesktop_x86)" name="UpdatesDesktopCategoryDC_x86">
      <parentCategory ref="AcrobatDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_Upsell_x86)" name="UpsellCategoryDC_x86">
      <parentCategory ref="AcrobatDCCategory_x86"/>
    </category>

    <!-- Reader DC (x86) Category -->
    <category displayName="$(string.ReaderDCCategory_x86)" name="ReaderDCCategory_x86">
      <parentCategory ref="AdobeCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_CloudConnectors_x86)" name="CloudConnectorsCategory_x86">
      <parentCategory ref="ReaderDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_ContextToolsSearch_x86)" name="ContextToolsSearchCategory_x86">
      <parentCategory ref="ReaderDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_DocsEditAccess_x86)" name="DocsEditAccessCategory_x86">
      <parentCategory ref="ReaderDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_SecurityExec_x86)" name="SecurityExecCategory_x86">
      <parentCategory ref="ReaderDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_SecurityTrust_x86)" name="SecurityTrustCategory_x86">
      <parentCategory ref="ReaderDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_SharingFeatures_x86)" name="SharingFeaturesCategory_x86">
      <parentCategory ref="ReaderDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_StartupExperience_x86)" name="StartupExperienceCategory_x86">
      <parentCategory ref="ReaderDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_UpdatesDesktop_x86)" name="UpdatesDesktopCategory_x86">
      <parentCategory ref="ReaderDCCategory_x86"/>
    </category>
    <category displayName="$(string.Cat_Upsell_x86)" name="UpsellCategory_x86">
      <parentCategory ref="ReaderDCCategory_x86"/>
    </category>

  </categories>
  <policies>

    <!-- ======================================== -->
    <!--                                          -->
    <!--    Adobe Acrobat DC (x86) - policies     -->
    <!--                                          -->
    <!-- ======================================== -->

