    <policy class="Machine" displayName="$(string.bToggleAdobeDocumentServicesDC_x86)" explainText="$(string.bToggleAdobeDocumentServicesDC_x86_Explain)" key="SOFTWARE\WOW6432Node\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
      name="bToggleAdobeDocumentServicesDC_x86" valueName="bToggleAdobeDocumentServices">
      <parentCategory ref="CloudConnectorsCategoryDC_x86"/>
      <supportedOn ref="SupportedAcrobatDC_x86"/>
