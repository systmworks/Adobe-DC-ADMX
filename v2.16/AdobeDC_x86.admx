    <policy class="Machine" displayName="$(string.bEnableGentechDC_x86)" explainText="$(string.bEnableGentechDC_x86_Explain)" key="SOFTWARE\WOW6432Node\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown"
