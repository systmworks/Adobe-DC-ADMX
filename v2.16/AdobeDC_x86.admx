    <!-- ======================================== -->

    <!-- Cloud and Connectors > Adobe Fill and Sign -->
    <!-- bToggleFillSign   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9299 -->
    <policy class="Machine" displayName="$(string.bToggleFillSignDC_x86)" explainText="$(string.bToggleFillSignDC_x86_Explain)" key="SOFTWARE\WOW6432Node\Policies\Adobe\Adobe Acrobat\DC\FeatureLockDown\cServices"
      name="bToggleFillSignDC_x86" valueName="bToggleFillSign">
      <parentCategory ref="CloudConnectorsCategoryDC_x86"/>
      <supportedOn ref="SupportedAcrobatDC_x86"/>
      <enabledValue>
        <decimal value="0" />
      </enabledValue>
      <disabledValue>
        <decimal value="1" />
      </disabledValue>
    </policy>

    <!-- Cloud and Connectors > Box Cloud Connector -->
    <!-- bBoxConnectorEnabled   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureLockDown.html#idkeyname_1_9966 -->
