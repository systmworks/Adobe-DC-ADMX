<policyDefinitionResources xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://schemas.microsoft.com/GroupPolicy/2006/07/PolicyDefinitions"
  revision="1.6" schemaVersion="1.0">
  <displayName>Adobe Acrobat DC / Reader DC (User Preferences)</displayName>
  <description>ADMX v1.6 for HKCU user preferences (Acrobat DC and Reader DC).</description>
  <resources>
    <stringTable>
      <string id="SupportedAcrobatDC_User">Adobe Acrobat DC</string>
      <string id="SupportedReaderDC_User">Adobe Reader DC</string>

      <string id="AdobeCategory_User">Adobe (User)</string>
      <string id="AcrobatDCCategory_User">Acrobat DC (User)</string>
      <string id="ReaderDCCategory_User">Reader DC (User)</string>

      <string id="Cat_ContextToolsSearch_User">Context, Tools &amp; Search</string>
      <string id="Cat_DocsEditAccess_User">Documents, Editing &amp; Accessibility</string>
      <string id="Cat_MicrosoftPurviewMIP_User">Microsoft Purview (MIP)</string>
      <string id="Cat_SecurityExec_User">Security: Execution &amp; Protection</string>
      <string id="Cat_SecurityTrust_User">Security: Trust &amp; Permissions</string>
      <string id="Cat_SharingFeatures_User">Sharing &amp; Features</string>
      <string id="Cat_StartupExperience_User">Startup &amp; Experience</string>
      <string id="Cat_UpdatesDesktop_User">Updates &amp; Desktop Integration</string>
      <string id="Cat_Upsell_User">Upsell</string>

      <!-- ======================================== -->
      <!--                                          -->
      <!-- Adobe Acrobat DC (User) - policy strings -->
      <!--                                          -->
      <!-- ======================================== -->

      <!-- ======================================== -->
      <!--        Context, Tools and Search         -->
      <!-- ======================================== -->

      <string id="iColumnSelectHaloDC_User">Column Select Halo</string>
      <string id="iColumnSelectHaloDC_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
      <string id="DisableSignInOfficeDC_User">Disable Sign in Office</string>
      <string id="DisableSignInOfficeDC_User_Explain">Specifies whether to install PDFMaker's Acrobat Sign integration component so that the sign user interface appears in Microsoft Office products.&#10;&#10;Possible values include: 0: Enable the Office plugin. 1: Disable the plugin.</string>
      <string id="EnableSignInOfficeDC_User">Enable Sign in Office</string>
      <string id="EnableSignInOfficeDC_User_Explain">Specifies whether to install PDFMaker's Acrobat Sign integration component so that the sign user interface appears in Microsoft Office products.&#10;&#10;Enabling this feature allows the user to invoke the Acrobat Sign workflow in MS Office products. Note that the Mac pref has a different name and plist location. Possible values include: 0: Disable PDFMaker's sign component. 1: Enable Acrobat Sign component.</string>
      <string id="bAlwaysUseFileNameAsDocTitleDC_User">Filename as Title</string>
      <string id="bAlwaysUseFileNameAsDocTitleDC_User_Explain">Specifies whether to use the PDF file name as the display name in the application's title bar.&#10;&#10;PDF documents have an Initial View property that's set to &quot;Document Title&quot; by default. Enabling this preference overrides any document-level setting with the app-level setting. Possible values include: 0: Don't use file names. 1: Use file names for the PDF title.</string>
      <string id="bUseFixedSnapshotResolutionDC_User">Fixed Snapshot Resolution</string>
      <string id="bUseFixedSnapshotResolutionDC_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
      <string id="ADC4318556DC_User">Flash Player for 3D</string>
      <string id="ADC4318556DC_User_Explain">Enables playing 3D and multimedia content using a Flash player in PDF.&#10;&#10;Since Flash is no longer supported, admins must install and configure the player. Possible values include: 0 or null: Don't play content with a Flash player. 1: Use the Flash player.</string>
      <string id="bHandSelectsDC_User">Hand Tool Select</string>
      <string id="bHandSelectsDC_User_Explain">Specifies whether the hand tool should be able to select text and images.&#10;&#10;With the DC 10/13/2015 release, this setting also works on Windows Touch devices. Possible values include: 0: Don't select text and images. 1: Select text and images.</string>
      <string id="iMaxMRUCntToBeStoredDC_User">Max Recent Files</string>
      <string id="iMaxMRUCntToBeStoredDC_User_Explain">Stores the number of recent files that should be listed in the recent files list.&#10;&#10;The recent files list appears under the file menu (5 item limit), the splash screen (5 item limit), and in My Files View (100 item limit). A number from 0-100. The default is 100.</string>
      <string id="bEnableAv2DC_User">Modern Viewer</string>
      <string id="bEnableAv2DC_User_Explain">Specifies whether to show the modern viewer first released in July 2022.&#10;&#10;0: Show the classic viewer. 1: Show the modern viewer.</string>
      <string id="bAllowMultipleExpandedPanelsDC_User">Multiple Comment Panels</string>
      <string id="bAllowMultipleExpandedPanelsDC_User_Explain">Specifies whether multiple comment panels can be expanded.&#10;&#10;Possible values include: 0: Don't allow more than one visible panel. 1: Do allow multiple visible panels.</string>
      <string id="iNumSwitcherContextualToolTipAV2ShownDC_User">New Look Coachmark</string>
      <string id="iNumSwitcherContextualToolTipAV2ShownDC_User_Explain">Specifies whether to show the &quot;Acrobat has a new look&quot; coachmark after launching Acrobat the first time.&#10;&#10;Once the coachmark displays, the app automatically resets this value to 0. This preference has no effect if bEnableAv2 is 0. 0: Do not show the coachmark. 1: Show the coachmark.</string>
      <string id="bPinHUDDC_User">Pin HUD Toolbar</string>
      <string id="bPinHUDDC_User_Explain">Specifies whether to pin the HUD to the toolbar.&#10;&#10;The application automatically creates this key when you click the &quot;pin to menu&quot; icon on the right-hand side of the HUD. Possible values include: 0: Don't pin the HUD to the toolbar. 1: Pin the HUD to the toolbar.</string>
      <string id="bPromptBeforeClosingMultipleTabsDC_User">Prompt Close Tabs</string>
      <string id="bPromptBeforeClosingMultipleTabsDC_User_Explain">Specifies whether to warn the user before closing documents open in multiple tabs.&#10;&#10;The ability to open documents in separate tabs was introduced in October, 2015. Possible values include: 0: Don't warn the user. 1: Warn the user.</string>
      <string id="bImagesFirstDC_User">Select Images First</string>
      <string id="bImagesFirstDC_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
      <string id="bInfobubbleDC_User">Show Tool Pane Tips</string>
      <string id="bInfobubbleDC_User_Explain">Specifies whether the popup tooltips for the Tools, Comments, and Share panes should appear.&#10;&#10;Possible values include: 0: Disable popup tooltips. 1: Enable popup tooltips.</string>
      <string id="bKeyPrefsShowVirtualKeyoardDC_User">Show Touch Keyboard</string>
      <string id="bKeyPrefsShowVirtualKeyoardDC_User_Explain">Specifies whether to show the touch keyboard if device is in touch or tablet mode on Win 8 and later.&#10;&#10;In general, the virtual keyboard should only appear on touch devices running Windows 8 and later where the user has detached a soft keyboard. The keyboard should appear when a user taps a text area such as a search box, comment popup, form field, and so on. Possible values include:</string>
      <string id="iSnapshotResolutionDC_User">Snapshot Resolution DPI</string>
      <string id="iSnapshotResolutionDC_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
      <string id="ADC4406238DC_User">Suppress PDF/UA Dialog</string>
      <string id="ADC4406238DC_User_Explain">Specifies whether to suppress the confirmation dialog when the Acrobat preference Mark PDF/UA compliant is checked in Microsoft Word.&#10;&#10;Admins can disable the following dialog when converting a Microsoft Word document to PDF: Possible values include: 0: Don't show the dialog. 1: Show the dialog.</string>
      <string id="irightPaneStateDC_User">Tools Pane State</string>
      <string id="irightPaneStateDC_User_Explain">Specifies whether to automatically open the Tools Pane on launch.&#10;&#10;Possible values include: 0: Use the default. 1: Always closed. 2: Always open.</string>
      <string id="iBasicSharePaneStickyStatusDC_User">Tools Pane Sticky</string>
      <string id="iBasicSharePaneStickyStatusDC_User_Explain">Specifies whether to remember the Tools Pane state across sessions.&#10;&#10;For example, if the user closes the Tools Pane, it will not automatically open on launch. Interacts with irightPaneState. Possible values include: 0: Don't remember the Tool Pane's state. The Pane is always closed on application open. 1: Do remember the Tool Pane's state.</string>
      <string id="iNumSwitcherContextualToolTipAVShownDC_User">Try New Coachmark</string>
      <string id="iNumSwitcherContextualToolTipAVShownDC_User_Explain">Specifies whether to show the &quot;Try the new Acrobat/Reader&quot; coachmark after launching Acrobat the first time.&#10;&#10;Once the coachmark displays, the app automatically resets this value to 0. This preference has no effect if bEnableAv2 is 0. 0: Do not show the coachmark. 1: Show the coachmark.</string>
      <string id="iNumSessionAV2DC_User">UI Switcher Sessions</string>
      <string id="iNumSessionAV2DC_User_Explain">Specifies whether to show the UI switcher coachmark based on the number of user sessions.&#10;&#10;Interacts with iNumSwitcherContextualToolTipAV2Shown . Possible values include: 0 or 1: Don't show the UI switcher. 2 or greater: Show the UI switcher if iNumSwitcherContextualToolTipAV2Shown is 0.</string>

      <!-- ======================================== -->
      <!--   Documents, Editing and Accessibility   -->
      <!-- ======================================== -->

      <string id="bUse2DGPUfDC_User">2D GPU Acceleration</string>
      <string id="bUse2DGPUfDC_User_Explain">Specifies whether 2D graphics acceleration should be used.&#10;&#10;Possible values include: 0: Disable 1: Enable</string>
      <string id="bAllowDocsToHideUIDC_User">Allow Hide UI</string>
      <string id="bAllowDocsToHideUIDC_User_Explain">Specifies whether to allow documents to hide the menu bar, toolbars, and window controls.&#10;&#10;Possible values include: 0: Don't allow documents to hide UI elements. 1: Allow documents to hide UI elements.</string>
      <string id="benableTextSelectionDC_User">Annotation Text Selection</string>
      <string id="benableTextSelectionDC_User_Explain">Specifies whether to enable text selection for annotations such as highlight, strikethrough or underline.&#10;&#10;Possible values include: 0: Enable text selection. When enabled, the cursor changes to ][ mode when the annotation (highlight, strikethrough or underline) is clicked and hovered over for more than 2 seconds. The cursor reverts to the previous mode after a time duration of 3 seconds upon hovering outside the bounding box of the annot. 1: Don't enable text selection. When disabled, the cursor changes to ][ mode only upon selecting Enable Text selection in the context menu. It will then remain in ][ mode for all annotations on the page.</string>
      <string id="bEnableATDC_User">Assistive Technology</string>
      <string id="bEnableATDC_User_Explain">Toggles assistive technology on and off.&#10;&#10;This preference enables certain workflows when assistive technology such as JAWS is detected. When enabled, a dialog appears in workflows where accessibility might be improved. For example, when processing untagged documents, the user is asked if they would like to use the setup assistant. When processing scanned images, a prompt asks if OCR should run. Possible values include: 0: Don't enable assistive technology. 1: Enable assistive technology.</string>
      <string id="bAttachLogDC_User">Attach Report</string>
      <string id="bAttachLogDC_User_Explain">Toggles whether to attach the accessibility report to the checked document after running accessibility full check.&#10;&#10;Possible values include: 0: Don't attach the report. 1: Do attach the report.</string>
      <string id="bAutoCompleteOnTabDC_User">Auto-Complete on Tab</string>
      <string id="bAutoCompleteOnTabDC_User_Explain">Specifies whether to auto complete form field entries on a tab key action.&#10;&#10;This option is enabled when the Advanced option is selected. Possible values include: 0: Don't auto complete on tab. 1: Auto complete on tab.</string>
      <string id="bautoOpenOtherDC_User">Auto-Open Drawing Popup</string>
      <string id="bautoOpenOtherDC_User_Explain">Automatically adds a popup note when another type of annotation is added.&#10;&#10;In other words, a popup note appears when you create a new comment using a drawing tool, the Stamp tool, or the Pencil tool. Possible values include: 0: Don't add a popup note for other annot types. 1: Do add a popup note for other annot types.</string>
      <string id="bAutoSaveDocsEnabledDC_User">Auto-Save</string>
      <string id="bAutoSaveDocsEnabledDC_User_Explain">Specifies whether or not to automatically save documents.&#10;&#10;Interacts with iAutoSaveDocsInterval. Possible values include: 0: Don't auto save documents 1: Auto save documents.</string>
      <string id="iAutoSaveDocsIntervalDC_User">Auto-Save Interval</string>
      <string id="iAutoSaveDocsIntervalDC_User_Explain">Specifies the time interval in minutes at which to automatically save docs.&#10;&#10;Interacts with bAutoSaveDocsEnabled. Possible values include: 5: Minutes User specified: Any value 1-99</string>
      <string id="bAutoSetLayersDC_User">Auto-Set Layers</string>
      <string id="bAutoSetLayersDC_User_Explain">Specifies whether to allow the document's layer state to be set by user information.&#10;&#10;Possible values include: 0: Don't allow layer state to be set by user information. 1: Allow layer state to be set by user information.</string>
      <string id="iAccessBackgroundColorDC_User">Background Color</string>
      <string id="iAccessBackgroundColorDC_User_Explain">Specifies the default document background color (accessibility feature)&#10;&#10;The key name is appended with (Blue|Green|Red|Space). Possible values include: Green text on black Yellow text on black White text on black Black text on white</string>
      <string id="iPagesDC_User">Check Page Range</string>
      <string id="iPagesDC_User_Explain">Toggles whether to check all pages of a document or a subset of pages when running an accessibility full check.&#10;&#10;Possible values include: 0: Don't check all pages. 1: Do check all pages.</string>
      <string id="benableDDRDC_User">ClearType Smoothing</string>
      <string id="benableDDRDC_User_Explain">Specifies whether to further smooth text on LCD screens.&#10;&#10;Text smoothing essentially has two levels. First, the text is anti-aliased. Then DDR technology is applied for devices which allow RGB bands to be painted in individual pixels to further smooth text (LCD screens). Possible values include: 0: None and Monitor 1: Laptop/LCD Screens.</string>
      <string id="bEnableCloudBasedATDC_User">Cloud Auto Tagging</string>
      <string id="bEnableCloudBasedATDC_User_Explain">Specifies whether to enable cloud-based auto-tagging.&#10;&#10;When enabled, the app uses an API to call the cloud-based auto-tagging feature. Possible values include: 0: Disable cloud-based auto-tagging 1: Enable cloud-based auto-tagging</string>
      <string id="iAccessColorPolicyDC_User">Color Replace Policy</string>
      <string id="iAccessColorPolicyDC_User_Explain">Specifies whether all the controls in the Replace Document Colors panel should be enabled.&#10;&#10;When disabled, this key is removed from the registry/plist. When this preference is selected, you can choose from a list of contrasting color combinations for text and background or create your own. Possible values include: null: User specified. 1: Use Windows Color Scheme 2: Use Custom Colors 4: Use High Contrast Colors</string>
      <string id="bCombineContentDC_User">Combine Reading Order</string>
      <string id="bCombineContentDC_User_Explain">Specifies whether similar content should be displayed together or separately.&#10;&#10;Possible values include: 0: Do display similar content types together. 1: Don't display similar content types together.</string>
      <string id="tauthorDC_User">Comment Author</string>
      <string id="tauthorDC_User_Explain">The author name specified by balwaysUseIdent.&#10;&#10;Possible values include: N/A: User specified.</string>
      <string id="dNoteFontSizeDC_User">Comment Font Size</string>
      <string id="dNoteFontSizeDC_User_Explain">Sets the font size.&#10;&#10;The font is not embedded in the PDF; this preference merely controls the viewer's preference rather than the author's preference. Possible values include: 10: Font size. N/A: User specified.</string>
      <string id="iNoteOpacityDC_User">Comment Opacity</string>
      <string id="iNoteOpacityDC_User_Explain">The opacity in percent of all comments.&#10;&#10;The number is entered in Hex. Possible values include: d99a: 85%. N/A: Any hex value representing 1-100%.</string>
      <string id="iSensDC_User">Compare Sensitivity</string>
      <string id="iSensDC_User_Explain">Last-used compare documents sensitivity (for compare pages).</string>
      <string id="iTypeDC_User">Compare Type</string>
      <string id="iTypeDC_User_Explain">Last-used compare documents type (pages/text/text+fonts).</string>
      <string id="bComplexScriptDC_User">Complex Script Support</string>
      <string id="bComplexScriptDC_User_Explain">Specifies whether to enable support for writing direction switching (complex script).&#10;&#10;Possible values include: 0: Don't enable Writing Direction Switching. 1: Enable Writing Direction Switching.</string>
      <string id="bconfirmEBRMergeDC_User">Confirm Review Import</string>
      <string id="bconfirmEBRMergeDC_User_Explain">Displays an alert on document open asking the user to confirm importing comments into an active review.&#10;&#10;Possible values include: 0: Disable confirmation alert on import. 1: Enable confirmation alert on import.</string>
      <string id="bcopyTextToDrawAnnotDC_User">Copy Text to Drawing</string>
      <string id="bcopyTextToDrawAnnotDC_User_Explain">Specifies whether to copy the encircled text into drawing comment popups.&#10;&#10;Adds a popup comment automatically to other markup types so that they can be annotated. Possible values include: 0: Don't copy the encircled text into comments. 1: Do copy the encircled text into comments.</string>
      <string id="bcopyTextToMarkupAnnotDC_User">Copy Text to Markup</string>
      <string id="bcopyTextToMarkupAnnotDC_User_Explain">Copies the selected text into highlight, cross-out, and underline comment popups.&#10;&#10;Adds a popup comment automatically to specified markup types so that they can be annotated. Possible values include: 0: Copy selected text. 1: Don't copy selected text.</string>
      <string id="bCreateLogDC_User">Create Report</string>
      <string id="bCreateLogDC_User_Explain">Toggles whether to create an accessibility report when running an accessibility full check.&#10;&#10;Possible values include: 0: Don't create report. 1: Do create report.</string>
      <string id="iDictionaryDefaultIDDC_User">Default Dictionary</string>
      <string id="iDictionaryDefaultIDDC_User_Explain">Identifies the default spelling dictionary ID.&#10;&#10;The value is an ID from cDictionaryOrderID\i0 . The dictionary name can be found in cDictionaryOrder\t0. Alternatively, set the value in the user interface, close the product, and look here again. Use the value that appears during deployment.</string>
      <string id="iPageViewLayoutModeDC_User">Default Page Layout</string>
      <string id="iPageViewLayoutModeDC_User_Explain">Specifies the default page layout when a PDF opens.&#10;&#10;These settings can be overridden by Accessiblity settings such as bOverridePageLayout. Possible values include: null: Automatic 1: Single Page 2: Single Page Continuous 3: Two Up Continuous 5: Two Up</string>
      <string id="iParaDirDC_User">Default Paragraph Dir</string>
      <string id="iParaDirDC_User_Explain">Specifies the paragraph direction.&#10;&#10;Possible values include: 0: Left to Right 1: Right to Left 2: Infer from document</string>
      <string id="iDefaultZoomScaleDC_User">Default Zoom Scale</string>
      <string id="iDefaultZoomScaleDC_User_Explain">Specifies the zoom scale % to use when a PDF opens.&#10;&#10;Possible values include a range beginning with Fit Page to Reflow . To set a value, configure the UI and look at the registry/plist preference to see what has been written. Possible values include: 199a: 10% 4000 25% 8000: 50% c000: 75% 10000: 100% etc.</string>
      <string id="iDefaultZoomTypeDC_User">Default Zoom Type</string>
      <string id="iDefaultZoomTypeDC_User_Explain">Specifies the default zoom type (other than a %) to use when a PDF opens.&#10;&#10;% scales are stored in iZoomScale. Possible values include: 1: Fit Page (automatic) 2: Fit Width 3: Fit Hieght 4: Fit Visible 6: Reflow</string>
      <string id="imaxPDFCommentsSizeDC_User">Embedded Comment Limit</string>
      <string id="imaxPDFCommentsSizeDC_User_Explain">Sets the comment threshold size for determining whether comments are embedded or sent as FDF files.&#10;&#10;When collaboration involves sending comments with a PDF, comments below the threshold size are embedded in the document. Comments above the threshold size are sent as FDF files. Possible values include: 3: Max size for Reader (Acrobat is 5)</string>
      <string id="bemptyContentToolTipDC_User">Empty Comment Tooltip</string>
      <string id="bemptyContentToolTipDC_User_Explain">Displays a tooltip stating the comment being hovered over is empty.&#10;&#10;Possible values include: 0: Don't indicate comment is empty. 1: Do indicate comment is empty.</string>
      <string id="bUseThinCodeDC_User">Enhance Thin Lines</string>
      <string id="bUseThinCodeDC_User_Explain">Specifies whether to enhance thin lines to improve visibility.&#10;&#10;Possible values include: 0: Don't enhance thin lines. 1: Enhance thin lines.</string>
      <string id="bSuperFastDrawingDC_User">Fast Scroll Drawing</string>
      <string id="bSuperFastDrawingDC_User_Explain">Specifies whether to use fast, low resolution intermediate representation during scrolling, zooming, etc.&#10;&#10;Superfast Drawing was introduced in Acrobat and Reader DC to make interactions with PDF documents smoother and more responsive. Superfast drawing suspends high quality rendering for the duration of operations like fast scrolling, panning, and zooming. This results in a lower quality intermediate representation being temporarily displayed during the current action. Possible values include: 0: Don't use Superfast Drawing and display high quality intermediates during scrolling, zooming, panning, etc. 1: Use Superfast Drawing to display low resolution intermediates during scrolling, zooming, panning, etc. GUI mapping None.</string>
      <string id="iaskFormsSelectEmailCLientDC_User">Form Email Prompt</string>
      <string id="iaskFormsSelectEmailCLientDC_User_Explain">Specifies whether the dialog confirming selection of desktop vs. internet email on XFA form submit appears.&#10;&#10;Possible values include: 0: Don't show the confirmation dialog on each XFA form submit. 1: Do show the confirmation dialog on each XFA form submit.</string>
      <string id="bHidePopupIfShowSummaryDC_User">Hide Popup on Summary</string>
      <string id="bHidePopupIfShowSummaryDC_User_Explain">Hide comment popups when comment's list is open.&#10;&#10;Possible values include: 0: Don't hide popups. 1: Do hide popups.</string>
      <string id="bHindiDigitDC_User">Hindi Digits</string>
      <string id="bHindiDigitDC_User_Explain">Specifies whether to enable support for Hindi digits.&#10;&#10;Possible values include: 0: Don't enable Hindi digits. 1: Enable Hindi digits.</string>
      <string id="bHoveringPopupsDC_User">Hover Popups</string>
      <string id="bHoveringPopupsDC_User_Explain">Automatically open popups on mouse rollover.&#10;&#10;Possible values include: 0: Don't open popups on mouse rollover. 1: Do open popups on mouse rollover.</string>
      <string id="bInlineAutoCompleteDC_User">Inline Auto-Complete</string>
      <string id="bInlineAutoCompleteDC_User_Explain">Specifies whether to auto complete a field based on remembered values when a user starts typing.&#10;&#10;This option is enabled for both the Basic and Advanced options. Possible values include: 0: Don't auto complete. 1: Do autocomplete.</string>
      <string id="iIntlSelectFontDC_User">International Font</string>
      <string id="iIntlSelectFontDC_User_Explain">Specifies the font to use.&#10;&#10;Possible values include: 0: Application default 1: GB18030 compatible font 2: HKSCS compatible font</string>
      <string id="bLigaturesDC_User">Ligatures</string>
      <string id="bLigaturesDC_User_Explain">Specifies whether to enable support for ligatures.&#10;&#10;Possible values include: 0: Don't enable ligatures. 1: Enable ligatures.</string>
      <string id="balwaysUseIdentDC_User">Login Name as Author</string>
      <string id="balwaysUseIdentDC_User_Explain">Uses the login names as the comment author name.&#10;&#10;The login name is the name specified in the identity preferences panel. If it is not present, the login-name is used. If it is not present for comments in collaborative documents (shared-review, browser-based review, email based review), the comment author identity is used that the user has set. For Acrobat, the default is true; for Reader, it is false. Possible values include: 0: Do use the login name as the comment author name. 1: Don't use the login name as the comment author name.</string>
      <string id="bOpenInPlaceDC_User">Open Links in Place</string>
      <string id="bOpenInPlaceDC_User_Explain">Specifies whether to open cross document links in the same window.&#10;&#10;Possible values include: 0: Don't open links in the same window. 1: Do open links in the same window.</string>
      <string id="bOverprintPreviewUseShiftClickDC_User">Overprint Shift+Click</string>
      <string id="bOverprintPreviewUseShiftClickDC_User_Explain">Specifies whether to use Shift + Click for multiple selection or for adding sticky notes containing color value when output preview dialog is open.&#10;&#10;Possible values include: 0: Use Shift + Click for adding a sticky note containing the color values. 1: To select multiple objects, use Shift + Click. To add a sticky note containing the color values, use Alt + Click (Windows) or Option + Click (Mac).</string>
      <string id="bAccessOverrideDocColorsDC_User">Override Document Colors</string>
      <string id="bAccessOverrideDocColorsDC_User_Explain">Specifies whether to replace black test or line art colors when iAccessColorPolicy is enabled and a replacement color has been specified.&#10;&#10;While the default is 1, the preference is not read unless iAccessPolicy is enabled (1). Possible values include: 0: Don't replace black text or line art colors. 1: Replace black text or line art colors.</string>
      <string id="bOverrideLineArtColorsDC_User">Override Line Art Colors</string>
      <string id="bOverrideLineArtColorsDC_User_Explain">Limits color changes to black text and line art when iAccessColorPolicy is enabled and a replacement color has been specified.&#10;&#10;While the default is 1, the preference is not read unless &quot;Accessibility&quot; enabled (1). Possible values include: 0: Don't replace text or line art colors. 1: Replace text or line art colors. See also bAccessOverrideDocColors in Originals.</string>
      <string id="iPageLayoutDC_User">Override Page Layout</string>
      <string id="iPageLayoutDC_User_Explain">Specifies the user selected page layout override.&#10;&#10;When bOverridePageLayout is set to 1, the override drop down list becomes enabled so that the user can set the desired page layout. Possible values include: 1: Single Page 2: Single Page Continuous 3: Two Up Continuous 5: Two Up</string>
      <string id="bOverrideZoomDC_User">Override Zoom</string>
      <string id="bOverrideZoomDC_User_Explain">Enables the zoom setting drop down list so that the user can specify a default zoom setting for all documents and overrides Page Display settings.&#10;&#10;PDF authors can specify what zoom level a PDF will open at. When enabled (1), the zoom drop down list becomes active so that the user can specify a default zoom level for all documents and set iZoomScale. Possible values include: 0: Use the documents default zoom setting. 1: Enable the zoom setting drop down list.</string>
      <string id="iZoomScaleDC_User">Override Zoom Scale</string>
      <string id="iZoomScaleDC_User_Explain">Specifies the value in % to zoom when iZoomType is set to a % value and overrides Page Display settings.&#10;&#10;Possible values include a range beginning with Fit Page to Reflow . When selected, % values are stored in iZoomScale. To set a value, configure the UI and look at the registry/plist preference to see what has been written. Possible values include: 199a: 10% 4000 25% 8000: 50% c000: 75% 10000: 100% etc.</string>
      <string id="iZoomTypeDC_User">Override Zoom Type</string>
      <string id="iZoomTypeDC_User_Explain">Specifies the zoom scale for all other documents other than a % scale and overrides Page Display settings.&#10;&#10;% scales are stored in iZoomScale. Possible values include: 1: Fit Page 2: Fit Width 3: Fit Hieght 4: Fit Visible 6: Reflow</string>
      <string id="iParagraphDirectionDC_User">Paragraph Direction</string>
      <string id="iParagraphDirectionDC_User_Explain">Specifies the paragraph direction.&#10;&#10;Possible values include: 0: Right to Left 1: Left to Right</string>
      <string id="bPopupsOpenIffSelectedDC_User">Popup When Selected</string>
      <string id="bPopupsOpenIffSelectedDC_User_Explain">Specifies whether to open a popup when it is selected.</string>
      <string id="bPopupsScrollWithPageDC_User">Popups Scroll With Page</string>
      <string id="bPopupsScrollWithPageDC_User_Explain">Specifies whether whether popups are visible when a document is scrolled.&#10;&#10;Possible values include: 0: Hide popups on document scroll. 1: Show popups on document scroll.</string>
      <string id="bUseDetailsNavigatorDC_User">Portfolio File List</string>
      <string id="bUseDetailsNavigatorDC_User_Explain">Specifies whether to show portfolio component files and file details in an accessible list.&#10;&#10;This preference replaces bUsePlatformNavigator. Files mode provides a better reading experience for people with disabilities such as mobility impairments, blindness, and low vision. Possible values include: 0: Don't show portfolio components in a list. 1: Do show portfolio components in a list.</string>
      <string id="bPrintAnnotsDC_User">Print Annotations</string>
      <string id="bPrintAnnotsDC_User_Explain">Specifies whether to print notes, popups, and other annotations.&#10;&#10;Setting a similar preference from the Print panel sets a corresponding setting in HKU. Possible values include: 0: Don't print annotations. 1: Do print annotations.</string>
      <string id="bprintCommentPopupsDC_User">Print Comment Popups</string>
      <string id="bprintCommentPopupsDC_User_Explain">Enables printing of comments and other annotations.&#10;&#10;Notes and popups that are open will be printed when the rest of the document is printed. Possible values include: 0: Don't print comments. 1: Do print comments.</string>
      <string id="bprintNotesOpaqueDC_User">Print Popups Opaque</string>
      <string id="bprintNotesOpaqueDC_User_Explain">Makes popups opaque regardless of other settings.&#10;&#10;Prints the popups as opaque without honoring the popup opacity specified by the user in commenting preferences (popup-opacity). Possible values include: 0: Don't make popups opaque. 1: Do make popups opaque.</string>
      <string id="bUserAskedToEnableAutoCompleteDC_User">Prompt Auto-Complete</string>
      <string id="bUserAskedToEnableAutoCompleteDC_User_Explain">Specifies whether the user is asked to enable auto complete at runtime.&#10;&#10;This option is enabled for the Advanced option. Possible values include: 0: Don't ask the user. 1: Do ask the user.</string>
      <string id="iShowOrderDC_User">Reading Order Display</string>
      <string id="iShowOrderDC_User_Explain">Specifies the type of grouping order to display in the touchup reading order panel.&#10;&#10;Possible values include: 0: Order (numbered). 1: Structure type. 2: None.</string>
      <string id="bRecordNewEntriesDC_User">Remember Form Entries</string>
      <string id="bRecordNewEntriesDC_User_Explain">Specifies whether to remember form field entries for use with future auto-complete actions.&#10;&#10;This option is enabled for both the Basic and Advanced options. Possible values include: 0: Don't remember entries. 1: Do remember entries.</string>
      <string id="iRememberViewDC_User">Restore Last View</string>
      <string id="iRememberViewDC_User_Explain">Specifies whether to restore last view settings when reopening documents.&#10;&#10;Possible values include: 1: Don't restore the last view settings. 2: Do restore the last view settings.</string>
      <string id="bRTLUIDC_User">Right-to-Left UI</string>
      <string id="bRTLUIDC_User_Explain">Specifies whether to enable right to left language options.&#10;&#10;Possible values include: 0: Disable right to left language options. 1: Enable right to left language options.</string>
      <string id="bDigitsUIDC_User">RTL Digit Display</string>
      <string id="bDigitsUIDC_User_Explain">Specifies whether to display digits in a way that's consistent with right to left language display.&#10;&#10;The value is automatically set when bRTLUI is set via the UI. Possible values include: 0: Don't display digits in a way that's consistent with right to left language display. 1: Do display digits in a way that's consistent with right to left language display.</string>
      <string id="bPrintSaveTonerDC_User">Save Toner/Ink</string>
      <string id="bPrintSaveTonerDC_User_Explain">Specifies whether to optimize content so that the printer uses less ink.&#10;&#10;When checked, this setting optimizes the content so that the printer uses less ink during printing. In some cases, toner savings may reach 15%. Print quality is usually not impaired in any discernable way. Possible values include: 0: Don't optimize printing. 1: Optimize printing.</string>
      <string id="bSDIModeDC_User">SDI Mode</string>
      <string id="bSDIModeDC_User_Explain">Specifies whether to open documents in a new window or in tabs in the same window.&#10;&#10;Possible values include: 0: Open documents in tabs in the same window . 1: Open documents in separate windows.</string>
      <string id="bsendFinalApprovalEmailDC_User">Send Approval Email</string>
      <string id="bsendFinalApprovalEmailDC_User_Explain">Specifies whether to send a notification email when the current approval is identified as the final one.&#10;&#10;Only valid for an approval workflow. Possible values include: 0: Don't send an email on final approval. 1: Do send an email on final approval.</string>
      <string id="bShowOptionsDialogDC_User">Show Check Options</string>
      <string id="bShowOptionsDialogDC_User_Explain">Toggles whether to display the options dialog when running a accessibility full check.&#10;&#10;Possible values include: 0: Don't show options dialog. 1: Show options dialog.</string>
      <string id="bcommentPanelOnImportDC_User">Show Comments on Import</string>
      <string id="bcommentPanelOnImportDC_User_Explain">Specifies whether to open the comment list when comments are imported.&#10;&#10;Possible values include: 0: Don't open the comment list when comments are imported. 1: Do open the comment list when comments are imported.</string>
      <string id="bShowAnnotConnectorDC_User">Show Connector Lines</string>
      <string id="bShowAnnotConnectorDC_User_Explain">Specifies whether to show lines connecting comment markups to their popups on mouse rollover.&#10;&#10;Possible values include: 0: Hide lines connecting comments to popups. 1: Show lines connecting comments to popups.</string>
      <string id="bFocusRectDC_User">Show Focus Rectangle</string>
      <string id="bFocusRectDC_User_Explain">Specifies whether to surround a field with a rectangle when it has focus.&#10;&#10;Possible values include: 0: Don't show a rectangle. 1: Do show a rectangle.</string>
      <string id="bShowKeyboardSelectionCursorDC_User">Show Keyboard Cursor</string>
      <string id="bShowKeyboardSelectionCursorDC_User_Explain">Specifies whether the keyboard selection cursor should always be active in the document.&#10;&#10;Select this option if you use a screen magnifier. Possible values include: 0: Don't show the cursor. 1: Always show the cursor.</string>
      <string id="bshowMarkupModifiersDC_User">Show Markup Indicators</string>
      <string id="bshowMarkupModifiersDC_User_Explain">Specifies whether to show markup tool-tips and text indicators.&#10;&#10;Possible values include: 0: Don't show markup tool-tips and text indicators. 1: Show markup tool-tips and text indicators.</string>
      <string id="bRulersVisibleDC_User">Show Rulers</string>
      <string id="bRulersVisibleDC_User_Explain">Specifies whether to show or hide rulers for every new document launch.&#10;&#10;Possible values include: 0: Don't show rulers on new document launch. 1: Show rulers on new document launch.</string>
      <string id="bStampsPaletteInvisibleDC_User">Show Stamps Palette</string>
      <string id="bStampsPaletteInvisibleDC_User_Explain">Specifies whether to show the stamps palette automatically when the commenting toolbar is displayed.&#10;&#10;Possible values include: 0: Show the palette. 1: Don't show the palette.</string>
      <string id="bShowAnnotSequenceDC_User">Show Tab Order</string>
      <string id="bShowAnnotSequenceDC_User_Explain">Specifies whether to show tab order of fields for Acroforms and XFA forms.</string>
      <string id="bsideNotesDC_User">Side-Aligned Popups</string>
      <string id="bsideNotesDC_User_Explain">Creates new popups aligned to the edge of the document.&#10;&#10;Controls popup positioning. Possible values include: 0: Don't align popups at the document edge. 1: Align popups at the document edge.</string>
      <string id="bAntialiasImagesDC_User">Smooth Images</string>
      <string id="bAntialiasImagesDC_User_Explain">Specifies wither to use anti-aliasing (smoothing) for images.&#10;&#10;Turning this preference off can improve scrolling performance in Citrix environments. Possible values include: 0: Don't smooth images. 1: Smooth images.</string>
      <string id="bAntialiasGraphicsDC_User">Smooth Line Art</string>
      <string id="bAntialiasGraphicsDC_User_Explain">Specifies wither to use anti-aliasing (smoothing) for line art.&#10;&#10;Turning this preference off can improve scrolling performance in Citrix environments. Possible values include: 0: Don't smooth line art. 1: Smooth line art.</string>
      <string id="bAntialiasTextDC_User">Smooth Text</string>
      <string id="bAntialiasTextDC_User_Explain">Specifies whether to smooth (anti-alias) text.&#10;&#10;This setting only applies when the Smooth Text field is set to Monitor or Laptop/LCD. Text smoothing essentially has two levels. First, the text is anti-aliased. Then, if benableDDR is set to 1, DDR technology is applied for devices which allow RGB bands to be painted in individual pixels to further smooth text. Possible values include: 0: None. 1: For both monitor and laptop/LCD Screens.</string>
      <string id="bSmoothZoomingDC_User">Smooth Zooming</string>
      <string id="bSmoothZoomingDC_User_Explain">Specifies whether smooth zooming should be enabled.&#10;&#10;Possible values include: 0: Disables smooth zooming 1: Enables smooth zooming</string>
      <string id="bSpellingUnderlineDC_User">Spell Check Underline</string>
      <string id="bSpellingUnderlineDC_User_Explain">Turns off and on spell checking as you type.&#10;&#10;This key is also duplicated under cPICommonPrefs\cSpelling.</string>
      <string id="bStoreNumericEntriesDC_User">Store Numeric Entries</string>
      <string id="bStoreNumericEntriesDC_User_Explain">Specifies whether to store user entered numeric values.&#10;&#10;This option is enabled for both the Basic and Advanced options. Possible values include: 0: Don't store numeric entries. 1: Do store numeric entries.</string>
      <string id="bUseStructTabOrderDC_User">Structure Tab Order</string>
      <string id="bUseStructTabOrderDC_User_Explain">Specifies whether to use the PDF document structure for determining the tab order.&#10;&#10;Possible values include: 0: Don't use document structure. 1: Use document structure.</string>
      <string id="bUseSystemSelectionColorDC_User">System Selection Color</string>
      <string id="bUseSystemSelectionColorDC_User_Explain">Specifies whether the default selection color (blue) is overridden with a color that the system specifies.&#10;&#10;Possible values include: 0: Don't use the system selection color. 1: Use the system selection color.</string>
      <string id="iAccessTextColorDC_User">Text Color</string>
      <string id="iAccessTextColorDC_User_Explain">Specifies the default document text color (accessibility feature)&#10;&#10;The key name is appended with (Blue|Green|Red|Space). Possible values include: null: not set Any RGB color: User specified.</string>
      <string id="bUseLocalFontsDC_User">Use Local Fonts</string>
      <string id="bUseLocalFontsDC_User_Explain">Specifies whether to use local fonts.&#10;&#10;Possible values include: 0: Don't use local fonts. 1: Do use local fonts.</string>
      <string id="iEmailClientSelectionDC_User">XFA Email Client</string>
      <string id="iEmailClientSelectionDC_User_Explain">Specifies the email client to use when submitting an XFA form.&#10;&#10;Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
      <string id="iRXOPolicyDC_User">XObjects View Mode</string>
      <string id="iRXOPolicyDC_User_Explain">Sets XObject access to either Never (0), Always (1), or Only PDF/X-5 Compliant Ones (2).&#10;&#10;The user must also set cRXOLocation and (Windows only) specify a privileged location for each parent (referencing) document. Possible values include: 0: Never 1: Always 2: Only PDF/X-5 Compliant Ones</string>

      <!-- ======================================== -->
      <!--         Microsoft Purview (MIP)          -->
      <!-- ======================================== -->

      <string id="bEnableLoggingDC_User">MIP Logging</string>
      <string id="bEnableLoggingDC_User_Explain">Specifies whether to enable debug logging for Microsoft Purview Information Protection operations.&#10;&#10;Useful for troubleshooting MIP label and authentication issues. Possible values include: 0: Disable MIP debug logging. 1: Enable MIP debug logging.</string>
      <string id="bEnablePolicyAuthenticationDC_User">MIP Policy Authentication</string>
      <string id="bEnablePolicyAuthenticationDC_User_Explain">Specifies whether MIP policy authentication is enabled for the current user.&#10;&#10;Used alongside bShowDMB. Setting both bShowDMB and bEnablePolicyAuthentication to 0 hides the applied label from the current file. Possible values include: 0: Disable MIP policy authentication. 1: Enable MIP policy authentication.</string>
      <string id="bShowDMBDC_User">Show Document Message Bar (MIP)</string>
      <string id="bShowDMBDC_User_Explain">Specifies whether to show Microsoft Purview Information Protection label information in the document message bar.&#10;&#10;Per-user preference under MicrosoftAIP. Possible values include: 0: Do not show MIP label info in the document message bar. 1: Show MIP label info in the document message bar.</string>

      <!-- ======================================== -->
      <!--    Security: Execution and Protection    -->
      <!-- ======================================== -->

      <string id="b3DEnableContentDC_User">3D Content Trust</string>
      <string id="b3DEnableContentDC_User_Explain">Specifies whether to trust and render 3D content.&#10;&#10;This setting can be overridden by bEnable3D . Possible values include: 0: Don't trust and render 3D content. Show the Yellow Message Bar so the end user can trust the document. 1: Trust and render 3D files.</string>
      <string id="bCrossDomainLoggingDC_User">Cross-Domain Logging</string>
      <string id="bCrossDomainLoggingDC_User_Explain">Enables cross domain logging for communication with a server that uses a cross domain policy file to manage the flow of data that does not conform to a same-origin policy.&#10;&#10;Create a logging file by navigating to the user account Application Directory. For example, on XP go to C:\Documents and Settings\(user name)\Application Data\Adobe\(application)\(version)\. Created an empty file called AcrobatCrossDomain.log.</string>
      <string id="bEnableDebuggerDC_User">Enable JS Debugger</string>
      <string id="bEnableDebuggerDC_User_Explain">Enables the debugger.&#10;&#10;Requires an application restart.</string>
      <string id="bChooseDialogDC_User">External JS Editor</string>
      <string id="bChooseDialogDC_User_Explain">Specifies wither or not to use the Acrobat editor or an external editor.&#10;&#10;When true, the &quot;Choose an external editor&quot; field becomes enabled.</string>
      <string id="bFIPSModeDC_User">FIPS Mode</string>
      <string id="bFIPSModeDC_User_Explain">Turns FIPS mode on and off thereby requiring stronger encryption algorithm and limiting certain application behavior.&#10;&#10;Security Reference: STIG ARDC-CN-000345 (V-213193) Medium; STIG AADC-CN-000955 (V-245874) Medium</string>
      <string id="bConsoleInputDC_User">JS Console Input</string>
      <string id="bConsoleInputDC_User_Explain">Toggles whether or not the console appears if script execution results in an error or message.</string>
      <string id="bConsoleOpenDC_User">JS Debugger Console</string>
      <string id="bConsoleOpenDC_User_Explain">Enables the interactive debugger console.</string>
      <string id="iExceptionsDC_User">JS Exception Handling</string>
      <string id="iExceptionsDC_User_Explain">Specifies how exceptions should be handled.&#10;&#10;Allowable values include: 0: Ignore 1: Trace 2: Break</string>
      <string id="bEnableGlobalSecurityDC_User">JS Global Security</string>
      <string id="bEnableGlobalSecurityDC_User_Explain">Controls whether or not a script in one sandbox can access a script object in another sandbox.&#10;&#10;By default, scripts can not access objects outside the current document sandbox. With 9.x and later, such communication only works in the standalone application since both the Acrobat and Reader browser-based viewer opens each window in a discrete browser instance.</string>
      <string id="bEnableMenuItemsDC_User">JS Menu Items</string>
      <string id="bEnableMenuItemsDC_User_Explain">Toggles off and on JavaScript's ability to execute menu items.</string>
      <string id="bEnableAlwaysOutlookAttachmentProtectedViewDC_User">Outlook Protected View</string>
      <string id="bEnableAlwaysOutlookAttachmentProtectedViewDC_User_Explain">Specifies whether Protected View is turned off for Outlook attachments.&#10;&#10;Note that earlier versions (e.g. Office 2003 and 2007) do not append origin information to files they download to its temp directory. As a result, there is no way of knowing if the file came from trusted source. Such files do not automatically open in PV. Possible values include: 0: Enable Protected View for Outlook attachments. 1: Disable Protected View for Outlook attachments.</string>
      <string id="bOldRecentFilesMigratedDC_User">Recent Files Migrated</string>
      <string id="bOldRecentFilesMigratedDC_User_Explain">Indicates whether the recent files list has been migrated.&#10;&#10;Admins should not change the preference value.</string>
      <string id="bSaveBreakpointsDC_User">Save JS Breakpoints</string>
      <string id="bSaveBreakpointsDC_User_Explain">Stores breakpoints in a PDF file&#10;&#10;Details, interactions with other keys, and allowable values, etc.</string>

      <!-- ======================================== -->
      <!--     Security: Trust and Permissions      -->
      <!-- ======================================== -->

      <string id="bUseExpiredTimestampsDC_User">Accept Expired Timestamps</string>
      <string id="bUseExpiredTimestampsDC_User_Explain">Specifies whether expired timestamps should be used.&#10;&#10;If true, an expired timestamp will not invalidate a signature.</string>
      <string id="bAllowConnectViaHTTPDC_User">Allow LiveCycle HTTP</string>
      <string id="bAllowConnectViaHTTPDC_User_Explain">If true, the server connection URI uses the format http://server:port/path; otherwise, it uses the format https://server:port/path.&#10;&#10;In either case, if the connection fails, an error message appears. For more information, see Guidelines for Developing CSPs for Acrobat on Windows .</string>
      <string id="bAllowCertNonGreenDC_User">Allow Non-Green Cert</string>
      <string id="bAllowCertNonGreenDC_User_Explain">Specifies whether a certification signature may be applied to a document containing Legal PDF warnings.&#10;&#10;If false, then its not allowed and the author is informed of the reason.</string>
      <string id="bAllowOCSPNoCheckDC_User">Allow OCSP NoCheck</string>
      <string id="bAllowOCSPNoCheckDC_User_Explain">Specifies whether the OCSPNoCheck extension is allowed in the response signing certificate.</string>
      <string id="bAlwaysConsultDC_User">Always Consult CDP</string>
      <string id="bAlwaysConsultDC_User_Explain">Determines when the URL is used for an additional URL CRL distribution point.&#10;&#10;If false, the URL is only used when the certificate does not have a CRLDp extension.</string>
      <string id="iAuthMechanismsDC_User">Auth Mechanisms</string>
      <string id="iAuthMechanismsDC_User_Explain">Specifies which registered provider(s) to use.&#10;&#10;0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
      <string id="iAutoAcceptEDCPrivacyNotificationDC_User">Auto-Accept Privacy</string>
      <string id="iAutoAcceptEDCPrivacyNotificationDC_User_Explain">Specifies whether to show an alert confirming acceptance of the privacy policy.&#10;&#10;Possible values include: 0: Don't show an alert. 1: Do show an alert.</string>
      <string id="iAutoAddLTVDC_User">Auto-Add LTV Info</string>
      <string id="iAutoAddLTVDC_User_Explain">Specifies whether LTV information should be automatically added to all signatures.&#10;&#10;Possible values include: 0: Never add LTV information. 1: (default) Ask whether LTV information should be added if it is too big. 2: Always add LTV information. When the cumulative size of the LTV data is greater than the sum of 10% of the PDF file size plus 10KB and Automatically add verification information on Save is set to &quot;Ask...&quot; a dialog appears asking the user if they would like to continue embedding the LTV information. Note that in workflows where the dialog appears asking whether to enable LTV, if the user selects the &quot;Do not show this message again&quot; checkbox, AND click the No button, then this preference is set to zero.</string>
      <string id="bSavePasswordDC_User">Cache Server Password</string>
      <string id="bSavePasswordDC_User_Explain">Indicates whether the password has been cached for this server.</string>
      <string id="iSHSDC_User">Console H-Splitter</string>
      <string id="iSHSDC_User_Explain">Indicates (in pixels) the position of the horizontal window splitter.</string>
      <string id="iSVSDC_User">Console V-Splitter</string>
      <string id="iSVSDC_User_Explain">Indicates (in pixels) the position of the vertical window splitter.</string>
      <string id="iMaxRevokeInfoCacheLifetimeDC_User">CRL Cache Lifetime</string>
      <string id="iMaxRevokeInfoCacheLifetimeDC_User_Explain">Maximum lifetime in hours the cached CRL is used for revocation checking.&#10;&#10;iMaxRevokeInfoCacheLifetime is only used if the validation method is set to &quot;current time&quot;. Possible values include: The number of hours for which the cached CRL is valid.</string>
      <string id="bCustomPrefsCreatedDC_User">Custom Cert Prefs</string>
      <string id="bCustomPrefsCreatedDC_User_Explain">Indicates whether a custom certificate specific preference (e.g. Identrus) has already been created and written to the registry.&#10;&#10;If true, it doesn't get created again. Deleting or setting this key to 0 forces Acrobat to recreate custom certificate preferences after which it will reset this key to 1.</string>
      <string id="iDirectoryProviderDC_User">Directory Provider</string>
      <string id="iDirectoryProviderDC_User_Explain">Specifies a directory provider for signature validation.&#10;&#10;0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
      <string id="bEnforceSecureChannelDC_User">Enforce Digest Compare</string>
      <string id="bEnforceSecureChannelDC_User_Explain">Specifies whether to prevent signing when the original message digest and the signed message digest do not match.&#10;&#10;When set to 1, the user sees a warning dialog when the digest mismatch occurs. This error can be caused by a modification of the original message digest, a modification of the signed message digest, or a mismatch between the private and public key used for signing. When using a certificate that doesn't include a public key (such as a DSA certificate with an omitted public key), the test to detect signature validity is not performed. Do not turn this setting on if such certificates are used.</string>
      <string id="bAutoLaunchAtDocCloseDC_User">Examine on Close</string>
      <string id="bAutoLaunchAtDocCloseDC_User_Explain">Automatically examines the document for hidden content when it is closed.</string>
      <string id="bAutoLaunchAtSendMailDC_User">Examine on Send</string>
      <string id="bAutoLaunchAtSendMailDC_User_Explain">Automatically examines the document for hidden content when it is sent in an email.</string>
      <string id="bExpiredCertGoOnlineDC_User">Expired Cert Go Online</string>
      <string id="bExpiredCertGoOnlineDC_User_Explain">Specifies whether to go online to get the revocation information for an expired certificate.&#10;&#10;11.0.16 introduced a signature validation change so that signatures are invalid if they are based on expired certificates and there is no embedded revocation information even if bIgnoreValidityDates is 1. For previous product versions, the signature would be valid. Now, to be standard's compliant, if a certificate has expired, the client should not check for the revocation information online. bExpiredCertGoOnline set to 1 re-enables the pre-11.0.16 behavior. 0: Do not go online for revocation even if bIgnoreValidityDates = 1 1: Do go online.</string>
      <string id="bFDFRequestExcludeCertDC_User">FDF Exclude Cert</string>
      <string id="bFDFRequestExcludeCertDC_User_Explain">Similar to the bFDFRequestSave.&#10;&#10;False includes the user's certificate in all certificate requests. True excludes it.</string>
      <string id="bFDFExportSaveDC_User">FDF Export Save</string>
      <string id="bFDFExportSaveDC_User_Explain">Persists whether user chose to save (1) or email (0) the FDF during export.</string>
      <string id="bFDFExportSignDC_User">FDF Export Sign</string>
      <string id="bFDFExportSignDC_User_Explain">Persists whether the user chose to sign the FDF during export.</string>
      <string id="bFDFRequestSaveDC_User">FDF Request Save</string>
      <string id="bFDFRequestSaveDC_User_Explain">Caches a user's answer to the question whether they want to save the request as an FDF or email it directly when that user requests a certificate.</string>
      <string id="bFollowURIsFromAIADC_User">Follow AIA URIs</string>
      <string id="bFollowURIsFromAIADC_User_Explain">Specifies whether to allow the chain builder to follow URIs in AIA certificate extensions so that certificates can be downloaded if they are not available locally.&#10;&#10;The default does not allow phone-home capability. CRLdps and OCSP AIA extensions do allow following URIs because they require that the certificate chain up to a trust anchor.</string>
      <string id="bSigAPStatusIconDisableDC_User">Hide Sig Status Icon</string>
      <string id="bSigAPStatusIconDisableDC_User_Explain">Controls whether the signature status icon is displayed in the signature appearance on the document.&#10;&#10;If true, status icon is not displayed regardless of signature status. This setting overrides iDisplayValidIcon and bShowWarningForChanges.</string>
      <string id="cDialogs_xSelHandlerDC_User">ID Dialog Position</string>
      <string id="cDialogs_xSelHandlerDC_User_Explain">The last on-screen coordinates of a handler's digital ID selection dialog&#10;&#10;It is a subkey containing 4 keys: Top, Bottom, Left, and Right. This preference could be used by 3rd party handlers or by someone invoking a non-signing digital ID selection dialog via JavaScript.</string>
      <string id="bIgnoreNextUpdateDC_User">Ignore OCSP NextUpdate</string>
      <string id="bIgnoreNextUpdateDC_User_Explain">Specifies whether to use embedded OCSP responses when nextUpdate is not present and the validation time is less than the greater of thisUpdate or producedAt time plus the value of iMaxClockSkew .&#10;&#10;For 10.1 and later, this preference is used along with iMaxClockSkew to determine whether or not embedded OCSP responses are actually used for signature validation. For details, see the subfeature description above. This behavior is designed to support Acrobat's long term validation feature and allows validating a signature with embedded responses that were valid at signing time. Possible values include: 0: iMaxClockSkew is applied to thisUpdate on both sides of the validation time, i.e. thisUpdate - iMaxClockSkew ( validation time ( checkTime + iMaxClockSkew where checkTime is the later of the producedAt and thisUpdate. When true, iMaxClockSkew is applied to thisUpdate only before the validation time: thisUpdate - iMaxClockSkew ( validation time. 1: If there is no nextUpdate, then we accept the OCSP response indefinitely (we do not check for if the validation time is too late) and don't check whether validation time is ( than checkTime)</string>
      <string id="iImportAddressBookDC_User">Import Address Book</string>
      <string id="iImportAddressBookDC_User_Explain">Specifies whether the addressbook.acrodata file should be imported during a new install.&#10;&#10;Many admins set a value of 2 so that the import dialog does not appear for end users. Possible values include: 0: Do not copy the old address book. The user is NOT prompted and the address book should NOT be installed. 1 or null: Default: The user is asked whether the address book should either be installed or not. 2: Import the address book silently.</string>
      <string id="bCertStoreImportEnableDC_User">Import Windows Certs</string>
      <string id="bCertStoreImportEnableDC_User_Explain">If true, then users can import from MSCAPI certificate stores into their Trusted Identity Manager.</string>
      <string id="bDontRemoveOverlappingDC_User">Keep Hidden Content</string>
      <string id="bDontRemoveOverlappingDC_User_Explain">Specifies whether to remove hidden content when sanitizing a document.&#10;&#10;During sanitization workflows, the app automatically rasterizes the document if overlapping content exists. This can result in a large file size increase. Disable this feature to avoid extremely large files. 0: Remove hidden (overlapping) content. 1: Do not remove hidden content when sanitizing a document.</string>
      <string id="iAPIndexDC_User">Last Sig Appearance</string>
      <string id="iAPIndexDC_User_Explain">Remembers the last used signature appearance index.</string>
      <string id="bIsEnabledDC_User">Long Term Validation</string>
      <string id="bIsEnabledDC_User_Explain">Specifies whether the signature revocation status is included in the signature.&#10;&#10;Possible values include: 0: Don't enable LTV and include the signature revocation status information in the signature. 1: Enable LTV.</string>
      <string id="iMaxRevInfoArchiveSizeDC_User">Max Rev Info Archive</string>
      <string id="iMaxRevInfoArchiveSizeDC_User_Explain">The maximum size of the revocation archival information in kilobytes.&#10;&#10;An attempt is made to store as much revocation information as possible without exceeding the limit. Note that older product versions may have a smaller supported size limit.</string>
      <string id="iMaxVerifySessionDC_User">Max Verify Sessions</string>
      <string id="iMaxVerifySessionDC_User_Explain">Specifies the maximum number of nested verification sessions allowed.&#10;&#10;This is used to prevent the application from going into infinite loop verifying the OCSP and/or CRL signer certificates caused by incorrect OCSP and/or CRL certificate setup.</string>
      <string id="iCreateNewSigFieldAVAlertDC_User">New Sig Field Alert</string>
      <string id="iCreateNewSigFieldAVAlertDC_User_Explain">Specifies whether to show the alert asking whether a new signature field should be created.&#10;&#10;Possible values include: 0: Don't show an alert. 1: Do show an alert.</string>
      <string id="bEnNonEmbFontLegPDFWarnDC_User">Non-Embedded Font Warn</string>
      <string id="bEnNonEmbFontLegPDFWarnDC_User_Explain">Turns on and off warnings about non-embedded fonts.&#10;&#10;A warning appears when the LegalPDF dictionary NonEmbeddedFonts attribute has a non zero value. Turning this value on causes a warning to appear in the PDF Signature Report which indicates the document contains unembedded fonts.</string>
      <string id="iSendNonceDC_User">OCSP Nonce Behavior</string>
      <string id="iSendNonceDC_User_Explain">Specifies signature validation behavior with respect to nonces.&#10;&#10;With 10.0, this preference replaces bSendNonce. Possible values include: 0: No nonces are sent. 1: Nonces are included in the OCSP request and expected to be present in the response and should match the request's nonce. 2: Nonces are included in the OCSP request, but if none are present in the response, their abscence is ignored.</string>
      <string id="iURLToConsultDC_User">OCSP Responder URL</string>
      <string id="iURLToConsultDC_User_Explain">Specifies how the revocation checker chooses which responder to use.&#10;&#10;Possible values include: 0: Use the AIA extension in the certificate. 1: Use the URL key in sURL. 2: Use the AIA extension in the certificate. If it is not present, use the URL key in sURL. 3: Use the OCSP request signer's certificate AIA extension. Relevant only if SignRequest is 0.</string>
      <string id="iResponseFreshnessDC_User">OCSP Response Freshness</string>
      <string id="iResponseFreshnessDC_User_Explain">Specifies the amount of time in minutes after the response's published thisUpdate time for which the response will be valid.&#10;&#10;After that time, the response will be invalid.</string>
      <string id="bAllowOpenFileDC_User">Open Non-PDF Attachments</string>
      <string id="bAllowOpenFileDC_User_Explain">Specifies whether to open non-PDF attachments in their native application.&#10;&#10;bAllowOpenFile, bSecureOpenFile, and tBuiltInPermsList work in tandem: If any of these are set to prevent the opening of an attachment, then the attachment type won't open (or all attachments depending on the setting). Possible values include: 0: Prevent attachments from opening in their native application. 1: Allow attachments to open in their native application.</string>
      <string id="bPreviewModeBeforeSigningDC_User">Preview Before Signing</string>
      <string id="bPreviewModeBeforeSigningDC_User_Explain">Specifies whether a signer is forced to use preview mode during signing.&#10;&#10;If true, preview mode is automatically invoked on a sign action. Users should read the document message bar text, view a report about any warnings, and then choose Sign Document.</string>
      <string id="bRequireAKIDC_User">Require AKI in CRL</string>
      <string id="bRequireAKIDC_User_Explain">Specifies whether the Authority Key Identifier extension must be present in a CRL.</string>
      <string id="bRequireOCSPCertHashDC_User">Require OCSP Cert Hash</string>
      <string id="bRequireOCSPCertHashDC_User_Explain">Specifies whether a certificate public key hash extension must be present in OCSP responses.</string>
      <string id="iRequireReviewWarningsDC_User">Require Sign Warnings</string>
      <string id="iRequireReviewWarningsDC_User_Explain">Specifies whether the user is required to review document warnings before signing via the signing dialog.&#10;&#10;Interacts with iShowDocumentWarnings. The possible values include: 0: Never 1: Show when certifying only 2: Always</string>
      <string id="bReqSigPropRetrievalDC_User">Require Timestamp</string>
      <string id="bReqSigPropRetrievalDC_User_Explain">Indicates whether retrieving a signature property must succeed.&#10;&#10;Acrobat currently provides a signature property for timestamps. By default, retrieving a valid and trusted timestamp is not required, and property retrieval failure only results in creating a signature which uses the local time. When property retrieval is required during signature creation and fetching a timestamp fails for any reason (bad URL, no network connection, etc.) the signature creation process is aborted, no signature is created, and an error appears. 0: Make best effort, but success is not required. A signature is created. 1: Property retrieval must succeed. On failure, a signature is not created and an error dialog appears.</string>
      <string id="bRequireValidSigForChainingDC_User">Require Valid Sig Chain</string>
      <string id="bRequireValidSigForChainingDC_User_Explain">Specifies whether to allow the chain builder to build chains with invalid RSA signatures on certificates.&#10;&#10;Consider chain CA ) ICA ) EE where the CA's signature on an ICA is invalid. If this setting is true, the chain building will stop at the ICA and the CA will not be included in the chain. If this preference is false, the full 3-certificate chain is produced. This setting does not affect DSA signatures.</string>
      <string id="bReturnRevInfoToUserDC_User">Return Rev Info to JS</string>
      <string id="bReturnRevInfoToUserDC_User_Explain">If true, the revocation information is maintained within the SignatureInfo object and can be retrieved through JavaScript.&#10;&#10;For more information, see the Acrobat JavaScript Reference .</string>
      <string id="iRevocationCheckerDC_User">Revocation Checker</string>
      <string id="iRevocationCheckerDC_User_Explain">Specifies a provider for revocation checking.&#10;&#10;0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
      <string id="bRevCheckTrustDC_User">Revoke Check Trust</string>
      <string id="bRevCheckTrustDC_User_Explain">Specifies whether to perform revocation checks on intermediate trust anchors (those which aren't roots).&#10;&#10;In previous versions, the application did not perform revocation checks on any intermediate trust anchors since it was assumed they were self-signed. With 10.1.2 and 9.5, this setting enables revocation checking on intermediate trust anchors if such information is available. Trust anchors from 3rd parties are often installed locally to facilitate signature validation. Since it is possible that the trust anchors could become compromised and thereby open the host machine to malicious attack, those 3rd party providers in such cases would revoke their certificates. This preference enables detecting that revocation by forcing a revocation check on any intermediate trust anchors. Root and self-signed certificates are exempt from checking. Possible values include: 0: Don't perform a revocation check on intermediate trust anchors. 1: Perform a revocation check on intermediate trust anchors.</string>
      <string id="iRSAPSSSaltLengthDC_User">RSA-PSS Salt Length</string>
      <string id="iRSAPSSSaltLengthDC_User_Explain">Specifies the Salt Length the RSA-PSS algorithm uses.&#10;&#10;When setting the salt length, you must assure the default base is hexadecimal. Either change the base to decimal or input its hex value. For example, if the salt length decimal value is 32, then set the hex value to 20.</string>
      <string id="bEnableRSAPSSSigningDC_User">RSA-PSS Signing</string>
      <string id="bEnableRSAPSSSigningDC_User_Explain">Specifies whether a signature should be created with the RSA-PSS algorithm.&#10;&#10;Possible values include: 0: Do not sign with the RSA-PSS algorithm. 1: Use the RSA-PSS algorithm.</string>
      <string id="iDigSigSaveAsCertifiedDC_User">Save Certified Alert</string>
      <string id="iDigSigSaveAsCertifiedDC_User_Explain">&#10;&#10;Possible values include: 0: Don't show an alert. 1: Do show an alert.</string>
      <string id="bSecureOpenFileDC_User">Secure Open Attachments</string>
      <string id="bSecureOpenFileDC_User_Explain">Specifies whether to allow opening attachments which are not PDF.&#10;&#10;When this pref is set to true, then Acrobat only allows opening PDF attachments. bAllowOpenFile, bSecureOpenFile, and tBuiltInPermsList work in tandem: If any of these are set to prevent the opening of an attachment, then the attachment type won't open (or all attachments depending on the setting). Possible values include: 0: Allow opening attachments with filetype other than PDF. 1: Don't open non-PDF attachments.</string>
      <string id="bSelfSignCertGenDC_User">Self-Sign ID Create</string>
      <string id="bSelfSignCertGenDC_User_Explain">Specifies whether or not the Create a self-signed ID option in Add ID workflows is available.&#10;&#10;Prevents users from creating a self-signed digital ID. Note that for products released after June 2016, disabling a user's ability to create a self-signed digital ID requires setting both bSelfSignCertGen and bEnableCEFBasedUI to 0. Possible values include: 0: Don't allow creating self-signed digital IDs. 1: Allow self-signed digital IDs.</string>
      <string id="bShowAllChainsDC_User">Show All Chains</string>
      <string id="bShowAllChainsDC_User_Explain">Specifies whether to show all chains in the Certificate Viewer.&#10;&#10;If true, the Certificate Viewer shows all the chains; otherwise, it shows only the trusted chain. If there are no trusted chains, then all the chains are shown and this preference is ignored.</string>
      <string id="iShowDocumentWarningsDC_User">Show Document Warnings</string>
      <string id="iShowDocumentWarningsDC_User_Explain">Specifies whether a button to allow reviewing document warnings shows up on the signing dialog.&#10;&#10;Interacts with iRequireDocumentWarnings. The possible values include: 0: Never 1: Show when certifying only 2: Always</string>
      <string id="bShowWarningForChangesDC_User">Show Post-Sign Warning</string>
      <string id="bShowWarningForChangesDC_User_Explain">Determines whether or not to show a blue i on validated signature(s) if the document changes after it was signed.&#10;&#10;If true, a document change results in a blue i status icon appearing for validated approval signatures. Use this setting when users need to know a document has changed after it was signed. If false, the status icon remains a green check and pen even if a document changes after it is signed. The setting provides a method for administrators to turn off the blue i in workflows where documents can be changed or signed multiple times. This setting does not affect certification signatures. The warning icon never appears for valid certification or approval signatures in certified documents if the signatures were allowed by the certifier. Interacts with iDisplayValidIcon which cannot be set to 2, or the icons will not appear regardless of how bShowWarningForChanges is set.</string>
      <string id="bAllowOtherInfoWhenSigningDC_User">Show Sign Contact Info</string>
      <string id="bAllowOtherInfoWhenSigningDC_User_Explain">Specifies whether the location and contact information UI will appear during signing.</string>
      <string id="bShowSignerWarningsDC_User">Show Signer Warnings</string>
      <string id="bShowSignerWarningsDC_User_Explain">Specifies whether to show a warning that there is a greater forgery risk when revocation information is embedded in the signature.&#10;&#10;Because this warning was removed from 10.x products, this preference is only applicable to 9.4.6 and later products in the 9.x line. Possible values include: 0: Don't show the warnings. 1: Do show the warnings.</string>
      <string id="iDisplayValidIconDC_User">Show Valid Sig Icon</string>
      <string id="iDisplayValidIconDC_User_Explain">Determines when the signature status icon is displayed in a signature appearance.&#10;&#10;Possible values include: 0: Always. 1: Display except when the signature is valid. 2: Never. This value disables bShowWarningForChanges and removes the Hide signature field validity icon option from the GUI. This setting does not affect the icons in the Signatures Pane or in the Signature Properties dialog Note : This UI item was removed from versions 9.x and later because signature status was moved to the Document Message Bar.</string>
      <string id="bReqSigPropVerificationDC_User">Sig Property Verify</string>
      <string id="bReqSigPropVerificationDC_User_Explain">Specifies whether signature property verification must succeed for a signature to be valid.&#10;&#10;As of 8.0, the only property used is the timestamp URL.</string>
      <string id="iSigVerificationTimeDC_User">Sig Verification Time</string>
      <string id="iSigVerificationTimeDC_User_Explain">Indicates the time at which signature validation should occur.&#10;&#10;Possible values include: 0: Always carry out the verification at current time 1: Use the signing time if it's secure (e.g. timestamped), else use current time 2: Always use signing time</string>
      <string id="bAllowSigCertOnlyDC_User">Sign Certified Only</string>
      <string id="bAllowSigCertOnlyDC_User_Explain">Specifies whether any subsequent signers can sign a certified document containing LegalPDF warnings with additional approval signatures.&#10;&#10;In other words, the presence of any LegalPDF warning prevent any additonal signatures.</string>
      <string id="isignDoneDC_User">Sign Done Dialog</string>
      <string id="isignDoneDC_User_Explain">Specifies whether to show a dialog indicating that a document was successfully signed.&#10;&#10;Possible values include: 0: Show the dialog after signing successfully. 1: Don't show the dialog after signing successfully.</string>
      <string id="bAllowSigCertGreenOnlyDC_User">Sign Green Cert Only</string>
      <string id="bAllowSigCertGreenOnlyDC_User_Explain">Specifies whether any subsequent signers can sign a certified document that does not contain LegalPDF warnings with additional approval signatures.&#10;&#10;In other words, the presence of any LegalPDF warning does not prevent any additonal signatures.</string>
      <string id="bSignRequestDC_User">Sign OCSP Requests</string>
      <string id="bSignRequestDC_User_Explain">Specifies whether the OCSP request should be signed.&#10;&#10;Some OCSP providers require that OCSP requests are signed (e.g IdenTrust). 0: Don't sign the OCSP request. 1: Force Acrobat to sign OCSP requests prior to sending.</string>
      <string id="iHashAlgoDC_User">Timestamp Hash Algo</string>
      <string id="iHashAlgoDC_User_Explain">Identifies the hashing algorithm used to hash the timestamped data.&#10;&#10;The valid values are: 0: MD5 1: SHA1 2: SHA256 For an alternative, see sHashAlgo which supports more options.</string>
      <string id="iSizeDC_User">Timestamp Sig Size</string>
      <string id="iSizeDC_User_Explain">ASPKI requires the signature property to predict the size (in bytes) so that enough space can be set aside.</string>
      <string id="bTrueTypeFontPDFSigQWarnDC_User">TrueType Font Warn</string>
      <string id="bTrueTypeFontPDFSigQWarnDC_User_Explain">Turns on and off warnings about True Type fonts.</string>
      <string id="bTrustCertifiedDocumentsDC_User">Trust Certified Docs</string>
      <string id="bTrustCertifiedDocumentsDC_User_Explain">Elevates (trusts) certified documents as a privileged location.&#10;&#10;This setting allows certified documents to bypass all the security restrictions that may be bypassed by other privileged locations. The exception is that this level of trust does not apply when the PDF is viewed in Protected View. To lock this setting, set bEnableCertificateBasedTrust . Possible values include: 0 or null: Don't make certified documents equivalent to privileged locations. 1: Do make certified documents equivalent to privileged locations (trusted).</string>
      <string id="bTrustOSTrustedSitesDC_User">Trust IE Trusted Sites</string>
      <string id="bTrustOSTrustedSitesDC_User_Explain">Elevates locations that Internet Explorer trusts to privileged locations so that they may bypass security restrictions.&#10;&#10;Prior to 10.1.1 and 9.4.7, trust was granted to Trusted Sites. With 10.1.2 and 9.5 and later, trust also includes Local Intranet zones. This setting essentially makes IE trust operate as if they were privileged locations. The feature can be disabled with bDisableOSTrustedSites. 0: Don't automatically trust Windows OS zones. 1: Do automatically trust Windows OS zones.</string>
      <string id="iURLPermsDC_User">URL Access Permissions</string>
      <string id="iURLPermsDC_User_Explain">Specifies whether to allow or block all websites or use a custom setting.&#10;&#10;If the user selects Custom Setting, tHostPerms is populated with the user's custom URLs. If Allow or Block is later selected, then iURLPerms overrides tHostPerms and tHostPerms is reset to null (the user list is ignored). Possible values include: 0: Custom Setting 1: Block all websites 2: Allow all websites For additional security-related details, refer to the Application Security Guide .</string>
      <string id="iUseArchivedRevInfoDC_User">Use Archived Rev Info</string>
      <string id="iUseArchivedRevInfoDC_User_Explain">Indicates whether the revocation information archived with the signature is used for revocation checking.&#10;&#10;Allowable values include: 0: Never (always require fresh revocation information to be successfully downloaded). 1: Deprecated. Do not use. 2: Always use (if embedded revocation information is available do not download fresh revocation information).</string>
      <string id="iValidityModelDC_User">Validity Model</string>
      <string id="iValidityModelDC_User_Explain">Specifies the validity model for validating signatures and certificates.&#10;&#10;The application uses shell validation by default, but chain validation may be used when required. Compliance with the German signature law requires chain validation. Allowabled values include: 0: PKIX shell model 1: Chain validity model. Chain validation is used to validate all or part of a certificate chain when any certificate chaining up to a CA certificate containing the qualified certificate policy extension (OID 1.3.36.8.1.1) or the validity model certificate extension OID (1.3.6.1.4.1.8301.3.5) with the value set to the chain model OID (1.3.6.1.4.1.8301.3.5.1).</string>
      <string id="iMSStoreTrustedDC_User">Windows Store Trust</string>
      <string id="iMSStoreTrustedDC_User_Explain">Controls whether or not certificates in the Windows Certificate Store are trusted for signing and certifying.&#10;&#10;To lock this setting, use bMSStoreTrusted. Allowable values include: 0x00: No checkbox selected. 0x60: Validating Signatures. 0x62: Validating Certified Documents and Signatures. Note that this setting disables the Validating Signatures checkbox because it also controls non-certified signatures and users should not be able to uncheck that checkbox.</string>

      <!-- ======================================== -->
      <!--           Sharing and Features           -->
      <!-- ======================================== -->

      <string id="iSendMailDefaultAccountAlertDC_User">Default Email Prompt</string>
      <string id="iSendMailDefaultAccountAlertDC_User_Explain">Specifies whether a dialog should appear asking if a PDF should be sent via the user's default email account.&#10;&#10;When a new user tries to send a PDF via email, a dialog appears and asks &quot;How would you like to send this email.&quot; Users then need to select a choice and check Remember my choice . Possible values include: 0: Don't show the dialog. 1: Do show the dialog.</string>
      <string id="bDefaultSetDC_User">Default Email Set</string>
      <string id="bDefaultSetDC_User_Explain">Indicates whether a default email client has been set.&#10;&#10;Possible values include: 0: Default webmail client is not set. 1: Default webmail client is set.</string>
      <string id="bDisableSharedReviewDC_User">Disable Shared Review</string>
      <string id="bDisableSharedReviewDC_User_Explain">Specifies whether to enable cloud-based shared reviews.&#10;&#10;To completely disable the Document Cloud Review service, disable all services or set bToggleAdobeReview (See FeatureLockDown for details). When set to 0, this preference removes Document Cloud Review service, including the Send for Review tool in the tool's pane and its associated menus. Possible values include: 0: Remove the option to use the DC review service when a user chooses Tools ) Send for Review OR Send for Review in the right-hand pane. Only legacy review types are available. 1: Enable the Document Cloud Review service option.</string>
      <string id="bNeedSynchronizerDC_User">Enable Synchronizer</string>
      <string id="bNeedSynchronizerDC_User_Explain">Disables the synchronizer.&#10;&#10;Features that use the synchronizer include services, the Adobe Acrobat Trust List, shared reviews, the recent files list (11.0.07+), and data collection in some forms workflows prior to 11.0.07. Disabling the Synchronizer is not recommended. Possible values include: 0: Disable the synchronizer. 1: Enable the synchronizer. Note that Acrobat and Reader do not use the same synchronizer. When there is an older minor version of Acrobat or Reader and the newer minor version is 11.0.07-11.1.10: Both Acrobat and Reader get the new synchronizer when updating to .07 or later. If the newer synchronizer is running, it supports older services and non-services operations. If the older synchronizer (pre 11.0.07) is running, sync-dependent operations do not work [3746864]</string>
      <string id="bEnableFillSignDC_User">Fill &amp; Sign Pane</string>
      <string id="bEnableFillSignDC_User_Explain">Specifies whether to remove the Fill and Sign pane without removing the Work with Certificates menu.&#10;&#10;11.x products only. This setting allows users to remove the Acrobat Sign menu items without removing the menu item for using digital signatures on the local machine. Possible values include: 0: Remove the Fill and Sign pane. 1: Don't remove the Fill and Sign pane.</string>
      <string id="bRemoveCommaDelimiterDC_User">Remove Comma Delimiter</string>
      <string id="bRemoveCommaDelimiterDC_User_Explain">Specifies whether to remove the comma in comma-delimited addressbook entries.&#10;&#10;During shared review workflows, the user invoke the addressbook to invite participants. In cases where the addressbook is comma-delimited, pre DC versions of the product display an error dialog. Use this prefererence to remove commas. Possible values include: 0: Don't remove commas. 1: Remove commas.</string>
      <string id="iSendForReviewConfirmDC_User">Review Confirm Alert</string>
      <string id="iSendForReviewConfirmDC_User_Explain"></string>
      <string id="bShowConnectDialogDC_User">Show Connect Dialog</string>
      <string id="bShowConnectDialogDC_User_Explain">Specifies whether to display the Connect dialog in Shared Reviews.&#10;&#10;Possible values include: 0: Don't show the Connect dialog. 1: Do show the Connect dialog.</string>
      <string id="bIsUsedShareReviewDC_User">Show Review Tip</string>
      <string id="bIsUsedShareReviewDC_User_Explain">Specifies whether to show a popup tip that informs users of the collaborative review feature.&#10;&#10;The popup only appears if the user has opened a review file but has not sent a review file. Once the user has initiated a review, the application sets this value to 1, and the popup no longer appears. Possible values include: 0: Show the tip. 1: Don't show the tip.</string>
      <string id="bIsUsedShareDC_User">Show Share Tip</string>
      <string id="bIsUsedShareDC_User_Explain">Specifies whether to show a popup tip that informs users of the share file feature.&#10;&#10;The popup only appears if the user has opened a shared file but has not shared a file. Once the user has shared a file, the application sets this value to 1, and the popup no longer appears. Possible values include: 0: Show the tip. 1: Don't show the tip.</string>
      <string id="bShowWelcomeDialogDC_User">Show Welcome Dialog</string>
      <string id="bShowWelcomeDialogDC_User_Explain">Specifies whether to show the Welcome dialog when a shared review is initiated.&#10;&#10;Possible values include: 0: Don't show the welcome dialog. 1: Do show the welcome dialog.</string>

      <!-- ======================================== -->
      <!--          Startup and Experience          -->
      <!-- ======================================== -->

      <string id="bActivatedDC_User">App Activated</string>
      <string id="bActivatedDC_User_Explain">Records whether the application has been activated online after installation.&#10;&#10;Possible values include: 0: Not activated 1: Activated</string>
      <string id="bHasLaunchedDC_User">App Has Launched</string>
      <string id="bHasLaunchedDC_User_Explain">Records whether the application has been launched after installation.&#10;&#10;Possible values include: 0: Not launched 1: Launched</string>
      <string id="bAppInitializedDC_User">App Initialized</string>
      <string id="bAppInitializedDC_User_Explain">Records whether the application has been initialized after installation.&#10;&#10;Possible values include: 0: Not initialized 1: Initialized</string>
      <string id="bLaunchedDC_User">App Launched</string>
      <string id="bLaunchedDC_User_Explain">Caches whether or not the application has ever been launched.&#10;&#10;Application behavior may vary across versions depending on whether the application has been launched. Possible values include: 0: The application has not been launched. 1: The application has been launched.</string>
      <string id="EULAAcceptedForBrowserDC_User">Browser EULA Accepted</string>
      <string id="EULAAcceptedForBrowserDC_User_Explain">For Acrobat's browser plugin, caches whether the browser-based EULA has been accepted.&#10;&#10;On Macintosh, this preference can not be set in the plist. Use the Mac Wizard or the PRTK tool. Reader uses the key EULA. If the EULA is not accepted, the application stops running after a set period of time. Possible values include: 0: Show the EULA because it has not been accepted. 1: Don't show the EULA.</string>
      <string id="bChooseLangAtStartupDC_User">Choose Language Startup</string>
      <string id="bChooseLangAtStartupDC_User_Explain">Allows the user to choose the language at startup.</string>
      <string id="bCreateFormDiscoveryShownDC_User">Create Form Onboarding</string>
      <string id="bCreateFormDiscoveryShownDC_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Create Form panel.&#10;&#10;Possible values include: 0: Show the onboarding coachmark. 1: Don't show the onboarding coachmark.</string>
      <string id="bEditDiscoveryShownDC_User">Edit Onboarding</string>
      <string id="bEditDiscoveryShownDC_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Edit panel.&#10;&#10;Possible values include: 0: Show the onboarding coachmark. 1: Don't show the onboarding coachmark.</string>
      <string id="iEULAAcceptanceTimeDC_User">EULA Accept Timeout</string>
      <string id="iEULAAcceptanceTimeDC_User_Explain">The amount of time granted to users after installation to accept the end user agreement.</string>
      <string id="bFillSignDiscoveryShownDC_User">Fill &amp; Sign Onboarding</string>
      <string id="bFillSignDiscoveryShownDC_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Fill &amp; Sign panel.&#10;&#10;Possible values include: 0: Show the onboarding coachmark. 1: Don't show the onboarding coachmark.</string>
      <string id="bHideHelpWelcomeDC_User">Hide Help Welcome</string>
      <string id="bHideHelpWelcomeDC_User_Explain">Specifies whether to disable the Welcome menu item under Help.&#10;&#10;Possible values include: 0 or null: Enable the Welcome menu item. 1: Disable the Welcome menu item.</string>
      <string id="bShownHomeOnboardingDC_User">Home Onboarding</string>
      <string id="bShownHomeOnboardingDC_User_Explain">Specifies whether to invoke the home onboarding tour when the modern viewer is invoked the first time.&#10;&#10;Once the home onboarding tour displays, the app automatically resets this value to 0. This preference has no effect if AVGeneral/bEnableAv2 is 0. Possible values include: 0: Show the onboarding tour (not yet shown). 1: Don't show the onboarding tour (already shown or declined).</string>
      <string id="bLoadAllPluginsAtStartupDC_User">Load All Plugins</string>
      <string id="bLoadAllPluginsAtStartupDC_User_Explain">Specifies whether all plugins should be loaded when the application is started.</string>
      <string id="bOrganizeDiscoveryShownDC_User">Organize Onboarding</string>
      <string id="bOrganizeDiscoveryShownDC_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Organize panel.&#10;&#10;Possible values include: 0: Show the onboarding coachmark. 1: Don't show the onboarding coachmark.</string>
      <string id="bUsePageCacheDC_User">Page Caching</string>
      <string id="bUsePageCacheDC_User_Explain">Specifies whether to cache pages that have been loaded.&#10;&#10;Possible values include: 0: Don't cache pages. 1: Do cache pages</string>
      <string id="bRedactDiscoveryShownDC_User">Redaction Onboarding</string>
      <string id="bRedactDiscoveryShownDC_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Redaction panel.&#10;&#10;Possible values include: 0: Show the onboarding coachmark. 1: Don't show the onboarding coachmark.</string>
      <string id="bDisplayAboutDialogDC_User">Show About Dialog</string>
      <string id="bDisplayAboutDialogDC_User_Explain">Specifies whether or not to display the startup splash screen at every launch.&#10;&#10;Possible values include: 0: Don't display the startup splash screen. 1: Display the startup splash screen at every launch.</string>
      <string id="idontShowAllImagesHaveAltTextDC_User">Show Alt Text Alert</string>
      <string id="idontShowAllImagesHaveAltTextDC_User_Explain">Toggles whether to show an alert when a user executes the Set Alternate Text dialog and there are no images missing alternate text.&#10;&#10;Possible values include: 0: Show alert. 1: Don't show alert.</string>
      <string id="bshowEULADC_User">Show EULA Startup</string>
      <string id="bshowEULADC_User_Explain">Toggles on and off whether the end user license agreement appears.</string>
      <string id="bLastShowStatusDC_User">Show Getting Started</string>
      <string id="bLastShowStatusDC_User_Explain">Specifies whether to show &quot;Get Started with Acrobat&quot; on startup.&#10;&#10;Possible values include: 0: Don't show the Getting Started page. 1: Show the Getting Started page.</string>
      <string id="bShowHorizontalScrollbarDC_User">Show H-Scrollbar</string>
      <string id="bShowHorizontalScrollbarDC_User_Explain">Specifies whether to show a horizontal scrollbar when the viewing area is narrower than the width of the loaded document.&#10;&#10;Possible values include: 0: Disable the horizontal scrollbar. 1: Enable the horizontal scrollbar.</string>
      <string id="bShowExistingAttachedReportAlertDC_User">Show Report Alert</string>
      <string id="bShowExistingAttachedReportAlertDC_User_Explain">Toggles whether to show an alert when a user tries to attach a report if there is already a report attached.&#10;&#10;Possible values include: 0: Show alert. 1: Don't show alert.</string>
      <string id="idontShowSetAltTextInfoDC_User">Show Set Alt Alert</string>
      <string id="idontShowSetAltTextInfoDC_User_Explain">Toggles whether to show an informative alert when a user executes the Set Alternate Text dialog.&#10;&#10;Possible values include: 0: Show alert. 1: Don't show alert.</string>
      <string id="bShowedSkipCardDC_User">Show Skip Card</string>
      <string id="bShowedSkipCardDC_User_Explain">Specifies whether to show the skipped onboarding coachmark.&#10;&#10;Possible values include: 0: Disables the feature. 1: Enables the feature.</string>
      <string id="bSplashDisplayedAtStartupDC_User">Show Splash Screen</string>
      <string id="bSplashDisplayedAtStartupDC_User_Explain">Toggles whether the splash screen appears on startup.</string>
      <string id="bDisplayedSplashDC_User">Splash Displayed</string>
      <string id="bDisplayedSplashDC_User_Explain">Indicates whether or not the application has started up and invoked the splash screen.&#10;&#10;Possible values include: 0: The splash screen has not been invoked yet. 1: The splash screen has been invoked.</string>
      <string id="bInTrialModeDC_User">Trial Mode Active</string>
      <string id="bInTrialModeDC_User_Explain">Records whether the application is operating in Trial Mode.&#10;&#10;Possible values include: 0: Not in trial mode 1: In trial mode</string>
      <string id="bShownViewerOnboardingDC_User">Viewer Onboarding</string>
      <string id="bShownViewerOnboardingDC_User_Explain">Specifies whether to invoke the new viewer onboarding tour when a PDF opens in the modern viewer the first time.&#10;&#10;Once the viewer onboarding tour displays, the app automatically resets this value to 0. This preference has no effect if AVGeneral/bEnableAv2 is 0. Possible values include: 0: Show the onboarding tour (not yet shown). 1: Don't show the onboarding tour (already shown or declined).</string>
      <string id="iDelayBeforeQuitViewerDC_User">Viewer Quit Delay</string>
      <string id="iDelayBeforeQuitViewerDC_User_Explain">Specifies the number of seconds the standalone application stays in memory before it shuts down.&#10;&#10;Possible values include: 30 Any integer</string>

      <!-- ======================================== -->
      <!--     Updates and Desktop Integration      -->
      <!-- ======================================== -->

      <string id="bDownloadEntireFileDC_User">Background Download</string>
      <string id="bDownloadEntireFileDC_User_Explain">Specifies whether to allow background downloading of resources the view thinks it needs to properly display the PDF.&#10;&#10;Possible values include: 0: Don't allow background downloading. 1: Do allow background downloading.</string>
      <string id="iDelayBeforeQuitBrowserDC_User">Browser Quit Delay</string>
      <string id="iDelayBeforeQuitBrowserDC_User_Explain">Specifies the number of seconds the browser-based application stays in memory before it shuts down.&#10;&#10;Possible values include: 30 Any integer</string>
      <string id="bBrowserDisplayInReadModeDC_User">Browser Read Mode</string>
      <string id="bBrowserDisplayInReadModeDC_User_Explain">Specifies whether to open documents in a browser in Read Mode.&#10;&#10;Read Mode was introduced in Acrobat and Reader 10.0 to enhance the PDF viewing experience for documents in a browser. Read Mode turns off the standard toolbars and menu items and provides a more compact and simple menu bar only when a user hovers over the bottom, middle area of the PDF. For more information, see the Browser Integration Quick Key in the Quick Key Library . Possible values include: 0: Don't use Read Mode and display the standard toolbars. 1: Use Read Mode and hide the standard toolbars.</string>
      <string id="bInstalledCleanupCheckDoneDC_User">Cleanup Check Done</string>
      <string id="bInstalledCleanupCheckDoneDC_User_Explain">A preference used by the usage measurement feature to determine whether the previously set UsageMeasurement-related keys should be reset.</string>
      <string id="bLoadOnStartDC_User">Collab Sync Startup</string>
      <string id="bLoadOnStartDC_User_Explain">Specifies whether the collaboration executable should be invoked and run as a background process on startup.&#10;&#10;When enabled, AdobeCollabSync.exe runs on application startup. This process is used for features like shared reviews and forms data collection . Possible values include: 0: Start the process. 1: Don't start the process.</string>
      <string id="bAllowByteRangeRequestsDC_User">Fast Web View</string>
      <string id="bAllowByteRangeRequestsDC_User_Explain">Specifies whether to enable Fast Web View by allowing display of the PDF before the entire file is downloaded.&#10;&#10;Possible values include: 0: Don't enable Fast Web View. 1: Enable Fast Web View.</string>
      <string id="bFavoriteFilesRememberChoiceDC_User">Remember Stars Choice</string>
      <string id="bFavoriteFilesRememberChoiceDC_User_Explain">Specifies the users choice&#10;&#10;When a user selects &quot;Ask every time&quot; and iFavoriteFilesAccessOption is set to 0, this new preference remembers the users choice for each file. Possible values include: Application generated.</string>
      <string id="bFavoritesStripInRFLDC_User">Show Starred Files</string>
      <string id="bFavoritesStripInRFLDC_User_Explain">Specifies whether to show starred files in the recent files list.&#10;&#10;A starred file is somewhat similar to a &quot;favorited&quot; file. Note that the lockable version of this preference is named bFavoritesFeaturesLockDown . Possible values include: 0: Show starred files in the recent files list. 1: Don't show starred files in the recent files list.</string>
      <string id="iFavoriteFilesAccessOptionDC_User">Starred Files Action</string>
      <string id="iFavoriteFilesAccessOptionDC_User_Explain">Specifies what action to take when starring a file.&#10;&#10;A starred file is somewhat similar to a &quot;favorited&quot; file. Possible values include: 0: Show a dialog and ask whether to save or upload. This option also results in creating a new bFavoriteFilesRememberChoice . 1: Upload to Document Cloud 2: Save the file locally</string>
      <string id="bStoreCredentialsDC_User">Store Credentials</string>
      <string id="bStoreCredentialsDC_User_Explain">Specifies whether the user logon credentials for the Tracker should be stored.&#10;&#10;Possible values include: 0: Don't store credentials. 1: Store credentials.</string>
      <string id="iAVARMNoAutoUpdateWarningDC_User">Suppress Update Warning</string>
      <string id="iAVARMNoAutoUpdateWarningDC_User_Explain">Specifies whether to turn of the &quot;Updater has not been able to check for updates recently&quot; dialog.&#10;&#10;Possible values include: 0: Don't turn off the dialog. 1: Do turn off the dialog.</string>

      <!-- ======================================== -->
      <!--                  Upsell                  -->
      <!-- ======================================== -->

      <string id="bAcrobatAppInstalledDC_User">Acrobat App Promo</string>
      <string id="bAcrobatAppInstalledDC_User_Explain">Specifies whether to show the Acrobat mobile app promotion and link in the Home banner.&#10;&#10;Disable and lock both the App Center and Home banner with bToggleDCAppCenter under FeatureLockDown. Possible values include: 0: Promote the mobile app. 1: Don't promote the mobile app.</string>
      <string id="bScanAppInstalledDC_User">Scan App Promo</string>
      <string id="bScanAppInstalledDC_User_Explain">Specifies whether to show the Adobe Scan mobile app promotion and link in the Home banner.&#10;&#10;Disable and lock both the App Center and Home banner with bToggleDCAppCenter under FeatureLockDown. Possible values include: 0: Promote the mobile app. 1: Don't promote the mobile app.</string>
      <string id="bShowTrialNagDC_User">Show Trial Nag</string>
      <string id="bShowTrialNagDC_User_Explain">Specifies whether a &quot;Trial Expired&quot; dialog should appear after 30 days.&#10;&#10;This preference is automatically set by the application. When the 30 day trial period expires, Acrobat is launched in reduced functionality mode, and a dialog appears asking if the user would like to purchase the product. Possible values include: 0: Don't show the &quot;Trial Expired&quot; dialog. 1: &quot;Trial Expired&quot; dialog.</string>

      <!-- ======================================== -->
      <!--                                          -->
      <!-- Adobe Reader DC (User) - policy strings  -->
      <!--                                          -->
      <!-- ======================================== -->

      <!-- ======================================== -->
      <!--        Context, Tools and Search         -->
      <!-- ======================================== -->

      <string id="iColumnSelectHalo_User">Column Select Halo</string>
      <string id="iColumnSelectHalo_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
      <string id="bAlwaysUseFileNameAsDocTitle_User">Filename as Title</string>
      <string id="bAlwaysUseFileNameAsDocTitle_User_Explain">Specifies whether to use the PDF file name as the display name in the application's title bar.&#10;&#10;PDF documents have an Initial View property that's set to &quot;Document Title&quot; by default. Enabling this preference overrides any document-level setting with the app-level setting. Possible values include: 0: Don't use file names. 1: Use file names for the PDF title.</string>
      <string id="bUseFixedSnapshotResolution_User">Fixed Snapshot Resolution</string>
      <string id="bUseFixedSnapshotResolution_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
      <string id="ADC4318556_User">Flash Player for 3D</string>
      <string id="ADC4318556_User_Explain">Enables playing 3D and multimedia content using a Flash player in PDF.&#10;&#10;Since Flash is no longer supported, admins must install and configure the player. Possible values include: 0 or null: Don't play content with a Flash player. 1: Use the Flash player.</string>
      <string id="bHandSelects_User">Hand Tool Select</string>
      <string id="bHandSelects_User_Explain">Specifies whether the hand tool should be able to select text and images.&#10;&#10;With the DC 10/13/2015 release, this setting also works on Windows Touch devices. Possible values include: 0: Don't select text and images. 1: Select text and images.</string>
      <string id="iMaxMRUCntToBeStored_User">Max Recent Files</string>
      <string id="iMaxMRUCntToBeStored_User_Explain">Stores the number of recent files that should be listed in the recent files list.&#10;&#10;The recent files list appears under the file menu (5 item limit), the splash screen (5 item limit), and in My Files View (100 item limit). A number from 0-100. The default is 100.</string>
      <string id="bEnableAv2_User">Modern Viewer</string>
      <string id="bEnableAv2_User_Explain">Specifies whether to show the modern viewer first released in July 2022.&#10;&#10;0: Show the classic viewer. 1: Show the modern viewer.</string>
      <string id="bAllowMultipleExpandedPanels_User">Multiple Comment Panels</string>
      <string id="bAllowMultipleExpandedPanels_User_Explain">Specifies whether multiple comment panels can be expanded.&#10;&#10;Possible values include: 0: Don't allow more than one visible panel. 1: Do allow multiple visible panels.</string>
      <string id="iNumSwitcherContextualToolTipAV2Shown_User">New Look Coachmark</string>
      <string id="iNumSwitcherContextualToolTipAV2Shown_User_Explain">Specifies whether to show the &quot;Acrobat has a new look&quot; coachmark after launching Acrobat the first time.&#10;&#10;Once the coachmark displays, the app automatically resets this value to 0. This preference has no effect if bEnableAv2 is 0. 0: Do not show the coachmark. 1: Show the coachmark.</string>
      <string id="bPinHUD_User">Pin HUD Toolbar</string>
      <string id="bPinHUD_User_Explain">Specifies whether to pin the HUD to the toolbar.&#10;&#10;The application automatically creates this key when you click the &quot;pin to menu&quot; icon on the right-hand side of the HUD. Possible values include: 0: Don't pin the HUD to the toolbar. 1: Pin the HUD to the toolbar.</string>
      <string id="bPromptBeforeClosingMultipleTabs_User">Prompt Close Tabs</string>
      <string id="bPromptBeforeClosingMultipleTabs_User_Explain">Specifies whether to warn the user before closing documents open in multiple tabs.&#10;&#10;The ability to open documents in separate tabs was introduced in October, 2015. Possible values include: 0: Don't warn the user. 1: Warn the user.</string>
      <string id="bImagesFirst_User">Select Images First</string>
      <string id="bImagesFirst_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
      <string id="bInfobubble_User">Show Tool Pane Tips</string>
      <string id="bInfobubble_User_Explain">Specifies whether the popup tooltips for the Tools, Comments, and Share panes should appear.&#10;&#10;Possible values include: 0: Disable popup tooltips. 1: Enable popup tooltips.</string>
      <string id="bKeyPrefsShowVirtualKeyoard_User">Show Touch Keyboard</string>
      <string id="bKeyPrefsShowVirtualKeyoard_User_Explain">Specifies whether to show the touch keyboard if device is in touch or tablet mode on Win 8 and later.&#10;&#10;In general, the virtual keyboard should only appear on touch devices running Windows 8 and later where the user has detached a soft keyboard. The keyboard should appear when a user taps a text area such as a search box, comment popup, form field, and so on. Possible values include:</string>
      <string id="iSnapshotResolution_User">Snapshot Resolution DPI</string>
      <string id="iSnapshotResolution_User_Explain">Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
      <string id="irightPaneState_User">Tools Pane State</string>
      <string id="irightPaneState_User_Explain">Specifies whether to automatically open the Tools Pane on launch.&#10;&#10;Possible values include: 0: Use the default. 1: Always closed. 2: Always open.</string>
      <string id="iBasicSharePaneStickyStatus_User">Tools Pane Sticky</string>
      <string id="iBasicSharePaneStickyStatus_User_Explain">Specifies whether to remember the Tools Pane state across sessions.&#10;&#10;For example, if the user closes the Tools Pane, it will not automatically open on launch. Interacts with irightPaneState. Possible values include: 0: Don't remember the Tool Pane's state. The Pane is always closed on application open. 1: Do remember the Tool Pane's state.</string>
      <string id="iNumSwitcherContextualToolTipAVShown_User">Try New Coachmark</string>
      <string id="iNumSwitcherContextualToolTipAVShown_User_Explain">Specifies whether to show the &quot;Try the new Acrobat/Reader&quot; coachmark after launching Acrobat the first time.&#10;&#10;Once the coachmark displays, the app automatically resets this value to 0. This preference has no effect if bEnableAv2 is 0. 0: Do not show the coachmark. 1: Show the coachmark.</string>
      <string id="iNumSessionAV2_User">UI Switcher Sessions</string>
      <string id="iNumSessionAV2_User_Explain">Specifies whether to show the UI switcher coachmark based on the number of user sessions.&#10;&#10;Interacts with iNumSwitcherContextualToolTipAV2Shown . Possible values include: 0 or 1: Don't show the UI switcher. 2 or greater: Show the UI switcher if iNumSwitcherContextualToolTipAV2Shown is 0.</string>

      <!-- ======================================== -->
      <!--   Documents, Editing and Accessibility   -->
      <!-- ======================================== -->

      <string id="bUse2DGPUf_User">2D GPU Acceleration</string>
      <string id="bUse2DGPUf_User_Explain">Specifies whether 2D graphics acceleration should be used.&#10;&#10;Possible values include: 0: Disable 1: Enable</string>
      <string id="bAllowDocsToHideUI_User">Allow Hide UI</string>
      <string id="bAllowDocsToHideUI_User_Explain">Specifies whether to allow documents to hide the menu bar, toolbars, and window controls.&#10;&#10;Possible values include: 0: Don't allow documents to hide UI elements. 1: Allow documents to hide UI elements.</string>
      <string id="benableTextSelection_User">Annotation Text Selection</string>
      <string id="benableTextSelection_User_Explain">Specifies whether to enable text selection for annotations such as highlight, strikethrough or underline.&#10;&#10;Possible values include: 0: Enable text selection. When enabled, the cursor changes to ][ mode when the annotation (highlight, strikethrough or underline) is clicked and hovered over for more than 2 seconds. The cursor reverts to the previous mode after a time duration of 3 seconds upon hovering outside the bounding box of the annot. 1: Don't enable text selection. When disabled, the cursor changes to ][ mode only upon selecting Enable Text selection in the context menu. It will then remain in ][ mode for all annotations on the page.</string>
      <string id="bEnableAT_User">Assistive Technology</string>
      <string id="bEnableAT_User_Explain">Toggles assistive technology on and off.&#10;&#10;This preference enables certain workflows when assistive technology such as JAWS is detected. When enabled, a dialog appears in workflows where accessibility might be improved. For example, when processing untagged documents, the user is asked if they would like to use the setup assistant. When processing scanned images, a prompt asks if OCR should run. Possible values include: 0: Don't enable assistive technology. 1: Enable assistive technology.</string>
      <string id="bAttachLog_User">Attach Report</string>
      <string id="bAttachLog_User_Explain">Toggles whether to attach the accessibility report to the checked document after running accessibility full check.&#10;&#10;Possible values include: 0: Don't attach the report. 1: Do attach the report.</string>
      <string id="bAutoCompleteOnTab_User">Auto-Complete on Tab</string>
      <string id="bAutoCompleteOnTab_User_Explain">Specifies whether to auto complete form field entries on a tab key action.&#10;&#10;This option is enabled when the Advanced option is selected. Possible values include: 0: Don't auto complete on tab. 1: Auto complete on tab.</string>
      <string id="bautoOpenOther_User">Auto-Open Drawing Popup</string>
      <string id="bautoOpenOther_User_Explain">Automatically adds a popup note when another type of annotation is added.&#10;&#10;In other words, a popup note appears when you create a new comment using a drawing tool, the Stamp tool, or the Pencil tool. Possible values include: 0: Don't add a popup note for other annot types. 1: Do add a popup note for other annot types.</string>
      <string id="bAutoSaveDocsEnabled_User">Auto-Save</string>
      <string id="bAutoSaveDocsEnabled_User_Explain">Specifies whether or not to automatically save documents.&#10;&#10;Interacts with iAutoSaveDocsInterval. Possible values include: 0: Don't auto save documents 1: Auto save documents.</string>
      <string id="iAutoSaveDocsInterval_User">Auto-Save Interval</string>
      <string id="iAutoSaveDocsInterval_User_Explain">Specifies the time interval in minutes at which to automatically save docs.&#10;&#10;Interacts with bAutoSaveDocsEnabled. Possible values include: 5: Minutes User specified: Any value 1-99</string>
      <string id="bAutoSetLayers_User">Auto-Set Layers</string>
      <string id="bAutoSetLayers_User_Explain">Specifies whether to allow the document's layer state to be set by user information.&#10;&#10;Possible values include: 0: Don't allow layer state to be set by user information. 1: Allow layer state to be set by user information.</string>
      <string id="iAccessBackgroundColor_User">Background Color</string>
      <string id="iAccessBackgroundColor_User_Explain">Specifies the default document background color (accessibility feature)&#10;&#10;The key name is appended with (Blue|Green|Red|Space). Possible values include: Green text on black Yellow text on black White text on black Black text on white</string>
      <string id="iPages_User">Check Page Range</string>
      <string id="iPages_User_Explain">Toggles whether to check all pages of a document or a subset of pages when running an accessibility full check.&#10;&#10;Possible values include: 0: Don't check all pages. 1: Do check all pages.</string>
      <string id="benableDDR_User">ClearType Smoothing</string>
      <string id="benableDDR_User_Explain">Specifies whether to further smooth text on LCD screens.&#10;&#10;Text smoothing essentially has two levels. First, the text is anti-aliased. Then DDR technology is applied for devices which allow RGB bands to be painted in individual pixels to further smooth text (LCD screens). Possible values include: 0: None and Monitor 1: Laptop/LCD Screens.</string>
      <string id="iAccessColorPolicy_User">Color Replace Policy</string>
      <string id="iAccessColorPolicy_User_Explain">Specifies whether all the controls in the Replace Document Colors panel should be enabled.&#10;&#10;When disabled, this key is removed from the registry/plist. When this preference is selected, you can choose from a list of contrasting color combinations for text and background or create your own. Possible values include: null: User specified. 1: Use Windows Color Scheme 2: Use Custom Colors 4: Use High Contrast Colors</string>
      <string id="bCombineContent_User">Combine Reading Order</string>
      <string id="bCombineContent_User_Explain">Specifies whether similar content should be displayed together or separately.&#10;&#10;Possible values include: 0: Do display similar content types together. 1: Don't display similar content types together.</string>
      <string id="tauthor_User">Comment Author</string>
      <string id="tauthor_User_Explain">The author name specified by balwaysUseIdent.&#10;&#10;Possible values include: N/A: User specified.</string>
      <string id="dNoteFontSize_User">Comment Font Size</string>
      <string id="dNoteFontSize_User_Explain">Sets the font size.&#10;&#10;The font is not embedded in the PDF; this preference merely controls the viewer's preference rather than the author's preference. Possible values include: 10: Font size. N/A: User specified.</string>
      <string id="iNoteOpacity_User">Comment Opacity</string>
      <string id="iNoteOpacity_User_Explain">The opacity in percent of all comments.&#10;&#10;The number is entered in Hex. Possible values include: d99a: 85%. N/A: Any hex value representing 1-100%.</string>
      <string id="iSens_User">Compare Sensitivity</string>
      <string id="iSens_User_Explain">Last-used compare documents sensitivity (for compare pages).</string>
      <string id="iType_User">Compare Type</string>
      <string id="iType_User_Explain">Last-used compare documents type (pages/text/text+fonts).</string>
      <string id="bComplexScript_User">Complex Script Support</string>
      <string id="bComplexScript_User_Explain">Specifies whether to enable support for writing direction switching (complex script).&#10;&#10;Possible values include: 0: Don't enable Writing Direction Switching. 1: Enable Writing Direction Switching.</string>
      <string id="bconfirmEBRMerge_User">Confirm Review Import</string>
      <string id="bconfirmEBRMerge_User_Explain">Displays an alert on document open asking the user to confirm importing comments into an active review.&#10;&#10;Possible values include: 0: Disable confirmation alert on import. 1: Enable confirmation alert on import.</string>
      <string id="bcopyTextToDrawAnnot_User">Copy Text to Drawing</string>
      <string id="bcopyTextToDrawAnnot_User_Explain">Specifies whether to copy the encircled text into drawing comment popups.&#10;&#10;Adds a popup comment automatically to other markup types so that they can be annotated. Possible values include: 0: Don't copy the encircled text into comments. 1: Do copy the encircled text into comments.</string>
      <string id="bcopyTextToMarkupAnnot_User">Copy Text to Markup</string>
      <string id="bcopyTextToMarkupAnnot_User_Explain">Copies the selected text into highlight, cross-out, and underline comment popups.&#10;&#10;Adds a popup comment automatically to specified markup types so that they can be annotated. Possible values include: 0: Copy selected text. 1: Don't copy selected text.</string>
      <string id="bCreateLog_User">Create Report</string>
      <string id="bCreateLog_User_Explain">Toggles whether to create an accessibility report when running an accessibility full check.&#10;&#10;Possible values include: 0: Don't create report. 1: Do create report.</string>
      <string id="iDictionaryDefaultID_User">Default Dictionary</string>
      <string id="iDictionaryDefaultID_User_Explain">Identifies the default spelling dictionary ID.&#10;&#10;The value is an ID from cDictionaryOrderID\i0 . The dictionary name can be found in cDictionaryOrder\t0. Alternatively, set the value in the user interface, close the product, and look here again. Use the value that appears during deployment.</string>
      <string id="iPageViewLayoutMode_User">Default Page Layout</string>
      <string id="iPageViewLayoutMode_User_Explain">Specifies the default page layout when a PDF opens.&#10;&#10;These settings can be overridden by Accessiblity settings such as bOverridePageLayout. Possible values include: null: Automatic 1: Single Page 2: Single Page Continuous 3: Two Up Continuous 5: Two Up</string>
      <string id="iParaDir_User">Default Paragraph Dir</string>
      <string id="iParaDir_User_Explain">Specifies the paragraph direction.&#10;&#10;Possible values include: 0: Left to Right 1: Right to Left 2: Infer from document</string>
      <string id="iDefaultZoomScale_User">Default Zoom Scale</string>
      <string id="iDefaultZoomScale_User_Explain">Specifies the zoom scale % to use when a PDF opens.&#10;&#10;Possible values include a range beginning with Fit Page to Reflow . To set a value, configure the UI and look at the registry/plist preference to see what has been written. Possible values include: 199a: 10% 4000 25% 8000: 50% c000: 75% 10000: 100% etc.</string>
      <string id="iDefaultZoomType_User">Default Zoom Type</string>
      <string id="iDefaultZoomType_User_Explain">Specifies the default zoom type (other than a %) to use when a PDF opens.&#10;&#10;% scales are stored in iZoomScale. Possible values include: 1: Fit Page (automatic) 2: Fit Width 3: Fit Hieght 4: Fit Visible 6: Reflow</string>
      <string id="imaxPDFCommentsSize_User">Embedded Comment Limit</string>
      <string id="imaxPDFCommentsSize_User_Explain">Sets the comment threshold size for determining whether comments are embedded or sent as FDF files.&#10;&#10;When collaboration involves sending comments with a PDF, comments below the threshold size are embedded in the document. Comments above the threshold size are sent as FDF files. Possible values include: 3: Max size for Reader (Acrobat is 5)</string>
      <string id="bemptyContentToolTip_User">Empty Comment Tooltip</string>
      <string id="bemptyContentToolTip_User_Explain">Displays a tooltip stating the comment being hovered over is empty.&#10;&#10;Possible values include: 0: Don't indicate comment is empty. 1: Do indicate comment is empty.</string>
      <string id="bUseThinCode_User">Enhance Thin Lines</string>
      <string id="bUseThinCode_User_Explain">Specifies whether to enhance thin lines to improve visibility.&#10;&#10;Possible values include: 0: Don't enhance thin lines. 1: Enhance thin lines.</string>
      <string id="bSuperFastDrawing_User">Fast Scroll Drawing</string>
      <string id="bSuperFastDrawing_User_Explain">Specifies whether to use fast, low resolution intermediate representation during scrolling, zooming, etc.&#10;&#10;Superfast Drawing was introduced in Acrobat and Reader DC to make interactions with PDF documents smoother and more responsive. Superfast drawing suspends high quality rendering for the duration of operations like fast scrolling, panning, and zooming. This results in a lower quality intermediate representation being temporarily displayed during the current action. Possible values include: 0: Don't use Superfast Drawing and display high quality intermediates during scrolling, zooming, panning, etc. 1: Use Superfast Drawing to display low resolution intermediates during scrolling, zooming, panning, etc. GUI mapping None.</string>
      <string id="iaskFormsSelectEmailCLient_User">Form Email Prompt</string>
      <string id="iaskFormsSelectEmailCLient_User_Explain">Specifies whether the dialog confirming selection of desktop vs. internet email on XFA form submit appears.&#10;&#10;Possible values include: 0: Don't show the confirmation dialog on each XFA form submit. 1: Do show the confirmation dialog on each XFA form submit.</string>
      <string id="bHidePopupIfShowSummary_User">Hide Popup on Summary</string>
      <string id="bHidePopupIfShowSummary_User_Explain">Hide comment popups when comment's list is open.&#10;&#10;Possible values include: 0: Don't hide popups. 1: Do hide popups.</string>
      <string id="bHindiDigit_User">Hindi Digits</string>
      <string id="bHindiDigit_User_Explain">Specifies whether to enable support for Hindi digits.&#10;&#10;Possible values include: 0: Don't enable Hindi digits. 1: Enable Hindi digits.</string>
      <string id="bHoveringPopups_User">Hover Popups</string>
      <string id="bHoveringPopups_User_Explain">Automatically open popups on mouse rollover.&#10;&#10;Possible values include: 0: Don't open popups on mouse rollover. 1: Do open popups on mouse rollover.</string>
      <string id="bInlineAutoComplete_User">Inline Auto-Complete</string>
      <string id="bInlineAutoComplete_User_Explain">Specifies whether to auto complete a field based on remembered values when a user starts typing.&#10;&#10;This option is enabled for both the Basic and Advanced options. Possible values include: 0: Don't auto complete. 1: Do autocomplete.</string>
      <string id="iIntlSelectFont_User">International Font</string>
      <string id="iIntlSelectFont_User_Explain">Specifies the font to use.&#10;&#10;Possible values include: 0: Application default 1: GB18030 compatible font 2: HKSCS compatible font</string>
      <string id="bLigatures_User">Ligatures</string>
      <string id="bLigatures_User_Explain">Specifies whether to enable support for ligatures.&#10;&#10;Possible values include: 0: Don't enable ligatures. 1: Enable ligatures.</string>
      <string id="balwaysUseIdent_User">Login Name as Author</string>
      <string id="balwaysUseIdent_User_Explain">Uses the login names as the comment author name.&#10;&#10;The login name is the name specified in the identity preferences panel. If it is not present, the login-name is used. If it is not present for comments in collaborative documents (shared-review, browser-based review, email based review), the comment author identity is used that the user has set. For Acrobat, the default is true; for Reader, it is false. Possible values include: 0: Do use the login name as the comment author name. 1: Don't use the login name as the comment author name.</string>
      <string id="bOpenInPlace_User">Open Links in Place</string>
      <string id="bOpenInPlace_User_Explain">Specifies whether to open cross document links in the same window.&#10;&#10;Possible values include: 0: Don't open links in the same window. 1: Do open links in the same window.</string>
      <string id="bOverprintPreviewUseShiftClick_User">Overprint Shift+Click</string>
      <string id="bOverprintPreviewUseShiftClick_User_Explain">Specifies whether to use Shift + Click for multiple selection or for adding sticky notes containing color value when output preview dialog is open.&#10;&#10;Possible values include: 0: Use Shift + Click for adding a sticky note containing the color values. 1: To select multiple objects, use Shift + Click. To add a sticky note containing the color values, use Alt + Click (Windows) or Option + Click (Mac).</string>
      <string id="bAccessOverrideDocColors_User">Override Document Colors</string>
      <string id="bAccessOverrideDocColors_User_Explain">Specifies whether to replace black test or line art colors when iAccessColorPolicy is enabled and a replacement color has been specified.&#10;&#10;While the default is 1, the preference is not read unless iAccessPolicy is enabled (1). Possible values include: 0: Don't replace black text or line art colors. 1: Replace black text or line art colors.</string>
      <string id="bOverrideLineArtColors_User">Override Line Art Colors</string>
      <string id="bOverrideLineArtColors_User_Explain">Limits color changes to black text and line art when iAccessColorPolicy is enabled and a replacement color has been specified.&#10;&#10;While the default is 1, the preference is not read unless &quot;Accessibility&quot; enabled (1). Possible values include: 0: Don't replace text or line art colors. 1: Replace text or line art colors. See also bAccessOverrideDocColors in Originals.</string>
      <string id="iPageLayout_User">Override Page Layout</string>
      <string id="iPageLayout_User_Explain">Specifies the user selected page layout override.&#10;&#10;When bOverridePageLayout is set to 1, the override drop down list becomes enabled so that the user can set the desired page layout. Possible values include: 1: Single Page 2: Single Page Continuous 3: Two Up Continuous 5: Two Up</string>
      <string id="bOverrideZoom_User">Override Zoom</string>
      <string id="bOverrideZoom_User_Explain">Enables the zoom setting drop down list so that the user can specify a default zoom setting for all documents and overrides Page Display settings.&#10;&#10;PDF authors can specify what zoom level a PDF will open at. When enabled (1), the zoom drop down list becomes active so that the user can specify a default zoom level for all documents and set iZoomScale. Possible values include: 0: Use the documents default zoom setting. 1: Enable the zoom setting drop down list.</string>
      <string id="iZoomScale_User">Override Zoom Scale</string>
      <string id="iZoomScale_User_Explain">Specifies the value in % to zoom when iZoomType is set to a % value and overrides Page Display settings.&#10;&#10;Possible values include a range beginning with Fit Page to Reflow . When selected, % values are stored in iZoomScale. To set a value, configure the UI and look at the registry/plist preference to see what has been written. Possible values include: 199a: 10% 4000 25% 8000: 50% c000: 75% 10000: 100% etc.</string>
      <string id="iZoomType_User">Override Zoom Type</string>
      <string id="iZoomType_User_Explain">Specifies the zoom scale for all other documents other than a % scale and overrides Page Display settings.&#10;&#10;% scales are stored in iZoomScale. Possible values include: 1: Fit Page 2: Fit Width 3: Fit Hieght 4: Fit Visible 6: Reflow</string>
      <string id="iParagraphDirection_User">Paragraph Direction</string>
      <string id="iParagraphDirection_User_Explain">Specifies the paragraph direction.&#10;&#10;Possible values include: 0: Right to Left 1: Left to Right</string>
      <string id="bPopupsOpenIffSelected_User">Popup When Selected</string>
      <string id="bPopupsOpenIffSelected_User_Explain">Specifies whether to open a popup when it is selected.</string>
      <string id="bUseDetailsNavigator_User">Portfolio File List</string>
      <string id="bUseDetailsNavigator_User_Explain">Specifies whether to show portfolio component files and file details in an accessible list.&#10;&#10;This preference replaces bUsePlatformNavigator. Files mode provides a better reading experience for people with disabilities such as mobility impairments, blindness, and low vision. Possible values include: 0: Don't show portfolio components in a list. 1: Do show portfolio components in a list.</string>
      <string id="bPrintAnnots_User">Print Annotations</string>
      <string id="bPrintAnnots_User_Explain">Specifies whether to print notes, popups, and other annotations.&#10;&#10;Setting a similar preference from the Print panel sets a corresponding setting in HKU. Possible values include: 0: Don't print annotations. 1: Do print annotations.</string>
      <string id="bprintCommentPopups_User">Print Comment Popups</string>
      <string id="bprintCommentPopups_User_Explain">Enables printing of comments and other annotations.&#10;&#10;Notes and popups that are open will be printed when the rest of the document is printed. Possible values include: 0: Don't print comments. 1: Do print comments.</string>
      <string id="bprintNotesOpaque_User">Print Popups Opaque</string>
      <string id="bprintNotesOpaque_User_Explain">Makes popups opaque regardless of other settings.&#10;&#10;Prints the popups as opaque without honoring the popup opacity specified by the user in commenting preferences (popup-opacity). Possible values include: 0: Don't make popups opaque. 1: Do make popups opaque.</string>
      <string id="bUserAskedToEnableAutoComplete_User">Prompt Auto-Complete</string>
      <string id="bUserAskedToEnableAutoComplete_User_Explain">Specifies whether the user is asked to enable auto complete at runtime.&#10;&#10;This option is enabled for the Advanced option. Possible values include: 0: Don't ask the user. 1: Do ask the user.</string>
      <string id="iShowOrder_User">Reading Order Display</string>
      <string id="iShowOrder_User_Explain">Specifies the type of grouping order to display in the touchup reading order panel.&#10;&#10;Possible values include: 0: Order (numbered). 1: Structure type. 2: None.</string>
      <string id="bRecordNewEntries_User">Remember Form Entries</string>
      <string id="bRecordNewEntries_User_Explain">Specifies whether to remember form field entries for use with future auto-complete actions.&#10;&#10;This option is enabled for both the Basic and Advanced options. Possible values include: 0: Don't remember entries. 1: Do remember entries.</string>
      <string id="iRememberView_User">Restore Last View</string>
      <string id="iRememberView_User_Explain">Specifies whether to restore last view settings when reopening documents.&#10;&#10;Possible values include: 1: Don't restore the last view settings. 2: Do restore the last view settings.</string>
      <string id="bRTLUI_User">Right-to-Left UI</string>
      <string id="bRTLUI_User_Explain">Specifies whether to enable right to left language options.&#10;&#10;Possible values include: 0: Disable right to left language options. 1: Enable right to left language options.</string>
      <string id="bDigitsUI_User">RTL Digit Display</string>
      <string id="bDigitsUI_User_Explain">Specifies whether to display digits in a way that's consistent with right to left language display.&#10;&#10;The value is automatically set when bRTLUI is set via the UI. Possible values include: 0: Don't display digits in a way that's consistent with right to left language display. 1: Do display digits in a way that's consistent with right to left language display.</string>
      <string id="bPrintSaveToner_User">Save Toner/Ink</string>
      <string id="bPrintSaveToner_User_Explain">Specifies whether to optimize content so that the printer uses less ink.&#10;&#10;When checked, this setting optimizes the content so that the printer uses less ink during printing. In some cases, toner savings may reach 15%. Print quality is usually not impaired in any discernable way. Possible values include: 0: Don't optimize printing. 1: Optimize printing.</string>
      <string id="bSDIMode_User">SDI Mode</string>
      <string id="bSDIMode_User_Explain">Specifies whether to open documents in a new window or in tabs in the same window.&#10;&#10;Possible values include: 0: Open documents in tabs in the same window . 1: Open documents in separate windows.</string>
      <string id="bsendFinalApprovalEmail_User">Send Approval Email</string>
      <string id="bsendFinalApprovalEmail_User_Explain">Specifies whether to send a notification email when the current approval is identified as the final one.&#10;&#10;Only valid for an approval workflow. Possible values include: 0: Don't send an email on final approval. 1: Do send an email on final approval.</string>
      <string id="bShowOptionsDialog_User">Show Check Options</string>
      <string id="bShowOptionsDialog_User_Explain">Toggles whether to display the options dialog when running a accessibility full check.&#10;&#10;Possible values include: 0: Don't show options dialog. 1: Show options dialog.</string>
      <string id="bcommentPanelOnImport_User">Show Comments on Import</string>
      <string id="bcommentPanelOnImport_User_Explain">Specifies whether to open the comment list when comments are imported.&#10;&#10;Possible values include: 0: Don't open the comment list when comments are imported. 1: Do open the comment list when comments are imported.</string>
      <string id="bShowAnnotConnector_User">Show Connector Lines</string>
      <string id="bShowAnnotConnector_User_Explain">Specifies whether to show lines connecting comment markups to their popups on mouse rollover.&#10;&#10;Possible values include: 0: Hide lines connecting comments to popups. 1: Show lines connecting comments to popups.</string>
      <string id="bFocusRect_User">Show Focus Rectangle</string>
      <string id="bFocusRect_User_Explain">Specifies whether to surround a field with a rectangle when it has focus.&#10;&#10;Possible values include: 0: Don't show a rectangle. 1: Do show a rectangle.</string>
      <string id="bShowKeyboardSelectionCursor_User">Show Keyboard Cursor</string>
      <string id="bShowKeyboardSelectionCursor_User_Explain">Specifies whether the keyboard selection cursor should always be active in the document.&#10;&#10;Select this option if you use a screen magnifier. Possible values include: 0: Don't show the cursor. 1: Always show the cursor.</string>
      <string id="bshowMarkupModifiers_User">Show Markup Indicators</string>
      <string id="bshowMarkupModifiers_User_Explain">Specifies whether to show markup tool-tips and text indicators.&#10;&#10;Possible values include: 0: Don't show markup tool-tips and text indicators. 1: Show markup tool-tips and text indicators.</string>
      <string id="bStampsPaletteInvisible_User">Show Stamps Palette</string>
      <string id="bStampsPaletteInvisible_User_Explain">Specifies whether to show the stamps palette automatically when the commenting toolbar is displayed.&#10;&#10;Possible values include: 0: Show the palette. 1: Don't show the palette.</string>
      <string id="bShowAnnotSequence_User">Show Tab Order</string>
      <string id="bShowAnnotSequence_User_Explain">Specifies whether to show tab order of fields for Acroforms and XFA forms.</string>
      <string id="bsideNotes_User">Side-Aligned Popups</string>
      <string id="bsideNotes_User_Explain">Creates new popups aligned to the edge of the document.&#10;&#10;Controls popup positioning. Possible values include: 0: Don't align popups at the document edge. 1: Align popups at the document edge.</string>
      <string id="bAntialiasImages_User">Smooth Images</string>
      <string id="bAntialiasImages_User_Explain">Specifies wither to use anti-aliasing (smoothing) for images.&#10;&#10;Turning this preference off can improve scrolling performance in Citrix environments. Possible values include: 0: Don't smooth images. 1: Smooth images.</string>
      <string id="bAntialiasGraphics_User">Smooth Line Art</string>
      <string id="bAntialiasGraphics_User_Explain">Specifies wither to use anti-aliasing (smoothing) for line art.&#10;&#10;Turning this preference off can improve scrolling performance in Citrix environments. Possible values include: 0: Don't smooth line art. 1: Smooth line art.</string>
      <string id="bAntialiasText_User">Smooth Text</string>
      <string id="bAntialiasText_User_Explain">Specifies whether to smooth (anti-alias) text.&#10;&#10;This setting only applies when the Smooth Text field is set to Monitor or Laptop/LCD. Text smoothing essentially has two levels. First, the text is anti-aliased. Then, if benableDDR is set to 1, DDR technology is applied for devices which allow RGB bands to be painted in individual pixels to further smooth text. Possible values include: 0: None. 1: For both monitor and laptop/LCD Screens.</string>
      <string id="bSmoothZooming_User">Smooth Zooming</string>
      <string id="bSmoothZooming_User_Explain">Specifies whether smooth zooming should be enabled.&#10;&#10;Possible values include: 0: Disables smooth zooming 1: Enables smooth zooming</string>
      <string id="bSpellingUnderline_User">Spell Check Underline</string>
      <string id="bSpellingUnderline_User_Explain">Turns off and on spell checking as you type.&#10;&#10;This key is also duplicated under cPICommonPrefs\cSpelling.</string>
      <string id="bStoreNumericEntries_User">Store Numeric Entries</string>
      <string id="bStoreNumericEntries_User_Explain">Specifies whether to store user entered numeric values.&#10;&#10;This option is enabled for both the Basic and Advanced options. Possible values include: 0: Don't store numeric entries. 1: Do store numeric entries.</string>
      <string id="bUseStructTabOrder_User">Structure Tab Order</string>
      <string id="bUseStructTabOrder_User_Explain">Specifies whether to use the PDF document structure for determining the tab order.&#10;&#10;Possible values include: 0: Don't use document structure. 1: Use document structure.</string>
      <string id="bUseSystemSelectionColor_User">System Selection Color</string>
      <string id="bUseSystemSelectionColor_User_Explain">Specifies whether the default selection color (blue) is overridden with a color that the system specifies.&#10;&#10;Possible values include: 0: Don't use the system selection color. 1: Use the system selection color.</string>
      <string id="iAccessTextColor_User">Text Color</string>
      <string id="iAccessTextColor_User_Explain">Specifies the default document text color (accessibility feature)&#10;&#10;The key name is appended with (Blue|Green|Red|Space). Possible values include: null: not set Any RGB color: User specified.</string>
      <string id="bUseLocalFonts_User">Use Local Fonts</string>
      <string id="bUseLocalFonts_User_Explain">Specifies whether to use local fonts.&#10;&#10;Possible values include: 0: Don't use local fonts. 1: Do use local fonts.</string>
      <string id="iEmailClientSelection_User">XFA Email Client</string>
      <string id="iEmailClientSelection_User_Explain">Specifies the email client to use when submitting an XFA form.&#10;&#10;Adobe's preference reference does not describe this value; use the URL column for the documentation link.</string>
      <string id="iRXOPolicy_User">XObjects View Mode</string>
      <string id="iRXOPolicy_User_Explain">Sets XObject access to either Never (0), Always (1), or Only PDF/X-5 Compliant Ones (2).&#10;&#10;The user must also set cRXOLocation and (Windows only) specify a privileged location for each parent (referencing) document. Possible values include: 0: Never 1: Always 2: Only PDF/X-5 Compliant Ones</string>

      <!-- ======================================== -->
      <!--         Microsoft Purview (MIP)          -->
      <!-- ======================================== -->

      <string id="bEnableLogging_User">MIP Logging</string>
      <string id="bEnableLogging_User_Explain">Specifies whether to enable debug logging for Microsoft Purview Information Protection operations.&#10;&#10;Useful for troubleshooting MIP label and authentication issues. Possible values include: 0: Disable MIP debug logging. 1: Enable MIP debug logging.</string>
      <string id="bEnablePolicyAuthentication_User">MIP Policy Authentication</string>
      <string id="bEnablePolicyAuthentication_User_Explain">Specifies whether MIP policy authentication is enabled for the current user.&#10;&#10;Used alongside bShowDMB. Setting both bShowDMB and bEnablePolicyAuthentication to 0 hides the applied label from the current file. Possible values include: 0: Disable MIP policy authentication. 1: Enable MIP policy authentication.</string>
      <string id="bShowDMB_User">Show Document Message Bar (MIP)</string>
      <string id="bShowDMB_User_Explain">Specifies whether to show Microsoft Purview Information Protection label information in the document message bar.&#10;&#10;Per-user preference under MicrosoftAIP. Possible values include: 0: Do not show MIP label info in the document message bar. 1: Show MIP label info in the document message bar.</string>

      <!-- ======================================== -->
      <!--    Security: Execution and Protection    -->
      <!-- ======================================== -->

      <string id="b3DEnableContent_User">3D Content Trust</string>
      <string id="b3DEnableContent_User_Explain">Specifies whether to trust and render 3D content.&#10;&#10;This setting can be overridden by bEnable3D . Possible values include: 0: Don't trust and render 3D content. Show the Yellow Message Bar so the end user can trust the document. 1: Trust and render 3D files.</string>
      <string id="bCrossDomainLogging_User">Cross-Domain Logging</string>
      <string id="bCrossDomainLogging_User_Explain">Enables cross domain logging for communication with a server that uses a cross domain policy file to manage the flow of data that does not conform to a same-origin policy.&#10;&#10;Create a logging file by navigating to the user account Application Directory. For example, on XP go to C:\Documents and Settings\(user name)\Application Data\Adobe\(application)\(version)\. Created an empty file called AcrobatCrossDomain.log.</string>
      <string id="bEnableDebugger_User">Enable JS Debugger</string>
      <string id="bEnableDebugger_User_Explain">Enables the debugger.&#10;&#10;Requires an application restart.</string>
      <string id="bFIPSMode_User">FIPS Mode</string>
      <string id="bFIPSMode_User_Explain">Turns FIPS mode on and off thereby requiring stronger encryption algorithm and limiting certain application behavior.&#10;&#10;Security Reference: STIG ARDC-CN-000345 (V-213193) Medium; STIG AADC-CN-000955 (V-245874) Medium</string>
      <string id="bEnableGlobalSecurity_User">JS Global Security</string>
      <string id="bEnableGlobalSecurity_User_Explain">Controls whether or not a script in one sandbox can access a script object in another sandbox.&#10;&#10;By default, scripts can not access objects outside the current document sandbox. With 9.x and later, such communication only works in the standalone application since both the Acrobat and Reader browser-based viewer opens each window in a discrete browser instance.</string>
      <string id="bEnableMenuItems_User">JS Menu Items</string>
      <string id="bEnableMenuItems_User_Explain">Toggles off and on JavaScript's ability to execute menu items.</string>
      <string id="bEnableAlwaysOutlookAttachmentProtectedView_User">Outlook Protected View</string>
      <string id="bEnableAlwaysOutlookAttachmentProtectedView_User_Explain">Specifies whether Protected View is turned off for Outlook attachments.&#10;&#10;Note that earlier versions (e.g. Office 2003 and 2007) do not append origin information to files they download to its temp directory. As a result, there is no way of knowing if the file came from trusted source. Such files do not automatically open in PV. Possible values include: 0: Enable Protected View for Outlook attachments. 1: Disable Protected View for Outlook attachments.</string>
      <string id="bOldRecentFilesMigrated_User">Recent Files Migrated</string>
      <string id="bOldRecentFilesMigrated_User_Explain">Indicates whether the recent files list has been migrated.&#10;&#10;Admins should not change the preference value.</string>

      <!-- ======================================== -->
      <!--     Security: Trust and Permissions      -->
      <!-- ======================================== -->

      <string id="bUseExpiredTimestamps_User">Accept Expired Timestamps</string>
      <string id="bUseExpiredTimestamps_User_Explain">Specifies whether expired timestamps should be used.&#10;&#10;If true, an expired timestamp will not invalidate a signature.</string>
      <string id="bAllowConnectViaHTTP_User">Allow LiveCycle HTTP</string>
      <string id="bAllowConnectViaHTTP_User_Explain">If true, the server connection URI uses the format http://server:port/path; otherwise, it uses the format https://server:port/path.&#10;&#10;In either case, if the connection fails, an error message appears. For more information, see Guidelines for Developing CSPs for Acrobat on Windows .</string>
      <string id="bAllowCertNonGreen_User">Allow Non-Green Cert</string>
      <string id="bAllowCertNonGreen_User_Explain">Specifies whether a certification signature may be applied to a document containing Legal PDF warnings.&#10;&#10;If false, then its not allowed and the author is informed of the reason.</string>
      <string id="bAllowOCSPNoCheck_User">Allow OCSP NoCheck</string>
      <string id="bAllowOCSPNoCheck_User_Explain">Specifies whether the OCSPNoCheck extension is allowed in the response signing certificate.</string>
      <string id="bAlwaysConsult_User">Always Consult CDP</string>
      <string id="bAlwaysConsult_User_Explain">Determines when the URL is used for an additional URL CRL distribution point.&#10;&#10;If false, the URL is only used when the certificate does not have a CRLDp extension.</string>
      <string id="iAuthMechanisms_User">Auth Mechanisms</string>
      <string id="iAuthMechanisms_User_Explain">Specifies which registered provider(s) to use.&#10;&#10;0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
      <string id="iAutoAcceptEDCPrivacyNotification_User">Auto-Accept Privacy</string>
      <string id="iAutoAcceptEDCPrivacyNotification_User_Explain">Specifies whether to show an alert confirming acceptance of the privacy policy.&#10;&#10;Possible values include: 0: Don't show an alert. 1: Do show an alert.</string>
      <string id="iAutoAddLTV_User">Auto-Add LTV Info</string>
      <string id="iAutoAddLTV_User_Explain">Specifies whether LTV information should be automatically added to all signatures.&#10;&#10;Possible values include: 0: Never add LTV information. 1: (default) Ask whether LTV information should be added if it is too big. 2: Always add LTV information. When the cumulative size of the LTV data is greater than the sum of 10% of the PDF file size plus 10KB and Automatically add verification information on Save is set to &quot;Ask...&quot; a dialog appears asking the user if they would like to continue embedding the LTV information. Note that in workflows where the dialog appears asking whether to enable LTV, if the user selects the &quot;Do not show this message again&quot; checkbox, AND click the No button, then this preference is set to zero.</string>
      <string id="bSavePassword_User">Cache Server Password</string>
      <string id="bSavePassword_User_Explain">Indicates whether the password has been cached for this server.</string>
      <string id="iSHS_User">Console H-Splitter</string>
      <string id="iSHS_User_Explain">Indicates (in pixels) the position of the horizontal window splitter.</string>
      <string id="iSVS_User">Console V-Splitter</string>
      <string id="iSVS_User_Explain">Indicates (in pixels) the position of the vertical window splitter.</string>
      <string id="iMaxRevokeInfoCacheLifetime_User">CRL Cache Lifetime</string>
      <string id="iMaxRevokeInfoCacheLifetime_User_Explain">Maximum lifetime in hours the cached CRL is used for revocation checking.&#10;&#10;iMaxRevokeInfoCacheLifetime is only used if the validation method is set to &quot;current time&quot;. Possible values include: The number of hours for which the cached CRL is valid.</string>
      <string id="bCustomPrefsCreated_User">Custom Cert Prefs</string>
      <string id="bCustomPrefsCreated_User_Explain">Indicates whether a custom certificate specific preference (e.g. Identrus) has already been created and written to the registry.&#10;&#10;If true, it doesn't get created again. Deleting or setting this key to 0 forces Acrobat to recreate custom certificate preferences after which it will reset this key to 1.</string>
      <string id="iDirectoryProvider_User">Directory Provider</string>
      <string id="iDirectoryProvider_User_Explain">Specifies a directory provider for signature validation.&#10;&#10;0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
      <string id="bEnforceSecureChannel_User">Enforce Digest Compare</string>
      <string id="bEnforceSecureChannel_User_Explain">Specifies whether to prevent signing when the original message digest and the signed message digest do not match.&#10;&#10;When set to 1, the user sees a warning dialog when the digest mismatch occurs. This error can be caused by a modification of the original message digest, a modification of the signed message digest, or a mismatch between the private and public key used for signing. When using a certificate that doesn't include a public key (such as a DSA certificate with an omitted public key), the test to detect signature validity is not performed. Do not turn this setting on if such certificates are used.</string>
      <string id="bAutoLaunchAtDocClose_User">Examine on Close</string>
      <string id="bAutoLaunchAtDocClose_User_Explain">Automatically examines the document for hidden content when it is closed.</string>
      <string id="bAutoLaunchAtSendMail_User">Examine on Send</string>
      <string id="bAutoLaunchAtSendMail_User_Explain">Automatically examines the document for hidden content when it is sent in an email.</string>
      <string id="bExpiredCertGoOnline_User">Expired Cert Go Online</string>
      <string id="bExpiredCertGoOnline_User_Explain">Specifies whether to go online to get the revocation information for an expired certificate.&#10;&#10;11.0.16 introduced a signature validation change so that signatures are invalid if they are based on expired certificates and there is no embedded revocation information even if bIgnoreValidityDates is 1. For previous product versions, the signature would be valid. Now, to be standard's compliant, if a certificate has expired, the client should not check for the revocation information online. bExpiredCertGoOnline set to 1 re-enables the pre-11.0.16 behavior. 0: Do not go online for revocation even if bIgnoreValidityDates = 1 1: Do go online.</string>
      <string id="bFDFRequestExcludeCert_User">FDF Exclude Cert</string>
      <string id="bFDFRequestExcludeCert_User_Explain">Similar to the bFDFRequestSave.&#10;&#10;False includes the user's certificate in all certificate requests. True excludes it.</string>
      <string id="bFDFExportSave_User">FDF Export Save</string>
      <string id="bFDFExportSave_User_Explain">Persists whether user chose to save (1) or email (0) the FDF during export.</string>
      <string id="bFDFExportSign_User">FDF Export Sign</string>
      <string id="bFDFExportSign_User_Explain">Persists whether the user chose to sign the FDF during export.</string>
      <string id="bFDFRequestSave_User">FDF Request Save</string>
      <string id="bFDFRequestSave_User_Explain">Caches a user's answer to the question whether they want to save the request as an FDF or email it directly when that user requests a certificate.</string>
      <string id="bFollowURIsFromAIA_User">Follow AIA URIs</string>
      <string id="bFollowURIsFromAIA_User_Explain">Specifies whether to allow the chain builder to follow URIs in AIA certificate extensions so that certificates can be downloaded if they are not available locally.&#10;&#10;The default does not allow phone-home capability. CRLdps and OCSP AIA extensions do allow following URIs because they require that the certificate chain up to a trust anchor.</string>
      <string id="bSigAPStatusIconDisable_User">Hide Sig Status Icon</string>
      <string id="bSigAPStatusIconDisable_User_Explain">Controls whether the signature status icon is displayed in the signature appearance on the document.&#10;&#10;If true, status icon is not displayed regardless of signature status. This setting overrides iDisplayValidIcon and bShowWarningForChanges.</string>
      <string id="cDialogs_xSelHandler_User">ID Dialog Position</string>
      <string id="cDialogs_xSelHandler_User_Explain">The last on-screen coordinates of a handler's digital ID selection dialog&#10;&#10;It is a subkey containing 4 keys: Top, Bottom, Left, and Right. This preference could be used by 3rd party handlers or by someone invoking a non-signing digital ID selection dialog via JavaScript.</string>
      <string id="bIgnoreNextUpdate_User">Ignore OCSP NextUpdate</string>
      <string id="bIgnoreNextUpdate_User_Explain">Specifies whether to use embedded OCSP responses when nextUpdate is not present and the validation time is less than the greater of thisUpdate or producedAt time plus the value of iMaxClockSkew .&#10;&#10;For 10.1 and later, this preference is used along with iMaxClockSkew to determine whether or not embedded OCSP responses are actually used for signature validation. For details, see the subfeature description above. This behavior is designed to support Acrobat's long term validation feature and allows validating a signature with embedded responses that were valid at signing time. Possible values include: 0: iMaxClockSkew is applied to thisUpdate on both sides of the validation time, i.e. thisUpdate - iMaxClockSkew ( validation time ( checkTime + iMaxClockSkew where checkTime is the later of the producedAt and thisUpdate. When true, iMaxClockSkew is applied to thisUpdate only before the validation time: thisUpdate - iMaxClockSkew ( validation time. 1: If there is no nextUpdate, then we accept the OCSP response indefinitely (we do not check for if the validation time is too late) and don't check whether validation time is ( than checkTime)</string>
      <string id="iImportAddressBook_User">Import Address Book</string>
      <string id="iImportAddressBook_User_Explain">Specifies whether the addressbook.acrodata file should be imported during a new install.&#10;&#10;Many admins set a value of 2 so that the import dialog does not appear for end users. Possible values include: 0: Do not copy the old address book. The user is NOT prompted and the address book should NOT be installed. 1 or null: Default: The user is asked whether the address book should either be installed or not. 2: Import the address book silently.</string>
      <string id="bCertStoreImportEnable_User">Import Windows Certs</string>
      <string id="bCertStoreImportEnable_User_Explain">If true, then users can import from MSCAPI certificate stores into their Trusted Identity Manager.</string>
      <string id="iAPIndex_User">Last Sig Appearance</string>
      <string id="iAPIndex_User_Explain">Remembers the last used signature appearance index.</string>
      <string id="bIsEnabled_User">Long Term Validation</string>
      <string id="bIsEnabled_User_Explain">Specifies whether the signature revocation status is included in the signature.&#10;&#10;Possible values include: 0: Don't enable LTV and include the signature revocation status information in the signature. 1: Enable LTV.</string>
      <string id="iMaxRevInfoArchiveSize_User">Max Rev Info Archive</string>
      <string id="iMaxRevInfoArchiveSize_User_Explain">The maximum size of the revocation archival information in kilobytes.&#10;&#10;An attempt is made to store as much revocation information as possible without exceeding the limit. Note that older product versions may have a smaller supported size limit.</string>
      <string id="iMaxVerifySession_User">Max Verify Sessions</string>
      <string id="iMaxVerifySession_User_Explain">Specifies the maximum number of nested verification sessions allowed.&#10;&#10;This is used to prevent the application from going into infinite loop verifying the OCSP and/or CRL signer certificates caused by incorrect OCSP and/or CRL certificate setup.</string>
      <string id="iCreateNewSigFieldAVAlert_User">New Sig Field Alert</string>
      <string id="iCreateNewSigFieldAVAlert_User_Explain">Specifies whether to show the alert asking whether a new signature field should be created.&#10;&#10;Possible values include: 0: Don't show an alert. 1: Do show an alert.</string>
      <string id="bEnNonEmbFontLegPDFWarn_User">Non-Embedded Font Warn</string>
      <string id="bEnNonEmbFontLegPDFWarn_User_Explain">Turns on and off warnings about non-embedded fonts.&#10;&#10;A warning appears when the LegalPDF dictionary NonEmbeddedFonts attribute has a non zero value. Turning this value on causes a warning to appear in the PDF Signature Report which indicates the document contains unembedded fonts.</string>
      <string id="iSendNonce_User">OCSP Nonce Behavior</string>
      <string id="iSendNonce_User_Explain">Specifies signature validation behavior with respect to nonces.&#10;&#10;With 10.0, this preference replaces bSendNonce. Possible values include: 0: No nonces are sent. 1: Nonces are included in the OCSP request and expected to be present in the response and should match the request's nonce. 2: Nonces are included in the OCSP request, but if none are present in the response, their abscence is ignored.</string>
      <string id="iURLToConsult_User">OCSP Responder URL</string>
      <string id="iURLToConsult_User_Explain">Specifies how the revocation checker chooses which responder to use.&#10;&#10;Possible values include: 0: Use the AIA extension in the certificate. 1: Use the URL key in sURL. 2: Use the AIA extension in the certificate. If it is not present, use the URL key in sURL. 3: Use the OCSP request signer's certificate AIA extension. Relevant only if SignRequest is 0.</string>
      <string id="iResponseFreshness_User">OCSP Response Freshness</string>
      <string id="iResponseFreshness_User_Explain">Specifies the amount of time in minutes after the response's published thisUpdate time for which the response will be valid.&#10;&#10;After that time, the response will be invalid.</string>
      <string id="bAllowOpenFile_User">Open Non-PDF Attachments</string>
      <string id="bAllowOpenFile_User_Explain">Specifies whether to open non-PDF attachments in their native application.&#10;&#10;bAllowOpenFile, bSecureOpenFile, and tBuiltInPermsList work in tandem: If any of these are set to prevent the opening of an attachment, then the attachment type won't open (or all attachments depending on the setting). Possible values include: 0: Prevent attachments from opening in their native application. 1: Allow attachments to open in their native application.</string>
      <string id="bPreviewModeBeforeSigning_User">Preview Before Signing</string>
      <string id="bPreviewModeBeforeSigning_User_Explain">Specifies whether a signer is forced to use preview mode during signing.&#10;&#10;If true, preview mode is automatically invoked on a sign action. Users should read the document message bar text, view a report about any warnings, and then choose Sign Document.</string>
      <string id="bRequireAKI_User">Require AKI in CRL</string>
      <string id="bRequireAKI_User_Explain">Specifies whether the Authority Key Identifier extension must be present in a CRL.</string>
      <string id="bRequireOCSPCertHash_User">Require OCSP Cert Hash</string>
      <string id="bRequireOCSPCertHash_User_Explain">Specifies whether a certificate public key hash extension must be present in OCSP responses.</string>
      <string id="iRequireReviewWarnings_User">Require Sign Warnings</string>
      <string id="iRequireReviewWarnings_User_Explain">Specifies whether the user is required to review document warnings before signing via the signing dialog.&#10;&#10;Interacts with iShowDocumentWarnings. The possible values include: 0: Never 1: Show when certifying only 2: Always</string>
      <string id="bReqSigPropRetrieval_User">Require Timestamp</string>
      <string id="bReqSigPropRetrieval_User_Explain">Indicates whether retrieving a signature property must succeed.&#10;&#10;Acrobat currently provides a signature property for timestamps. By default, retrieving a valid and trusted timestamp is not required, and property retrieval failure only results in creating a signature which uses the local time. When property retrieval is required during signature creation and fetching a timestamp fails for any reason (bad URL, no network connection, etc.) the signature creation process is aborted, no signature is created, and an error appears. 0: Make best effort, but success is not required. A signature is created. 1: Property retrieval must succeed. On failure, a signature is not created and an error dialog appears.</string>
      <string id="bRequireValidSigForChaining_User">Require Valid Sig Chain</string>
      <string id="bRequireValidSigForChaining_User_Explain">Specifies whether to allow the chain builder to build chains with invalid RSA signatures on certificates.&#10;&#10;Consider chain CA ) ICA ) EE where the CA's signature on an ICA is invalid. If this setting is true, the chain building will stop at the ICA and the CA will not be included in the chain. If this preference is false, the full 3-certificate chain is produced. This setting does not affect DSA signatures.</string>
      <string id="bReturnRevInfoToUser_User">Return Rev Info to JS</string>
      <string id="bReturnRevInfoToUser_User_Explain">If true, the revocation information is maintained within the SignatureInfo object and can be retrieved through JavaScript.&#10;&#10;For more information, see the Acrobat JavaScript Reference .</string>
      <string id="iRevocationChecker_User">Revocation Checker</string>
      <string id="iRevocationChecker_User_Explain">Specifies a provider for revocation checking.&#10;&#10;0: Use none of the registered providers. 1: Use first registered provider. 2: Use all registered providers.</string>
      <string id="bRevCheckTrust_User">Revoke Check Trust</string>
      <string id="bRevCheckTrust_User_Explain">Specifies whether to perform revocation checks on intermediate trust anchors (those which aren't roots).&#10;&#10;In previous versions, the application did not perform revocation checks on any intermediate trust anchors since it was assumed they were self-signed. With 10.1.2 and 9.5, this setting enables revocation checking on intermediate trust anchors if such information is available. Trust anchors from 3rd parties are often installed locally to facilitate signature validation. Since it is possible that the trust anchors could become compromised and thereby open the host machine to malicious attack, those 3rd party providers in such cases would revoke their certificates. This preference enables detecting that revocation by forcing a revocation check on any intermediate trust anchors. Root and self-signed certificates are exempt from checking. Possible values include: 0: Don't perform a revocation check on intermediate trust anchors. 1: Perform a revocation check on intermediate trust anchors.</string>
      <string id="iRSAPSSSaltLength_User">RSA-PSS Salt Length</string>
      <string id="iRSAPSSSaltLength_User_Explain">Specifies the Salt Length the RSA-PSS algorithm uses.&#10;&#10;When setting the salt length, you must assure the default base is hexadecimal. Either change the base to decimal or input its hex value. For example, if the salt length decimal value is 32, then set the hex value to 20.</string>
      <string id="bEnableRSAPSSSigning_User">RSA-PSS Signing</string>
      <string id="bEnableRSAPSSSigning_User_Explain">Specifies whether a signature should be created with the RSA-PSS algorithm.&#10;&#10;Possible values include: 0: Do not sign with the RSA-PSS algorithm. 1: Use the RSA-PSS algorithm.</string>
      <string id="iDigSigSaveAsCertified_User">Save Certified Alert</string>
      <string id="iDigSigSaveAsCertified_User_Explain">&#10;&#10;Possible values include: 0: Don't show an alert. 1: Do show an alert.</string>
      <string id="bSecureOpenFile_User">Secure Open Attachments</string>
      <string id="bSecureOpenFile_User_Explain">Specifies whether to allow opening attachments which are not PDF.&#10;&#10;When this pref is set to true, then Acrobat only allows opening PDF attachments. bAllowOpenFile, bSecureOpenFile, and tBuiltInPermsList work in tandem: If any of these are set to prevent the opening of an attachment, then the attachment type won't open (or all attachments depending on the setting). Possible values include: 0: Allow opening attachments with filetype other than PDF. 1: Don't open non-PDF attachments.</string>
      <string id="bSelfSignCertGen_User">Self-Sign ID Create</string>
      <string id="bSelfSignCertGen_User_Explain">Specifies whether or not the Create a self-signed ID option in Add ID workflows is available.&#10;&#10;Prevents users from creating a self-signed digital ID. Note that for products released after June 2016, disabling a user's ability to create a self-signed digital ID requires setting both bSelfSignCertGen and bEnableCEFBasedUI to 0. Possible values include: 0: Don't allow creating self-signed digital IDs. 1: Allow self-signed digital IDs.</string>
      <string id="bShowAllChains_User">Show All Chains</string>
      <string id="bShowAllChains_User_Explain">Specifies whether to show all chains in the Certificate Viewer.&#10;&#10;If true, the Certificate Viewer shows all the chains; otherwise, it shows only the trusted chain. If there are no trusted chains, then all the chains are shown and this preference is ignored.</string>
      <string id="iShowDocumentWarnings_User">Show Document Warnings</string>
      <string id="iShowDocumentWarnings_User_Explain">Specifies whether a button to allow reviewing document warnings shows up on the signing dialog.&#10;&#10;Interacts with iRequireDocumentWarnings. The possible values include: 0: Never 1: Show when certifying only 2: Always</string>
      <string id="bShowWarningForChanges_User">Show Post-Sign Warning</string>
      <string id="bShowWarningForChanges_User_Explain">Determines whether or not to show a blue i on validated signature(s) if the document changes after it was signed.&#10;&#10;If true, a document change results in a blue i status icon appearing for validated approval signatures. Use this setting when users need to know a document has changed after it was signed. If false, the status icon remains a green check and pen even if a document changes after it is signed. The setting provides a method for administrators to turn off the blue i in workflows where documents can be changed or signed multiple times. This setting does not affect certification signatures. The warning icon never appears for valid certification or approval signatures in certified documents if the signatures were allowed by the certifier. Interacts with iDisplayValidIcon which cannot be set to 2, or the icons will not appear regardless of how bShowWarningForChanges is set.</string>
      <string id="bAllowOtherInfoWhenSigning_User">Show Sign Contact Info</string>
      <string id="bAllowOtherInfoWhenSigning_User_Explain">Specifies whether the location and contact information UI will appear during signing.</string>
      <string id="bShowSignerWarnings_User">Show Signer Warnings</string>
      <string id="bShowSignerWarnings_User_Explain">Specifies whether to show a warning that there is a greater forgery risk when revocation information is embedded in the signature.&#10;&#10;Because this warning was removed from 10.x products, this preference is only applicable to 9.4.6 and later products in the 9.x line. Possible values include: 0: Don't show the warnings. 1: Do show the warnings.</string>
      <string id="iDisplayValidIcon_User">Show Valid Sig Icon</string>
      <string id="iDisplayValidIcon_User_Explain">Determines when the signature status icon is displayed in a signature appearance.&#10;&#10;Possible values include: 0: Always. 1: Display except when the signature is valid. 2: Never. This value disables bShowWarningForChanges and removes the Hide signature field validity icon option from the GUI. This setting does not affect the icons in the Signatures Pane or in the Signature Properties dialog Note : This UI item was removed from versions 9.x and later because signature status was moved to the Document Message Bar.</string>
      <string id="bReqSigPropVerification_User">Sig Property Verify</string>
      <string id="bReqSigPropVerification_User_Explain">Specifies whether signature property verification must succeed for a signature to be valid.&#10;&#10;As of 8.0, the only property used is the timestamp URL.</string>
      <string id="iSigVerificationTime_User">Sig Verification Time</string>
      <string id="iSigVerificationTime_User_Explain">Indicates the time at which signature validation should occur.&#10;&#10;Possible values include: 0: Always carry out the verification at current time 1: Use the signing time if it's secure (e.g. timestamped), else use current time 2: Always use signing time</string>
      <string id="bAllowSigCertOnly_User">Sign Certified Only</string>
      <string id="bAllowSigCertOnly_User_Explain">Specifies whether any subsequent signers can sign a certified document containing LegalPDF warnings with additional approval signatures.&#10;&#10;In other words, the presence of any LegalPDF warning prevent any additonal signatures.</string>
      <string id="isignDone_User">Sign Done Dialog</string>
      <string id="isignDone_User_Explain">Specifies whether to show a dialog indicating that a document was successfully signed.&#10;&#10;Possible values include: 0: Show the dialog after signing successfully. 1: Don't show the dialog after signing successfully.</string>
      <string id="bAllowSigCertGreenOnly_User">Sign Green Cert Only</string>
      <string id="bAllowSigCertGreenOnly_User_Explain">Specifies whether any subsequent signers can sign a certified document that does not contain LegalPDF warnings with additional approval signatures.&#10;&#10;In other words, the presence of any LegalPDF warning does not prevent any additonal signatures.</string>
      <string id="bSignRequest_User">Sign OCSP Requests</string>
      <string id="bSignRequest_User_Explain">Specifies whether the OCSP request should be signed.&#10;&#10;Some OCSP providers require that OCSP requests are signed (e.g IdenTrust). 0: Don't sign the OCSP request. 1: Force Acrobat to sign OCSP requests prior to sending.</string>
      <string id="iHashAlgo_User">Timestamp Hash Algo</string>
      <string id="iHashAlgo_User_Explain">Identifies the hashing algorithm used to hash the timestamped data.&#10;&#10;The valid values are: 0: MD5 1: SHA1 2: SHA256 For an alternative, see sHashAlgo which supports more options.</string>
      <string id="iSize_User">Timestamp Sig Size</string>
      <string id="iSize_User_Explain">ASPKI requires the signature property to predict the size (in bytes) so that enough space can be set aside.</string>
      <string id="bTrueTypeFontPDFSigQWarn_User">TrueType Font Warn</string>
      <string id="bTrueTypeFontPDFSigQWarn_User_Explain">Turns on and off warnings about True Type fonts.</string>
      <string id="bTrustCertifiedDocuments_User">Trust Certified Docs</string>
      <string id="bTrustCertifiedDocuments_User_Explain">Elevates (trusts) certified documents as a privileged location.&#10;&#10;This setting allows certified documents to bypass all the security restrictions that may be bypassed by other privileged locations. The exception is that this level of trust does not apply when the PDF is viewed in Protected View. To lock this setting, set bEnableCertificateBasedTrust . Possible values include: 0 or null: Don't make certified documents equivalent to privileged locations. 1: Do make certified documents equivalent to privileged locations (trusted).</string>
      <string id="bTrustOSTrustedSites_User">Trust IE Trusted Sites</string>
      <string id="bTrustOSTrustedSites_User_Explain">Elevates locations that Internet Explorer trusts to privileged locations so that they may bypass security restrictions.&#10;&#10;Prior to 10.1.1 and 9.4.7, trust was granted to Trusted Sites. With 10.1.2 and 9.5 and later, trust also includes Local Intranet zones. This setting essentially makes IE trust operate as if they were privileged locations. The feature can be disabled with bDisableOSTrustedSites. 0: Don't automatically trust Windows OS zones. 1: Do automatically trust Windows OS zones.</string>
      <string id="iURLPerms_User">URL Access Permissions</string>
      <string id="iURLPerms_User_Explain">Specifies whether to allow or block all websites or use a custom setting.&#10;&#10;If the user selects Custom Setting, tHostPerms is populated with the user's custom URLs. If Allow or Block is later selected, then iURLPerms overrides tHostPerms and tHostPerms is reset to null (the user list is ignored). Possible values include: 0: Custom Setting 1: Block all websites 2: Allow all websites For additional security-related details, refer to the Application Security Guide .</string>
      <string id="iUseArchivedRevInfo_User">Use Archived Rev Info</string>
      <string id="iUseArchivedRevInfo_User_Explain">Indicates whether the revocation information archived with the signature is used for revocation checking.&#10;&#10;Allowable values include: 0: Never (always require fresh revocation information to be successfully downloaded). 1: Deprecated. Do not use. 2: Always use (if embedded revocation information is available do not download fresh revocation information).</string>
      <string id="iValidityModel_User">Validity Model</string>
      <string id="iValidityModel_User_Explain">Specifies the validity model for validating signatures and certificates.&#10;&#10;The application uses shell validation by default, but chain validation may be used when required. Compliance with the German signature law requires chain validation. Allowabled values include: 0: PKIX shell model 1: Chain validity model. Chain validation is used to validate all or part of a certificate chain when any certificate chaining up to a CA certificate containing the qualified certificate policy extension (OID 1.3.36.8.1.1) or the validity model certificate extension OID (1.3.6.1.4.1.8301.3.5) with the value set to the chain model OID (1.3.6.1.4.1.8301.3.5.1).</string>
      <string id="iMSStoreTrusted_User">Windows Store Trust</string>
      <string id="iMSStoreTrusted_User_Explain">Controls whether or not certificates in the Windows Certificate Store are trusted for signing and certifying.&#10;&#10;To lock this setting, use bMSStoreTrusted. Allowable values include: 0x00: No checkbox selected. 0x60: Validating Signatures. 0x62: Validating Certified Documents and Signatures. Note that this setting disables the Validating Signatures checkbox because it also controls non-certified signatures and users should not be able to uncheck that checkbox.</string>

      <!-- ======================================== -->
      <!--           Sharing and Features           -->
      <!-- ======================================== -->

      <string id="iSendMailDefaultAccountAlert_User">Default Email Prompt</string>
      <string id="iSendMailDefaultAccountAlert_User_Explain">Specifies whether a dialog should appear asking if a PDF should be sent via the user's default email account.&#10;&#10;When a new user tries to send a PDF via email, a dialog appears and asks &quot;How would you like to send this email.&quot; Users then need to select a choice and check Remember my choice . Possible values include: 0: Don't show the dialog. 1: Do show the dialog.</string>
      <string id="bDefaultSet_User">Default Email Set</string>
      <string id="bDefaultSet_User_Explain">Indicates whether a default email client has been set.&#10;&#10;Possible values include: 0: Default webmail client is not set. 1: Default webmail client is set.</string>
      <string id="bDisableSharedReview_User">Disable Shared Review</string>
      <string id="bDisableSharedReview_User_Explain">Specifies whether to enable cloud-based shared reviews.&#10;&#10;To completely disable the Document Cloud Review service, disable all services or set bToggleAdobeReview (See FeatureLockDown for details). When set to 0, this preference removes Document Cloud Review service, including the Send for Review tool in the tool's pane and its associated menus. Possible values include: 0: Remove the option to use the DC review service when a user chooses Tools ) Send for Review OR Send for Review in the right-hand pane. Only legacy review types are available. 1: Enable the Document Cloud Review service option.</string>
      <string id="bNeedSynchronizer_User">Enable Synchronizer</string>
      <string id="bNeedSynchronizer_User_Explain">Disables the synchronizer.&#10;&#10;Features that use the synchronizer include services, the Adobe Acrobat Trust List, shared reviews, the recent files list (11.0.07+), and data collection in some forms workflows prior to 11.0.07. Disabling the Synchronizer is not recommended. Possible values include: 0: Disable the synchronizer. 1: Enable the synchronizer. Note that Acrobat and Reader do not use the same synchronizer. When there is an older minor version of Acrobat or Reader and the newer minor version is 11.0.07-11.1.10: Both Acrobat and Reader get the new synchronizer when updating to .07 or later. If the newer synchronizer is running, it supports older services and non-services operations. If the older synchronizer (pre 11.0.07) is running, sync-dependent operations do not work [3746864]</string>
      <string id="bEnableFillSign_User">Fill &amp; Sign Pane</string>
      <string id="bEnableFillSign_User_Explain">Specifies whether to remove the Fill and Sign pane without removing the Work with Certificates menu.&#10;&#10;11.x products only. This setting allows users to remove the Acrobat Sign menu items without removing the menu item for using digital signatures on the local machine. Possible values include: 0: Remove the Fill and Sign pane. 1: Don't remove the Fill and Sign pane.</string>
      <string id="bRemoveCommaDelimiter_User">Remove Comma Delimiter</string>
      <string id="bRemoveCommaDelimiter_User_Explain">Specifies whether to remove the comma in comma-delimited addressbook entries.&#10;&#10;During shared review workflows, the user invoke the addressbook to invite participants. In cases where the addressbook is comma-delimited, pre DC versions of the product display an error dialog. Use this prefererence to remove commas. Possible values include: 0: Don't remove commas. 1: Remove commas.</string>
      <string id="iSendForReviewConfirm_User">Review Confirm Alert</string>
      <string id="iSendForReviewConfirm_User_Explain"></string>
      <string id="bShowConnectDialog_User">Show Connect Dialog</string>
      <string id="bShowConnectDialog_User_Explain">Specifies whether to display the Connect dialog in Shared Reviews.&#10;&#10;Possible values include: 0: Don't show the Connect dialog. 1: Do show the Connect dialog.</string>
      <string id="bShowWelcomeDialog_User">Show Welcome Dialog</string>
      <string id="bShowWelcomeDialog_User_Explain">Specifies whether to show the Welcome dialog when a shared review is initiated.&#10;&#10;Possible values include: 0: Don't show the welcome dialog. 1: Do show the welcome dialog.</string>

      <!-- ======================================== -->
      <!--          Startup and Experience          -->
      <!-- ======================================== -->

      <string id="bActivated_User">App Activated</string>
      <string id="bActivated_User_Explain">Records whether the application has been activated online after installation.&#10;&#10;Possible values include: 0: Not activated 1: Activated</string>
      <string id="bHasLaunched_User">App Has Launched</string>
      <string id="bHasLaunched_User_Explain">Records whether the application has been launched after installation.&#10;&#10;Possible values include: 0: Not launched 1: Launched</string>
      <string id="bAppInitialized_User">App Initialized</string>
      <string id="bAppInitialized_User_Explain">Records whether the application has been initialized after installation.&#10;&#10;Possible values include: 0: Not initialized 1: Initialized</string>
      <string id="bLaunched_User">App Launched</string>
      <string id="bLaunched_User_Explain">Caches whether or not the application has ever been launched.&#10;&#10;Application behavior may vary across versions depending on whether the application has been launched. Possible values include: 0: The application has not been launched. 1: The application has been launched.</string>
      <string id="bChooseLangAtStartup_User">Choose Language Startup</string>
      <string id="bChooseLangAtStartup_User_Explain">Allows the user to choose the language at startup.</string>
      <string id="bCreateFormDiscoveryShown_User">Create Form Onboarding</string>
      <string id="bCreateFormDiscoveryShown_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Create Form panel.&#10;&#10;Possible values include: 0: Show the onboarding coachmark. 1: Don't show the onboarding coachmark.</string>
      <string id="bEditDiscoveryShown_User">Edit Onboarding</string>
      <string id="bEditDiscoveryShown_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Edit panel.&#10;&#10;Possible values include: 0: Show the onboarding coachmark. 1: Don't show the onboarding coachmark.</string>
      <string id="iEULAAcceptanceTime_User">EULA Accept Timeout</string>
      <string id="iEULAAcceptanceTime_User_Explain">The amount of time granted to users after installation to accept the end user agreement.</string>
      <string id="EULA_User">EULA Acceptance</string>
      <string id="EULA_User_Explain">For Reader, indicates whether the EULA has been accepted.&#10;&#10;If the EULA is not accepted, the application stops running after a set period of time. Possible values include: 0: Show the EULA because it has not been accepted. 1: Don't show the EULA because it has not been accepted.</string>
      <string id="bFillSignDiscoveryShown_User">Fill &amp; Sign Onboarding</string>
      <string id="bFillSignDiscoveryShown_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Fill &amp; Sign panel.&#10;&#10;Possible values include: 0: Show the onboarding coachmark. 1: Don't show the onboarding coachmark.</string>
      <string id="bHideHelpWelcome_User">Hide Help Welcome</string>
      <string id="bHideHelpWelcome_User_Explain">Specifies whether to disable the Welcome menu item under Help.&#10;&#10;Possible values include: 0 or null: Enable the Welcome menu item. 1: Disable the Welcome menu item.</string>
      <string id="bShownHomeOnboarding_User">Home Onboarding</string>
      <string id="bShownHomeOnboarding_User_Explain">Specifies whether to invoke the home onboarding tour when the modern viewer is invoked the first time.&#10;&#10;Once the home onboarding tour displays, the app automatically resets this value to 0. This preference has no effect if AVGeneral/bEnableAv2 is 0. Possible values include: 0: Show the onboarding tour (not yet shown). 1: Don't show the onboarding tour (already shown or declined).</string>
      <string id="bLoadAllPluginsAtStartup_User">Load All Plugins</string>
      <string id="bLoadAllPluginsAtStartup_User_Explain">Specifies whether all plugins should be loaded when the application is started.</string>
      <string id="bOrganizeDiscoveryShown_User">Organize Onboarding</string>
      <string id="bOrganizeDiscoveryShown_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Organize panel.&#10;&#10;Possible values include: 0: Show the onboarding coachmark. 1: Don't show the onboarding coachmark.</string>
      <string id="bUsePageCache_User">Page Caching</string>
      <string id="bUsePageCache_User_Explain">Specifies whether to cache pages that have been loaded.&#10;&#10;Possible values include: 0: Don't cache pages. 1: Do cache pages</string>
      <string id="bRedactDiscoveryShown_User">Redaction Onboarding</string>
      <string id="bRedactDiscoveryShown_User_Explain">Specifies whether to show the onboarding coachmark when the user invokes the Redaction panel.&#10;&#10;Possible values include: 0: Show the onboarding coachmark. 1: Don't show the onboarding coachmark.</string>
      <string id="bDisplayAboutDialog_User">Show About Dialog</string>
      <string id="bDisplayAboutDialog_User_Explain">Specifies whether or not to display the startup splash screen at every launch.&#10;&#10;Possible values include: 0: Don't display the startup splash screen. 1: Display the startup splash screen at every launch.</string>
      <string id="idontShowAllImagesHaveAltText_User">Show Alt Text Alert</string>
      <string id="idontShowAllImagesHaveAltText_User_Explain">Toggles whether to show an alert when a user executes the Set Alternate Text dialog and there are no images missing alternate text.&#10;&#10;Possible values include: 0: Show alert. 1: Don't show alert.</string>
      <string id="bshowEULA_User">Show EULA Startup</string>
      <string id="bshowEULA_User_Explain">Toggles on and off whether the end user license agreement appears.</string>
      <string id="bLastShowStatus_User">Show Getting Started</string>
      <string id="bLastShowStatus_User_Explain">Specifies whether to show &quot;Get Started with Acrobat&quot; on startup.&#10;&#10;Possible values include: 0: Don't show the Getting Started page. 1: Show the Getting Started page.</string>
      <string id="bShowHorizontalScrollbar_User">Show H-Scrollbar</string>
      <string id="bShowHorizontalScrollbar_User_Explain">Specifies whether to show a horizontal scrollbar when the viewing area is narrower than the width of the loaded document.&#10;&#10;Possible values include: 0: Disable the horizontal scrollbar. 1: Enable the horizontal scrollbar.</string>
      <string id="bShowExistingAttachedReportAlert_User">Show Report Alert</string>
      <string id="bShowExistingAttachedReportAlert_User_Explain">Toggles whether to show an alert when a user tries to attach a report if there is already a report attached.&#10;&#10;Possible values include: 0: Show alert. 1: Don't show alert.</string>
      <string id="idontShowSetAltTextInfo_User">Show Set Alt Alert</string>
      <string id="idontShowSetAltTextInfo_User_Explain">Toggles whether to show an informative alert when a user executes the Set Alternate Text dialog.&#10;&#10;Possible values include: 0: Show alert. 1: Don't show alert.</string>
      <string id="bShowedSkipCard_User">Show Skip Card</string>
      <string id="bShowedSkipCard_User_Explain">Specifies whether to show the skipped onboarding coachmark.&#10;&#10;Possible values include: 0: Disables the feature. 1: Enables the feature.</string>
      <string id="bSplashDisplayedAtStartup_User">Show Splash Screen</string>
      <string id="bSplashDisplayedAtStartup_User_Explain">Toggles whether the splash screen appears on startup.</string>
      <string id="bDisplayedSplash_User">Splash Displayed</string>
      <string id="bDisplayedSplash_User_Explain">Indicates whether or not the application has started up and invoked the splash screen.&#10;&#10;Possible values include: 0: The splash screen has not been invoked yet. 1: The splash screen has been invoked.</string>
      <string id="bInTrialMode_User">Trial Mode Active</string>
      <string id="bInTrialMode_User_Explain">Records whether the application is operating in Trial Mode.&#10;&#10;Possible values include: 0: Not in trial mode 1: In trial mode</string>
      <string id="bShownViewerOnboarding_User">Viewer Onboarding</string>
      <string id="bShownViewerOnboarding_User_Explain">Specifies whether to invoke the new viewer onboarding tour when a PDF opens in the modern viewer the first time.&#10;&#10;Once the viewer onboarding tour displays, the app automatically resets this value to 0. This preference has no effect if AVGeneral/bEnableAv2 is 0. Possible values include: 0: Show the onboarding tour (not yet shown). 1: Don't show the onboarding tour (already shown or declined).</string>
      <string id="iDelayBeforeQuitViewer_User">Viewer Quit Delay</string>
      <string id="iDelayBeforeQuitViewer_User_Explain">Specifies the number of seconds the standalone application stays in memory before it shuts down.&#10;&#10;Possible values include: 30 Any integer</string>

      <!-- ======================================== -->
      <!--     Updates and Desktop Integration      -->
      <!-- ======================================== -->

      <string id="bDownloadEntireFile_User">Background Download</string>
      <string id="bDownloadEntireFile_User_Explain">Specifies whether to allow background downloading of resources the view thinks it needs to properly display the PDF.&#10;&#10;Possible values include: 0: Don't allow background downloading. 1: Do allow background downloading.</string>
      <string id="iDelayBeforeQuitBrowser_User">Browser Quit Delay</string>
      <string id="iDelayBeforeQuitBrowser_User_Explain">Specifies the number of seconds the browser-based application stays in memory before it shuts down.&#10;&#10;Possible values include: 30 Any integer</string>
      <string id="bBrowserDisplayInReadMode_User">Browser Read Mode</string>
      <string id="bBrowserDisplayInReadMode_User_Explain">Specifies whether to open documents in a browser in Read Mode.&#10;&#10;Read Mode was introduced in Acrobat and Reader 10.0 to enhance the PDF viewing experience for documents in a browser. Read Mode turns off the standard toolbars and menu items and provides a more compact and simple menu bar only when a user hovers over the bottom, middle area of the PDF. For more information, see the Browser Integration Quick Key in the Quick Key Library . Possible values include: 0: Don't use Read Mode and display the standard toolbars. 1: Use Read Mode and hide the standard toolbars.</string>
      <string id="bInstalledCleanupCheckDone_User">Cleanup Check Done</string>
      <string id="bInstalledCleanupCheckDone_User_Explain">A preference used by the usage measurement feature to determine whether the previously set UsageMeasurement-related keys should be reset.</string>
      <string id="bLoadOnStart_User">Collab Sync Startup</string>
      <string id="bLoadOnStart_User_Explain">Specifies whether the collaboration executable should be invoked and run as a background process on startup.&#10;&#10;When enabled, AdobeCollabSync.exe runs on application startup. This process is used for features like shared reviews and forms data collection . Possible values include: 0: Start the process. 1: Don't start the process.</string>
      <string id="bAllowByteRangeRequests_User">Fast Web View</string>
      <string id="bAllowByteRangeRequests_User_Explain">Specifies whether to enable Fast Web View by allowing display of the PDF before the entire file is downloaded.&#10;&#10;Possible values include: 0: Don't enable Fast Web View. 1: Enable Fast Web View.</string>
      <string id="bFavoriteFilesRememberChoice_User">Remember Stars Choice</string>
      <string id="bFavoriteFilesRememberChoice_User_Explain">Specifies the users choice&#10;&#10;When a user selects &quot;Ask every time&quot; and iFavoriteFilesAccessOption is set to 0, this new preference remembers the users choice for each file. Possible values include: Application generated.</string>
      <string id="bFavoritesStripInRFL_User">Show Starred Files</string>
      <string id="bFavoritesStripInRFL_User_Explain">Specifies whether to show starred files in the recent files list.&#10;&#10;A starred file is somewhat similar to a &quot;favorited&quot; file. Note that the lockable version of this preference is named bFavoritesFeaturesLockDown . Possible values include: 0: Show starred files in the recent files list. 1: Don't show starred files in the recent files list.</string>
      <string id="iFavoriteFilesAccessOption_User">Starred Files Action</string>
      <string id="iFavoriteFilesAccessOption_User_Explain">Specifies what action to take when starring a file.&#10;&#10;A starred file is somewhat similar to a &quot;favorited&quot; file. Possible values include: 0: Show a dialog and ask whether to save or upload. This option also results in creating a new bFavoriteFilesRememberChoice . 1: Upload to Document Cloud 2: Save the file locally</string>
      <string id="bStoreCredentials_User">Store Credentials</string>
      <string id="bStoreCredentials_User_Explain">Specifies whether the user logon credentials for the Tracker should be stored.&#10;&#10;Possible values include: 0: Don't store credentials. 1: Store credentials.</string>
      <string id="iAVARMNoAutoUpdateWarning_User">Suppress Update Warning</string>
      <string id="iAVARMNoAutoUpdateWarning_User_Explain">Specifies whether to turn of the &quot;Updater has not been able to check for updates recently&quot; dialog.&#10;&#10;Possible values include: 0: Don't turn off the dialog. 1: Do turn off the dialog.</string>

      <!-- ======================================== -->
      <!--                  Upsell                  -->
      <!-- ======================================== -->

      <string id="bAcrobatAppInstalled_User">Acrobat App Promo</string>
      <string id="bAcrobatAppInstalled_User_Explain">Specifies whether to show the Acrobat mobile app promotion and link in the Home banner.&#10;&#10;Disable and lock both the App Center and Home banner with bToggleDCAppCenter under FeatureLockDown. Possible values include: 0: Promote the mobile app. 1: Don't promote the mobile app.</string>
      <string id="bScanAppInstalled_User">Scan App Promo</string>
      <string id="bScanAppInstalled_User_Explain">Specifies whether to show the Adobe Scan mobile app promotion and link in the Home banner.&#10;&#10;Disable and lock both the App Center and Home banner with bToggleDCAppCenter under FeatureLockDown. Possible values include: 0: Promote the mobile app. 1: Don't promote the mobile app.</string>
    </stringTable>

  </resources>
</policyDefinitionResources>