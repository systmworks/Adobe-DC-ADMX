    <!-- Context, Tools and Search > UI Switcher Sessions -->
    <!-- iNumSessionAV2   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_7251 -->
    <policy class="Both" displayName="$(string.iNumSessionAV2DC_User)" explainText="$(string.iNumSessionAV2DC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral"
      name="iNumSessionAV2DC_User" valueName="iNumSessionAV2">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- ======================================== -->
    <!--   Documents, Editing and Accessibility   -->
    <!-- ======================================== -->

    <!-- Documents, Editing and Accessibility > 2D GPU Acceleration -->
    <!-- bUse2DGPUf   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVDisplay.html#idkeyname_1_4906 -->
    <policy class="Both" displayName="$(string.bUse2DGPUfDC_User)" explainText="$(string.bUse2DGPUfDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVDisplay"
      name="bUse2DGPUfDC_User" valueName="bUse2DGPUf">
