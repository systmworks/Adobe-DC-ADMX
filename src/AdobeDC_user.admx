<policyDefinitions xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  revision="1.6" schemaVersion="1.0"
  xmlns="http://schemas.microsoft.com/GroupPolicy/2006/07/PolicyDefinitions">
  <policyNamespaces>
    <target prefix="Adobe_User" namespace="Adobe.Policies.Adobe_User" />
  </policyNamespaces>
  <resources minRequiredRevision="1.6" />
  <supportedOn>
    <definitions>
      <definition displayName="$(string.SupportedAcrobatDC_User)" name="SupportedAcrobatDC_User"/>
      <definition displayName="$(string.SupportedReaderDC_User)" name="SupportedReaderDC_User"/>
    </definitions>
  </supportedOn>

  <categories>
    <!-- Parent Category -->
    <category displayName="$(string.AdobeCategory_User)" name="AdobeCategory_User"/>

    <!-- Acrobat DC (User) Category -->
    <category displayName="$(string.AcrobatDCCategory_User)" name="AcrobatDCCategory_User">
      <parentCategory ref="AdobeCategory_User"/>
    </category>
    <category displayName="$(string.Cat_ContextToolsSearch_User)" name="ContextToolsSearchCategoryDC_User">
      <parentCategory ref="AcrobatDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_DocsEditAccess_User)" name="DocsEditAccessCategoryDC_User">
      <parentCategory ref="AcrobatDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_MicrosoftPurviewMIP_User)" name="MicrosoftPurviewMIPCategoryDC_User">
      <parentCategory ref="AcrobatDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_SecurityExec_User)" name="SecurityExecCategoryDC_User">
      <parentCategory ref="AcrobatDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_SecurityTrust_User)" name="SecurityTrustCategoryDC_User">
      <parentCategory ref="AcrobatDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_SharingFeatures_User)" name="SharingFeaturesCategoryDC_User">
      <parentCategory ref="AcrobatDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_StartupExperience_User)" name="StartupExperienceCategoryDC_User">
      <parentCategory ref="AcrobatDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_UpdatesDesktop_User)" name="UpdatesDesktopCategoryDC_User">
      <parentCategory ref="AcrobatDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_Upsell_User)" name="UpsellCategoryDC_User">
      <parentCategory ref="AcrobatDCCategory_User"/>
    </category>

    <!-- Reader DC (User) Category -->
    <category displayName="$(string.ReaderDCCategory_User)" name="ReaderDCCategory_User">
      <parentCategory ref="AdobeCategory_User"/>
    </category>
    <category displayName="$(string.Cat_ContextToolsSearch_User)" name="ContextToolsSearchCategory_User">
      <parentCategory ref="ReaderDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_DocsEditAccess_User)" name="DocsEditAccessCategory_User">
      <parentCategory ref="ReaderDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_MicrosoftPurviewMIP_User)" name="MicrosoftPurviewMIPCategory_User">
      <parentCategory ref="ReaderDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_SecurityExec_User)" name="SecurityExecCategory_User">
      <parentCategory ref="ReaderDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_SecurityTrust_User)" name="SecurityTrustCategory_User">
      <parentCategory ref="ReaderDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_SharingFeatures_User)" name="SharingFeaturesCategory_User">
      <parentCategory ref="ReaderDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_StartupExperience_User)" name="StartupExperienceCategory_User">
      <parentCategory ref="ReaderDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_UpdatesDesktop_User)" name="UpdatesDesktopCategory_User">
      <parentCategory ref="ReaderDCCategory_User"/>
    </category>
    <category displayName="$(string.Cat_Upsell_User)" name="UpsellCategory_User">
      <parentCategory ref="ReaderDCCategory_User"/>
    </category>

  </categories>
  <policies>

    <!-- ======================================== -->
    <!--                                          -->
    <!--    Adobe Acrobat DC (User) - policies    -->
    <!--                                          -->
    <!-- ======================================== -->

    <!-- ======================================== -->
    <!--        Context, Tools and Search         -->
    <!-- ======================================== -->

    <!-- Context, Tools and Search > Column Select Halo -->
    <!-- iColumnSelectHalo   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/Selection.html#idkeyname_1_26748 -->
    <policy class="Both" displayName="$(string.iColumnSelectHaloDC_User)" explainText="$(string.iColumnSelectHaloDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\Selection"
      name="iColumnSelectHaloDC_User" valueName="iColumnSelectHalo">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Disable Sign in Office -->
    <!-- DisableSignInOffice   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureState.html#idkeyname_1_13625 -->
    <policy class="Both" displayName="$(string.DisableSignInOfficeDC_User)" explainText="$(string.DisableSignInOfficeDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\FeatureState"
      name="DisableSignInOfficeDC_User" valueName="DisableSignInOffice">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Enable Sign in Office -->
    <!-- EnableSignInOffice   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureState.html#idkeyname_1_13581 -->
    <policy class="Both" displayName="$(string.EnableSignInOfficeDC_User)" explainText="$(string.EnableSignInOfficeDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\FeatureState"
      name="EnableSignInOfficeDC_User" valueName="EnableSignInOffice">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Filename as Title -->
    <!-- bAlwaysUseFileNameAsDocTitle   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_5367 -->
    <policy class="Both" displayName="$(string.bAlwaysUseFileNameAsDocTitleDC_User)" explainText="$(string.bAlwaysUseFileNameAsDocTitleDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral"
      name="bAlwaysUseFileNameAsDocTitleDC_User" valueName="bAlwaysUseFileNameAsDocTitle">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Fixed Snapshot Resolution -->
    <!-- bUseFixedSnapshotResolution   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/Selection.html#idkeyname_1_26716 -->
    <policy class="Both" displayName="$(string.bUseFixedSnapshotResolutionDC_User)" explainText="$(string.bUseFixedSnapshotResolutionDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\Selection"
      name="bUseFixedSnapshotResolutionDC_User" valueName="bUseFixedSnapshotResolution">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Flash Player for 3D -->
    <!-- ADC4318556   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureState.html#idkeyname_1_14027 -->
    <policy class="Both" displayName="$(string.ADC4318556DC_User)" explainText="$(string.ADC4318556DC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\FeatureState"
      name="ADC4318556DC_User" valueName="ADC4318556">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Hand Tool Select -->
    <!-- bHandSelects   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/Selection.html#idkeyname_1_26642 -->
    <policy class="Both" displayName="$(string.bHandSelectsDC_User)" explainText="$(string.bHandSelectsDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\Selection"
      name="bHandSelectsDC_User" valueName="bHandSelects">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Max Recent Files -->
    <!-- iMaxMRUCntToBeStored   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_6500 -->
    <policy class="Both" displayName="$(string.iMaxMRUCntToBeStoredDC_User)" explainText="$(string.iMaxMRUCntToBeStoredDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral"
      name="iMaxMRUCntToBeStoredDC_User" valueName="iMaxMRUCntToBeStored">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Modern Viewer -->
    <!-- bEnableAv2   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_7055 -->
    <policy class="Both" displayName="$(string.bEnableAv2DC_User)" explainText="$(string.bEnableAv2DC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral"
      name="bEnableAv2DC_User" valueName="bEnableAv2">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Multiple Comment Panels -->
    <!-- bAllowMultipleExpandedPanels   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_5914 -->
    <policy class="Both" displayName="$(string.bAllowMultipleExpandedPanelsDC_User)" explainText="$(string.bAllowMultipleExpandedPanelsDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral\cTaskPanes\cBasicCommentPane"
      name="bAllowMultipleExpandedPanelsDC_User" valueName="bAllowMultipleExpandedPanels">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > New Look Coachmark -->
    <!-- iNumSwitcherContextualToolTipAV2Shown   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_7102 -->
    <policy class="Both" displayName="$(string.iNumSwitcherContextualToolTipAV2ShownDC_User)" explainText="$(string.iNumSwitcherContextualToolTipAV2ShownDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral"
      name="iNumSwitcherContextualToolTipAV2ShownDC_User" valueName="iNumSwitcherContextualToolTipAV2Shown">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Pin HUD Toolbar -->
    <!-- bPinHUD   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_5318 -->
    <policy class="Both" displayName="$(string.bPinHUDDC_User)" explainText="$(string.bPinHUDDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral"
      name="bPinHUDDC_User" valueName="bPinHUD">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Prompt Close Tabs -->
    <!-- bPromptBeforeClosingMultipleTabs   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_5411 -->
    <policy class="Both" displayName="$(string.bPromptBeforeClosingMultipleTabsDC_User)" explainText="$(string.bPromptBeforeClosingMultipleTabsDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral"
      name="bPromptBeforeClosingMultipleTabsDC_User" valueName="bPromptBeforeClosingMultipleTabs">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Select Images First -->
    <!-- bImagesFirst   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/Selection.html#idkeyname_1_26684 -->
    <policy class="Both" displayName="$(string.bImagesFirstDC_User)" explainText="$(string.bImagesFirstDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\Selection"
      name="bImagesFirstDC_User" valueName="bImagesFirst">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Show Tool Pane Tips -->
    <!-- bInfobubble   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_6091 -->
    <policy class="Both" displayName="$(string.bInfobubbleDC_User)" explainText="$(string.bInfobubbleDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral"
      name="bInfobubbleDC_User" valueName="bInfobubble">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Show Touch Keyboard -->
    <!-- bKeyPrefsShowVirtualKeyoard   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_5455 -->
    <policy class="Both" displayName="$(string.bKeyPrefsShowVirtualKeyoardDC_User)" explainText="$(string.bKeyPrefsShowVirtualKeyoardDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral"
      name="bKeyPrefsShowVirtualKeyoardDC_User" valueName="bKeyPrefsShowVirtualKeyoard">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Snapshot Resolution DPI -->
    <!-- iSnapshotResolution   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/Selection.html#idkeyname_1_26780 -->
    <policy class="Both" displayName="$(string.iSnapshotResolutionDC_User)" explainText="$(string.iSnapshotResolutionDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\Selection"
      name="iSnapshotResolutionDC_User" valueName="iSnapshotResolution">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Suppress PDF/UA Dialog -->
    <!-- 4406238   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/FeatureState.html#idkeyname_1_13278 -->
    <policy class="Both" displayName="$(string.ADC4406238DC_User)" explainText="$(string.ADC4406238DC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\FeatureState"
      name="ADC4406238DC_User" valueName="4406238">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="0" />
      </enabledValue>
      <disabledValue>
        <decimal value="1" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Tools Pane State -->
    <!-- irightPaneState   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_5867 -->
    <policy class="Both" displayName="$(string.irightPaneStateDC_User)" explainText="$(string.irightPaneStateDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral\cTaskPanes"
      name="irightPaneStateDC_User" valueName="irightPaneState">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Context, Tools and Search > Tools Pane Sticky -->
    <!-- iBasicSharePaneStickyStatus   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/AVGeneral.html#idkeyname_1_5823 -->
    <policy class="Both" displayName="$(string.iBasicSharePaneStickyStatusDC_User)" explainText="$(string.iBasicSharePaneStickyStatusDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\AVGeneral\cTaskPanes"
      name="iBasicSharePaneStickyStatusDC_User" valueName="iBasicSharePaneStickyStatus">
      <parentCategory ref="ContextToolsSearchCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
