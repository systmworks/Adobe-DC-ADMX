    <!-- Documents, Editing and Accessibility > Assistive Technology -->
    <!-- bEnableAT   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/Access.html#idkeyname_1_530 -->
    <policy class="Both" displayName="$(string.bEnableATDC_User)" explainText="$(string.bEnableATDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\Access"
      name="bEnableATDC_User" valueName="bEnableAT">
      <parentCategory ref="DocsEditAccessCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
        <decimal value="0" />
      </disabledValue>
    </policy>

    <!-- Documents, Editing and Accessibility > Attach Report -->
    <!-- bAttachLog   https://www.adobe.com/devnet-docs/acrobatetk/tools/PrefRef/Windows/Accessibility.html#idkeyname_1_746 -->
    <policy class="Both" displayName="$(string.bAttachLogDC_User)" explainText="$(string.bAttachLogDC_User_Explain)" key="Software\Adobe\Adobe Acrobat\DC\Accessibility\cAccCheckerOptions"
      name="bAttachLogDC_User" valueName="bAttachLog">
      <parentCategory ref="DocsEditAccessCategoryDC_User"/>
      <supportedOn ref="SupportedAcrobatDC_User"/>
      <enabledValue>
        <decimal value="1" />
      </enabledValue>
      <disabledValue>
